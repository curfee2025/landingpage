---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/shared/Header.astro';
import Footer from '@/components/shared/Footer.astro';
import { getTranslations } from '@/i18n/translations';
import '@/styles/global.css';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  dateModified?: string;
  datePublished?: string;
  ogType?: 'website' | 'article' | 'profile';
  noindex?: boolean;
  showHeader?: boolean;
}

const t = getTranslations();

const {
  title,
  description = t['meta.home.description'],
  canonicalPath = '',
  jsonLd,
  dateModified,
  datePublished,
  ogType = 'website',
  noindex = false,
  showHeader = true,
} = Astro.props;

const siteUrl = 'https://curfee.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/assets/og-image.png`;

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#founder`,
  "name": "Philipp Höllinger",
  "givenName": "Philipp",
  "familyName": "Höllinger",
  "jobTitle": t['meta.about.jobTitle'],
  "description": "Philipp Höllinger is a systems, software and infrastructure architect based in Salzburg, Austria, and the sole founder of Curfee e.U. (founded 2026). He consults on systems, software and infrastructure architecture and root-cause analysis, applying the Decision Enforcement Principle: architectural decisions are enforced by the system itself through pipelines, automated checks, and tool configuration, rather than by the discipline, memory, or vigilance of individual people.",
  "url": siteUrl,
  "mainEntityOfPage": `${siteUrl}/#about`,
  "image": {
    "@type": "ImageObject",
    "url": `${siteUrl}/assets/profile.webp`,
    "contentUrl": `${siteUrl}/assets/profile.webp`,
    "caption": "Portrait of Philipp Höllinger, systems, software and infrastructure architect and founder of Curfee",
    "width": 180,
    "height": 225
  },
  "sameAs": ["https://www.linkedin.com/in/phoellinger"],
  "nationality": { "@type": "Country", "name": "Austria" },
  "knowsAbout": [
    "Systems Architecture",
    "Software Architecture",
    "Infrastructure Architecture",
    "System Analysis",
    "IT Consulting",
    "Root Cause Analysis",
    "Dependency Mapping",
    "Decision Enforcement",
    "Decision Enforcement Principle",
    "Standards and Conventions Design",
    "Tool Landscape Assessment",
    "Structural Consulting",
    "Change Management",
    "Quality Assurance",
    "System Development",
    "Onboarding",
    "Collaboration",
    "Knowledge Transfer"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": "Systems, Software & Infrastructure Architect",
    "occupationLocation": { "@id": `${siteUrl}/#place-salzburg` },
    "occupationalCategory": {
      "@type": "CategoryCode",
      "codeValue": "15-1199.02",
      "name": "Computer Systems Engineer/Architect",
      "inCodeSet": {
        "@type": "CategoryCodeSet",
        "name": "O*NET-SOC"
      }
    },
    "skills": "Systems architecture, software architecture, infrastructure architecture, root cause analysis, dependency mapping, decision enforcement, standards and conventions design, tool landscape assessment"
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "German", "alternateName": "de" },
    { "@type": "Language", "name": "English", "alternateName": "en" }
  ],
  "worksFor": { "@id": `${siteUrl}/#organization` },
  "memberOf": { "@id": `${siteUrl}/#organization` },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  }
};

const placeLd = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": `${siteUrl}/#place-salzburg`,
  "name": "Salzburg, Austria",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8066,
    "longitude": 13.0089
  }
};

const organizationLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "ProfessionalService", "LocalBusiness"],
  "@id": `${siteUrl}/#organization`,
  "name": "Curfee",
  "legalName": "Curfee e.U.",
  "alternateName": ["Curfee Systems, Software & Infrastructure Architecture Consulting", "Curfee Consulting"],
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/assets/og-image.png`,
    "width": 1200,
    "height": 630,
    "caption": "Curfee"
  },
  "image": { "@id": `${siteUrl}/#logo` },
  "description": t['meta.home.jsonld.description'],
  "slogan": t['footer.tagline'],
  "founder": { "@id": `${siteUrl}/#founder` },
  "employee": { "@id": `${siteUrl}/#founder` },
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 1 },
  "foundingDate": "2026",
  "foundingLocation": { "@id": `${siteUrl}/#place-salzburg` },
  "location": { "@id": `${siteUrl}/#place-salzburg` },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8066,
    "longitude": 13.0089
  },
  "areaServed": [
    { "@type": "Country", "name": "Austria", "alternateName": "AT" },
    { "@type": "Country", "name": "Germany", "alternateName": "DE" },
