    "name": "DACH region"
  },
  "knowsAbout": [
    "Systems Architecture",
    "Software Architecture",
    "Infrastructure Architecture",
    "System Analysis",
    "IT Consulting",
    "Root Cause Analysis",
    "Dependency Mapping",
    "Decision Enforcement Principle",
    "Standards and Conventions Design",
    "Tool Landscape Assessment",
    "Structural Consulting",
    "Technical Debt Resolution",
    "Change Management",
    "Quality Assurance",
    "System Development",
