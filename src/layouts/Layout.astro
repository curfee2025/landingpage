---
import { ClientRouter } from 'astro:transitions';
import Header from '@/components/shared/Header.astro';
import Footer from '@/components/shared/Footer.astro';
import ScrollToTop from '@/components/shared/ScrollToTop.astro';
import CookieBanner from '@/components/shared/CookieBanner.astro';
import { getLangFromUrl, getAlternateUrl } from '@/i18n/utils';
import { getTranslations } from '@/i18n/translations';
import '@/styles/global.css';

import type { Lang } from '@/configurations/i18n';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  lang?: Lang;
  dateModified?: string;
}

const lang = Astro.props.lang ?? getLangFromUrl(Astro.url);
const translations = getTranslations(lang);

const {
  title,
  description = translations['meta.home.description'],
  canonicalPath = '',
  jsonLd,
  dateModified,
} = Astro.props;

const siteUrl = 'https://curfee.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/assets/og-image.png`;
const alternate = getAlternateUrl(Astro.url, siteUrl);
const ogLocale = lang === 'de' ? 'de_DE' : 'en_US';
const ogLocaleAlt = lang === 'de' ? 'en_US' : 'de_DE';

const organizationLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": `${siteUrl}/#organization`,
  "name": "Curfee",
  "legalName": "Curfee e.U.",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/assets/og-image.png`,
    "width": 1200,
    "height": 630
  },
  "description": translations['meta.home.jsonld.description'],
  "founder": {
    "@type": "Person",
    "@id": `${siteUrl}/#founder`,
    "name": "Philipp Höllinger",
    "jobTitle": translations['meta.about.jobTitle']
  },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Salzburg",
    "addressCountry": "AT"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "office@curfee.com",
    "contactType": "customer service"
  },
  "sameAs": ["https://www.linkedin.com/in/phoellinger"]
};

const speakableLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "url": canonicalUrl,
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["[aria-labelledby] h1, [aria-labelledby] h2, main > :first-child h1, main > :first-child p:first-of-type"]
  }
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' data: https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com; frame-src 'none'; base-uri 'self'; form-action 'self'" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {dateModified && <meta name="article:modified_time" content={dateModified} />}

    <!-- Preload critical fonts -->
    <link rel="preload" href="/assets/fonts/quicksand/quicksand_latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/google_sans/google_sans_regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/assets/fonts/google_sans/google_sans_medium.woff2" as="font" type="font/woff2" crossorigin />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={alternate.en} />
    <link rel="alternate" hreflang="de" href={alternate.de} />
    <link rel="alternate" hreflang="x-default" href={alternate.de} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Curfee" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicons -->
    <link rel="icon" href="/assets/favicons/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/assets/favicons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/favicons/favicon_32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/assets/favicons/favicon_16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/assets/favicons/apple_touch_icon.png" />
    <link rel="manifest" href="/assets/favicons/site.webmanifest" />
    <meta name="theme-color" content="#003366" />

    <!-- Structured Data — Sitewide Organization + Speakable -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(speakableLd)} />
    <!-- Structured Data — Page-specific -->
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((ld) => (
            <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
          ))
        : <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <ClientRouter />
  </head>
  <body>
    <div class="relative min-h-screen overflow-hidden">
      <div class="pointer-events-none absolute -inset-32" style="filter: blur(80px);" aria-hidden="true">
        <div class="absolute inset-0 bg-gradient-to-br from-brand-primary/35 via-brand-tertiary/16 to-brand-secondary/20 mask-radial" />
        <div class="absolute inset-0 bg-gradient-to-tr from-brand-secondary/22 via-brand-tertiary/18 to-brand-primary/35 mask-radial-2" />
        <div class="absolute inset-0 bg-gradient-to-tl from-brand-tertiary/20 via-brand-primary/12 to-transparent mask-radial-3" />
      </div>
      <div class="pointer-events-none absolute inset-0 opacity-[0.035] mix-blend-overlay" aria-hidden="true" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 512 512%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22n%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%225%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23n)%22/%3E%3C/svg%3E');" />

      <div class="relative z-10">
        <Header lang={lang} translations={translations} />
        <main class="pt-12 md:pt-16">
          <slot />
        </main>
        <Footer lang={lang} translations={translations} />
      </div>
    </div>

    <ScrollToTop />
    <CookieBanner lang={lang} translations={translations} />
  </body>
</html>
