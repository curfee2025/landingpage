  "vatID": "ATU83146203",
  "taxID": "ATU83146203",
  "identifier": [
    { "@type": "PropertyValue", "propertyID": "VAT", "value": "ATU83146203" },
    { "@type": "PropertyValue", "propertyID": "GISA", "value": "39453891" }
  ],
  "memberOf": {
    "@type": "Organization",
    "name": "Wirtschaftskammer Österreich",
    "alternateName": "WKO",
    "url": "https://www.wko.at"
  },
  "keywords": [
    "systems software and infrastructure architecture consulting",
    "systems architecture consulting",
    "software architecture consulting",
    "infrastructure architecture consulting",
    "decision enforcement",
    "architecture governance automation",
    "root cause analysis",
    "system landscape assessment",
    "dependency mapping",
    "standards enforcement pipelines",
    "structural consulting",
    "IT consulting Austria",
