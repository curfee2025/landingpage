  ],
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "email": "office@curfee.com",
      "telephone": "+4367763024228",
      "contactType": "customer service",
      "availableLanguage": ["en"],
      "areaServed": ["AT", "DE", "CH"]
    },
    {
      "@type": "ContactPoint",
      "email": "office@curfee.com",
      "contactType": "sales",
      "availableLanguage": ["en"]
    }
  ],
  "potentialAction": {
    "@type": "CommunicateAction",
    "name": "Contact by email",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "mailto:office@curfee.com",
      "inLanguage": ["en"]
    }
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "German", "alternateName": "de" },
    { "@type": "Language", "name": "English", "alternateName": "en" }
