---
import { ClientRouter } from 'astro:transitions';
import Footer from '@/components/shared/Footer.astro';
import ScrollToTop from '@/components/shared/ScrollToTop.astro';
import CookieBanner from '@/components/shared/CookieBanner.astro';
import { getTranslations } from '@/i18n/translations';
import { getAlternateUrl } from '@/i18n/utils';
import '@/styles/global.css';

import type { Lang } from '@/configurations/i18n';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  lang?: Lang;
  dateModified?: string;
  noindex?: boolean;
}

const lang = Astro.props.lang ?? 'de';
const t = getTranslations(lang);

const {
  title,
  description = t['meta.home.description'],
  canonicalPath = '',
  jsonLd,
  dateModified,
  noindex = false,
} = Astro.props;

const siteUrl = 'https://curfee.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/assets/og-image.png`;
const alternate = getAlternateUrl(Astro.url, siteUrl);
const ogLocale = lang === 'de' ? 'de_AT' : 'en_US';
const ogLocaleAlt = lang === 'de' ? 'en_US' : 'de_AT';
const htmlLang = lang === 'de' ? 'de-AT' : 'en';

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#founder`,
  "name": "Philipp Höllinger",
  "givenName": "Philipp",
  "familyName": "Höllinger",
  "jobTitle": t['meta.about.jobTitle'],
  "description": lang === 'de'
    ? "Systemarchitekt in Österreich. Gründer von Curfee. Beratung für Systemarchitektur und Ursachenanalyse – damit Architekturentscheidungen vom System selbst durchgesetzt werden, nicht von Personen oder Disziplin."
    : "Systems architect based in Austria. Founder of Curfee. Consulting for systems architecture and root cause analysis – making architecture decisions stick by design, enforced by the system itself, not by people or discipline.",
  "url": siteUrl,
  "mainEntityOfPage": `${siteUrl}/#about`,
  "image": {
    "@type": "ImageObject",
    "url": `${siteUrl}/assets/profile.webp`,
    "contentUrl": `${siteUrl}/assets/profile.webp`,
    "caption": lang === 'de'
      ? "Portrait von Philipp Höllinger, Systemarchitekt und Gründer von Curfee"
      : "Portrait of Philipp Höllinger, systems architect and founder of Curfee",
    "width": 180,
    "height": 225
  },
  "sameAs": ["https://www.linkedin.com/in/phoellinger"],
  "nationality": { "@type": "Country", "name": "Austria" },
  "knowsAbout": [
    "Systems Architecture",
    "Software Architecture",
    "System Analysis",
    "IT Consulting",
    "Root Cause Analysis",
    "Dependency Mapping",
    "Decision Enforcement",
    "Standards and Conventions Design",
    "Tool Landscape Assessment",
    "Structural Consulting"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": lang === 'de' ? "Systemarchitekt" : "Systems Architect",
    "occupationLocation": { "@id": `${siteUrl}/#place-salzburg` },
    "occupationalCategory": {
      "@type": "CategoryCode",
      "codeValue": "15-1199.02",
      "name": "Computer Systems Engineer/Architect",
      "inCodeSet": {
        "@type": "CategoryCodeSet",
        "name": "O*NET-SOC"
      }
    },
    "skills": "Systems architecture, root cause analysis, dependency mapping, decision enforcement, standards and conventions design, tool landscape assessment"
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "German", "alternateName": "de" },
    { "@type": "Language", "name": "English", "alternateName": "en" }
  ],
  "worksFor": { "@id": `${siteUrl}/#organization` },
  "memberOf": { "@id": `${siteUrl}/#organization` },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  }
};

const placeLd = {
  "@context": "https://schema.org",
  "@type": "Place",
  "@id": `${siteUrl}/#place-salzburg`,
  "name": "Salzburg, Austria",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8066,
    "longitude": 13.0089
  }
};

const organizationLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "ProfessionalService", "LocalBusiness"],
  "@id": `${siteUrl}/#organization`,
  "name": "Curfee",
  "legalName": "Curfee e.U.",
  "alternateName": ["Curfee Systems Architecture Consulting", "Curfee Consulting"],
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "@id": `${siteUrl}/#logo`,
    "url": `${siteUrl}/assets/og-image.png`,
    "width": 1200,
    "height": 630,
    "caption": "Curfee"
  },
  "image": { "@id": `${siteUrl}/#logo` },
  "description": t['meta.home.jsonld.description'],
  "slogan": t['footer.tagline'],
  "founder": { "@id": `${siteUrl}/#founder` },
  "employee": { "@id": `${siteUrl}/#founder` },
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 1 },
  "foundingDate": "2025",
  "foundingLocation": { "@id": `${siteUrl}/#place-salzburg` },
  "location": { "@id": `${siteUrl}/#place-salzburg` },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8066,
    "longitude": 13.0089
  },
  "areaServed": [
    { "@type": "Country", "name": "Austria", "alternateName": "AT" },
    { "@type": "Country", "name": "Germany", "alternateName": "DE" },
    { "@type": "Country", "name": "Switzerland", "alternateName": "CH" }
  ],
  "serviceArea": {
    "@type": "AdministrativeArea",
    "name": "DACH region"
  },
  "knowsAbout": [
    "Systems Architecture",
    "Software Architecture",
    "System Analysis",
    "IT Consulting",
    "Root Cause Analysis",
    "Dependency Mapping",
    "Decision Enforcement",
    "Standards and Conventions Design",
    "Tool Landscape Assessment",
    "Structural Consulting",
    "Technical Debt Resolution"
  ],
  "mentions": {
    "@type": "DefinedTerm",
    "@id": `${siteUrl}/#decision-enforcement-principle`,
    "name": "Decision Enforcement Principle",
    "description": lang === 'de'
      ? "Architekturentscheidungen müssen vom System selbst durchgesetzt werden – durch Pipelines, Tooling und automatische Checks – nicht durch Personen, Technologien oder Disziplin."
      : "Architecture decisions must be enforced by the system itself — through pipelines, tooling, and automated checks — not by people, technologies, or discipline.",
    "inDefinedTermSet": {
      "@type": "DefinedTermSet",
      "name": "Curfee Methodology",
      "inDefinedTermSet": `${siteUrl}/#organization`
    }
  },
  "contactPoint": [
    {
      "@type": "ContactPoint",
      "email": "office@curfee.com",
      "telephone": "+4367763024228",
      "contactType": "customer service",
      "availableLanguage": ["de", "en"],
      "areaServed": ["AT", "DE", "CH"]
    },
    {
      "@type": "ContactPoint",
      "url": "https://calendly.com/curfee/30min",
      "contactType": "sales",
      "contactOption": "OnlineAppointment",
      "availableLanguage": ["de", "en"]
    }
  ],
  "potentialAction": {
    "@type": "ReserveAction",
    "name": lang === 'de' ? "30-minütiges Erstgespräch buchen" : "Book a 30-minute intro call",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://calendly.com/curfee/30min",
      "inLanguage": ["de", "en"],
      "actionPlatform": ["https://schema.org/DesktopWebPlatform", "https://schema.org/MobileWebPlatform"]
    }
  },
  "knowsLanguage": [
    { "@type": "Language", "name": "German", "alternateName": "de" },
    { "@type": "Language", "name": "English", "alternateName": "en" }
  ],
  "vatID": "ATU83146203",
  "taxID": "ATU83146203",
  "identifier": [
    { "@type": "PropertyValue", "propertyID": "VAT", "value": "ATU83146203" },
    { "@type": "PropertyValue", "propertyID": "GISA", "value": "39453891" }
  ],
  "memberOf": {
    "@type": "Organization",
    "name": "Wirtschaftskammer Österreich",
    "alternateName": "WKO",
    "url": "https://www.wko.at"
  },
  "keywords": [
    "systems architecture consulting",
    "decision enforcement",
    "architecture governance automation",
    "root cause analysis",
    "system landscape assessment",
    "dependency mapping",
    "standards enforcement pipelines",
    "structural consulting",
    "IT consulting Austria",
    "Systemarchitektur Beratung",
    "Systemarchitektur Österreich",
    "Architekturentscheidungen durchsetzen",
    "Systemarchitekt Österreich"
  ],
  "sameAs": [
    "https://www.linkedin.com/in/phoellinger",
    "https://calendly.com/curfee/30min"
  ]
};

const speakableLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}${canonicalPath}#webpage`,
  "name": title,
  "url": canonicalUrl,
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#organization` },
  "author": { "@id": `${siteUrl}/#founder` },
  "publisher": { "@id": `${siteUrl}/#organization` },
  "inLanguage": htmlLang,
  ...(dateModified && { "dateModified": dateModified }),
  "primaryImageOfPage": {
    "@type": "ImageObject",
    "url": ogImage
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["[data-speakable]"]
  }
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' data: https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com; frame-src 'none'; base-uri 'self'; form-action 'self'" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Philipp Höllinger" />
    <meta name="robots" content={noindex ? "noindex, follow" : "index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1"} />
    {dateModified && <meta property="article:modified_time" content={dateModified} />}

    <!-- Geo Meta Tags — Local SEO (Salzburg, Austria) -->
    <meta name="geo.region" content="AT-5" />
    <meta name="geo.placename" content="Salzburg, Austria" />
    <meta name="geo.position" content="47.8066;13.0089" />
    <meta name="ICBM" content="47.8066, 13.0089" />

    <!-- DNS Prefetch for third-party domains -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    <!-- Preload critical fonts (only above-the-fold fonts) -->
    <link rel="preload" href="/assets/fonts/google_sans/google_sans_regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- LLM context files -->
    <link rel="help" type="text/plain" href={`${siteUrl}/llms.txt`} title="LLM context" />
    <link rel="help" type="text/plain" href={`${siteUrl}/llms-full.txt`} title="LLM full context" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={alternate.en} />
    <link rel="alternate" hreflang="de" href={alternate.de} />
    <link rel="alternate" hreflang="x-default" href={alternate.de} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Curfee" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t['meta.og.image.alt']} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={t['meta.og.image.alt']} />

    <!-- Favicons -->
    <link rel="icon" href="/assets/favicons/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/assets/favicons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/favicons/favicon_32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/assets/favicons/favicon_16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/assets/favicons/apple_touch_icon.png" />
    <link rel="manifest" href="/assets/favicons/site.webmanifest" />
    <meta name="theme-color" content="#003366" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)" />

    <!-- Structured Data — Sitewide Place + Person + Organization + Speakable -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(placeLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(speakableLd)} />
    <!-- Structured Data — Page-specific -->
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((ld) => (
            <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
          ))
        : <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Browser language redirect — inline for zero-flash, mirrors logic from src/i18n/language-detection.ts -->
    <script is:inline>
      (function() {
        var key = 'lang-preference';
        var stored;
        try { stored = localStorage.getItem(key); } catch(e) { return; }
        if (stored === 'de' || stored === 'en') return;
        var langs = navigator.languages || [navigator.language || ''];
        var detected = 'en';
        for (var i = 0; i < langs.length; i++) {
          if (langs[i].split('-')[0].toLowerCase() === 'de') { detected = 'de'; break; }
        }
        try { localStorage.setItem(key, detected); } catch(e) {}
        var path = location.pathname;
        var isEn = path === '/en' || path.substring(0, 4) === '/en/';
        if (detected === 'de' && isEn) {
          location.replace(path.replace(/^\/en\/?/, '/') || '/');
        } else if (detected === 'en' && !isEn) {
          location.replace(path === '/' ? '/en/' : '/en' + path);
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <div class="relative min-h-screen" style="overflow: clip;">
      <div class="pointer-events-none absolute inset-0 page-gradient" aria-hidden="true" />

      <div class="relative z-10">
        <main>
          <slot />
        </main>
        <Footer lang={lang} />
      </div>
    </div>

    <ScrollToTop />
    <CookieBanner lang={lang} />

    <script>
      import { initLanguageSwitcher } from '@/i18n/language-detection';
      document.addEventListener('astro:page-load', initLanguageSwitcher);
    </script>
  </body>
</html>

<style>
  .page-gradient {
    background: linear-gradient(
      to bottom,
      rgb(var(--brand-primary) / 0.10) 0%,
      rgb(var(--brand-primary) / 0.04) 35%,
      transparent 50%,
      rgb(var(--brand-secondary) / 0.02) 65%,
      rgb(var(--brand-secondary) / 0.04) 100%
    );
    contain: strict;
  }
</style>
