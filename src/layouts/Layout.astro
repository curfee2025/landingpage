---
import { ClientRouter } from 'astro:transitions';
import Footer from '@/components/shared/Footer.astro';
import ScrollToTop from '@/components/shared/ScrollToTop.astro';
import CookieBanner from '@/components/shared/CookieBanner.astro';
import { getTranslations } from '@/i18n/translations';
import { getAlternateUrl } from '@/i18n/utils';
import '@/styles/global.css';

import type { Lang } from '@/configurations/i18n';

interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  jsonLd?: object | object[];
  lang?: Lang;
  dateModified?: string;
}

const lang = Astro.props.lang ?? 'de';
const t = getTranslations(lang);

const {
  title,
  description = t['meta.home.description'],
  canonicalPath = '',
  jsonLd,
  dateModified,
} = Astro.props;

const siteUrl = 'https://curfee.com';
const canonicalUrl = `${siteUrl}${canonicalPath}`;
const ogImage = `${siteUrl}/assets/og-image.png`;
const alternate = getAlternateUrl(Astro.url, siteUrl);
const ogLocale = lang === 'de' ? 'de_AT' : 'en_US';
const ogLocaleAlt = lang === 'de' ? 'en_US' : 'de_AT';
const htmlLang = lang === 'de' ? 'de-AT' : 'en';

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  "@id": `${siteUrl}/#founder`,
  "name": "Philipp Höllinger",
  "givenName": "Philipp",
  "familyName": "Höllinger",
  "jobTitle": t['meta.about.jobTitle'],
  "description": lang === 'de'
    ? "Systemarchitekt in Salzburg, Österreich. Gründer von Curfee. Beratung für Systemarchitektur, Root-Cause-Analyse und strukturelle Verankerung von Entscheidungen in Systemlandschaften."
    : "Systems architect based in Salzburg, Austria. Founder of Curfee. Consulting for systems architecture, root cause analysis, and structural anchoring of decisions in system landscapes.",
  "url": siteUrl,
  "image": `${siteUrl}/assets/profile.webp`,
  "sameAs": ["https://www.linkedin.com/in/phoellinger"],
  "nationality": { "@type": "Country", "name": "Austria" },
  "knowsAbout": [
    "Systems Architecture",
    "Software Architecture",
    "System Analysis",
    "IT Consulting",
    "Organizational Structure",
    "Root Cause Analysis",
    "Dependency Mapping",
    "Governance Anchoring",
    "Standards and Conventions Design",
    "Tool Landscape Assessment",
    "Enterprise Architecture",
    "Technical Debt Management",
    "Architecture Decision Records"
  ],
  "hasOccupation": {
    "@type": "Occupation",
    "name": lang === 'de' ? "Systemarchitekt" : "Systems Architect",
    "occupationLocation": {
      "@type": "City",
      "name": "Salzburg"
    },
    "occupationalCategory": "15-1299.00",
    "skills": "Systems architecture, root cause analysis, dependency mapping, governance anchoring, standards design"
  },
  "knowsLanguage": ["de", "en"],
  "worksFor": { "@id": `${siteUrl}/#organization` },
  "memberOf": { "@id": `${siteUrl}/#organization` },
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  }
};

const organizationLd = {
  "@context": "https://schema.org",
  "@type": ["Organization", "ProfessionalService"],
  "@id": `${siteUrl}/#organization`,
  "name": "Curfee",
  "legalName": "Curfee e.U.",
  "alternateName": "Curfee e.U. — Systems Architecture Consulting",
  "url": siteUrl,
  "logo": {
    "@type": "ImageObject",
    "url": `${siteUrl}/assets/og-image.png`,
    "width": 1200,
    "height": 630
  },
  "image": `${siteUrl}/assets/og-image.png`,
  "description": t['meta.home.jsonld.description'],
  "slogan": lang === 'de'
    ? "Entscheidungen in der Struktur verankern – unabhängig von Personen, Technologien und Disziplin."
    : "Anchoring decisions in structure — independent of people, technologies, and discipline.",
  "founder": { "@id": `${siteUrl}/#founder` },
  "employee": { "@id": `${siteUrl}/#founder` },
  "numberOfEmployees": { "@type": "QuantitativeValue", "value": 1 },
  "foundingDate": "2025",
  "foundingLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Salzburg",
      "addressCountry": "AT"
    }
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Lieferinger Hauptstraße 49A",
    "postalCode": "5020",
    "addressLocality": "Salzburg",
    "addressRegion": "Salzburg",
    "addressCountry": "AT"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 47.8095,
    "longitude": 13.0550
  },
  "areaServed": [
    {
      "@type": "Country",
      "name": "Austria"
    },
    {
      "@type": "Country",
      "name": "Germany"
    },
    {
      "@type": "Country",
      "name": "Switzerland"
    },
    {
      "@type": "GeoCircle",
      "geoMidpoint": {
        "@type": "GeoCoordinates",
        "latitude": 47.8095,
        "longitude": 13.0550
      },
      "geoRadius": "500 km"
    }
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "office@curfee.com",
    "telephone": "+4367763024228",
    "contactType": "customer service",
    "availableLanguage": ["de", "en"]
  },
  "knowsLanguage": ["de", "en"],
  "priceRange": "$$",
  "vatID": "ATU83146203",
  "keywords": [
    "systems architecture consulting",
    "software architecture",
    "root cause analysis",
    "system landscape assessment",
    "dependency mapping",
    "governance anchoring",
    "structural consulting",
    "IT consulting Austria",
    "Systemarchitektur Beratung",
    "Systemarchitekt Salzburg"
  ],
  "sameAs": ["https://www.linkedin.com/in/phoellinger"]
};

const speakableLd = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": title,
  "url": canonicalUrl,
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["[aria-labelledby] h1, [aria-labelledby] h2, main > :first-child h1, main > :first-child p:first-of-type"]
  }
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />

    <!-- Security Headers -->
    <meta http-equiv="X-Content-Type-Options" content="nosniff" />
    <meta http-equiv="Referrer-Policy" content="strict-origin-when-cross-origin" />
    <meta http-equiv="Permissions-Policy" content="geolocation=(), microphone=(), camera=()" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' data: https://www.googletagmanager.com https://www.google-analytics.com https://*.google-analytics.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:; connect-src 'self' https://www.google-analytics.com https://*.google-analytics.com https://www.googletagmanager.com; frame-src 'none'; base-uri 'self'; form-action 'self'" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Philipp Höllinger" />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
    {dateModified && <meta name="article:modified_time" content={dateModified} />}

    <!-- Geo Meta Tags — Local SEO (Salzburg, Austria) -->
    <meta name="geo.region" content="AT-5" />
    <meta name="geo.placename" content="Salzburg" />
    <meta name="geo.position" content="47.8095;13.0550" />
    <meta name="ICBM" content="47.8095, 13.0550" />

    <!-- DNS Prefetch for third-party domains -->
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    <!-- Preload critical fonts (only above-the-fold fonts) -->
    <link rel="preload" href="/assets/fonts/google_sans/google_sans_regular.woff2" as="font" type="font/woff2" crossorigin />

    <!-- LLM context files -->
    <link rel="help" type="text/plain" href={`${siteUrl}/llms.txt`} title="LLM context" />
    <link rel="help" type="text/plain" href={`${siteUrl}/llms-full.txt`} title="LLM full context" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Hreflang -->
    <link rel="alternate" hreflang="en" href={alternate.en} />
    <link rel="alternate" hreflang="de" href={alternate.de} />
    <link rel="alternate" hreflang="x-default" href={alternate.de} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Curfee" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlt} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={t['meta.og.image.alt']} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content={t['meta.og.image.alt']} />

    <!-- Favicons -->
    <link rel="icon" href="/assets/favicons/favicon.ico" sizes="48x48" />
    <link rel="icon" href="/assets/favicons/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/assets/favicons/favicon_32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/assets/favicons/favicon_16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/assets/favicons/apple_touch_icon.png" />
    <link rel="manifest" href="/assets/favicons/site.webmanifest" />
    <meta name="theme-color" content="#003366" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#141416" media="(prefers-color-scheme: dark)" />

    <!-- Structured Data — Sitewide Person + Organization + Speakable -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationLd)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(speakableLd)} />
    <!-- Structured Data — Page-specific -->
    {jsonLd && (
      Array.isArray(jsonLd)
        ? jsonLd.map((ld) => (
            <script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
          ))
        : <script is:inline type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}

    <!-- Browser language redirect — inline for zero-flash, mirrors logic from src/i18n/language-detection.ts -->
    <script is:inline>
      (function() {
        var key = 'lang-preference';
        var stored;
        try { stored = localStorage.getItem(key); } catch(e) { return; }
        if (stored === 'de' || stored === 'en') return;
        var langs = navigator.languages || [navigator.language || ''];
        var detected = 'en';
        for (var i = 0; i < langs.length; i++) {
          if (langs[i].split('-')[0].toLowerCase() === 'de') { detected = 'de'; break; }
        }
        try { localStorage.setItem(key, detected); } catch(e) {}
        var path = location.pathname;
        var isEn = path === '/en' || path.substring(0, 4) === '/en/';
        if (detected === 'de' && isEn) {
          location.replace(path.replace(/^\/en\/?/, '/') || '/');
        } else if (detected === 'en' && !isEn) {
          location.replace(path === '/' ? '/en/' : '/en' + path);
        }
      })();
    </script>

    <ClientRouter />
  </head>
  <body>
    <div class="relative min-h-screen" style="overflow: clip;">
      <div class="pointer-events-none absolute inset-0 page-gradient" aria-hidden="true" />

      <div class="relative z-10">
        <main>
          <slot />
        </main>
        <Footer lang={lang} />
      </div>
    </div>

    <ScrollToTop />
    <CookieBanner lang={lang} />

    <script>
      import { initLanguageSwitcher } from '@/i18n/language-detection';
      document.addEventListener('astro:page-load', initLanguageSwitcher);
    </script>
  </body>
</html>

<style>
  .page-gradient {
    background: linear-gradient(
      to bottom,
      rgb(var(--brand-primary) / 0.10) 0%,
      rgb(var(--brand-primary) / 0.04) 35%,
      transparent 50%,
      rgb(var(--brand-secondary) / 0.02) 65%,
      rgb(var(--brand-secondary) / 0.04) 100%
    );
    contain: strict;
  }
</style>
