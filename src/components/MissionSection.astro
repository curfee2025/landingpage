---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section id="mission" class="py-16 md:py-24">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto grid grid-cols-1 md:grid-cols-2 gap-6">
      <div class="rounded-md bg-surface-raised shadow-elevation-1 p-8">
        <span class="text-label-large text-brand-primary font-medium">{t['mission.label']}</span>
        <p class="text-body-large text-ink-primary mt-3 leading-relaxed">{t['mission.text']}</p>
      </div>
      <div class="rounded-md bg-surface-raised shadow-elevation-1 p-8">
        <span class="text-label-large text-brand-primary font-medium">{t['vision.label']}</span>
        <p class="text-body-large text-ink-primary mt-3 leading-relaxed">{t['vision.text']}</p>
      </div>
    </div>
  </div>
</section>
