---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;

const items = [
  { num: '1', title: t['result.1.title'] },
  { num: '2', title: t['result.2.title'] },
  { num: '3', title: t['result.3.title'] },
];
---

<section id="result" class="py-20 md:py-24" aria-labelledby="result-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <h2 id="result-heading" class="text-headline-large md:text-display-small text-ink-primary">{t['result.heading']}</h2>
    </div>
    <div class="max-w-md mx-auto">
      <ol class="relative">
        {items.map((item, i) => (
          <li class:list={["relative flex items-start gap-5", i < items.length - 1 ? "pb-10" : ""]}>
            {/* Vertical connector line */}
            {i < items.length - 1 && (
              <div class="absolute left-5 top-10 bottom-0 w-px bg-brand-primary/20" aria-hidden="true" />
            )}
            {/* Number circle: outline + light fill */}
            <div class="relative z-10 flex-shrink-0 w-10 h-10 rounded-full border-2 border-brand-primary bg-brand-primary/[0.08] flex items-center justify-center">
              <span class="text-label-large text-brand-primary">{item.num}</span>
            </div>
            {/* Title */}
            <h3 class="text-title-medium text-ink-primary pt-2">{item.title}</h3>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>
