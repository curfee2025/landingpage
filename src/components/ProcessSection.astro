---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;

const steps = [
  { title: t['process.1.title'], description: t['process.1.description'] },
  { title: t['process.2.title'], description: t['process.2.description'] },
  { title: t['process.3.title'], description: t['process.3.description'] },
  { title: t['process.4.title'], description: t['process.4.description'] },
  { title: t['process.5.title'], description: t['process.5.description'] },
];
---

<section id="process" class="py-20 md:py-24" aria-labelledby="process-heading">
  <div class="text-center mb-12 md:mb-16">
    <span class="text-label-large text-brand-primary tracking-wider uppercase">{t['process.tagline']}</span>
    <h2 id="process-heading" class="text-headline-large md:text-display-small text-ink-primary mt-3">
      {t['process.heading']}
    </h2>
  </div>

  <div class="relative pl-12 max-w-2xl mx-auto">
    {steps.map((step, i) => (
      <div class={`relative ${i < steps.length - 1 ? 'pb-10' : ''}`}>
        {i < steps.length - 1 && (
          <div class="absolute -left-8 top-8 bottom-0 w-0.5 bg-brand-primary/[0.12]" aria-hidden="true"></div>
        )}
        <div class="absolute -left-12 top-0 w-8 h-8 rounded-full border-2 border-brand-primary bg-surface-raised flex items-center justify-center text-label-large text-brand-primary z-10">
          {i + 1}
        </div>
        <h3 class="text-title-large text-ink-primary mb-1">{step.title}</h3>
        <p class="text-body-medium text-ink-muted">{step.description}</p>
      </div>
    ))}
  </div>
</section>
