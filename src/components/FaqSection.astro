---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}

const { translations: t } = Astro.props;

const questions = [
  { question: t['faq.1.question'], answer: t['faq.1.answer'] },
  { question: t['faq.2.question'], answer: t['faq.2.answer'] },
  { question: t['faq.3.question'], answer: t['faq.3.answer'] },
  { question: t['faq.4.question'], answer: t['faq.4.answer'] },
  { question: t['faq.5.question'], answer: t['faq.5.answer'] },
  { question: t['faq.6.question'], answer: t['faq.6.answer'] },
  { question: t['faq.7.question'], answer: t['faq.7.answer'] },
  { question: t['faq.8.question'], answer: t['faq.8.answer'] },
];
---

<section id="faq" class="py-20 md:py-28" aria-labelledby="faq-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 id="faq-heading" class="text-headline-large md:text-display-small text-ink-primary mb-2">{t['faq.heading']}</h2>
    <p class="text-title-medium text-brand-primary/70 font-medium mb-12">{t['faq.subtitle']}</p>

    <!-- Desktop: two-column layout -->
    <div class="hidden md:grid md:grid-cols-[1fr_1.5fr] md:gap-10 md:items-start">
      <div class="space-y-1 sticky top-28" data-faq-list>
        {questions.map((q, i) => (
          <button
            type="button"
            data-faq-select={i}
            class:list={[
              "w-full text-left px-4 py-3 rounded-md text-body-large transition-all duration-short4 ease-standard cursor-pointer",
              i === 0 ? "bg-brand-primary/[0.08] text-brand-primary font-medium" : "text-ink-muted hover:text-ink-primary hover:bg-ink-primary/[0.08]"
            ]}
          >
            {q.question}
          </button>
        ))}
      </div>
      <div data-faq-answer class="rounded-lg bg-surface-raised border border-stroke-outlineVariant p-8 min-h-[200px]">
        <h3 class="text-title-large text-ink-primary mb-4" data-faq-answer-title>{questions[0].question}</h3>
        <p data-speakable class="text-body-large text-ink-muted leading-relaxed" data-faq-answer-text>{questions[0].answer}</p>
      </div>
    </div>

    <!-- Mobile: stacked details -->
    <div class="md:hidden divide-y divide-stroke-subtle">
      {questions.map(q => (
        <details class="group faq-details" name="faq-accordion">
          <summary class="flex items-center justify-between cursor-pointer py-6 text-title-medium text-ink-primary hover:text-brand-primary transition-colors duration-short4 ease-standard text-left list-none [&::-webkit-details-marker]:hidden">
            <span>{q.question}</span>
            <span class="flex-shrink-0 ml-4 text-ink-muted transition-transform duration-150 ease-standard group-open:rotate-180">
              <Icon name="expand_less" class="w-5 h-5" />
            </span>
          </summary>
          <div class="faq-content">
            <p class="text-body-medium text-ink-muted leading-relaxed pb-6">{q.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 150ms cubic-bezier(0.2, 0, 0, 1);
  }
  .faq-content > p {
    overflow: hidden;
  }
  .faq-details[open] > .faq-content {
    grid-template-rows: 1fr;
  }
</style>

<script>
  function initFaqSection() {
    const questions = document.querySelectorAll('[data-faq-select]');
    const title = document.querySelector('[data-faq-answer-title]');
    const text = document.querySelector('[data-faq-answer-text]');
    if (questions.length && title && text) {
      const data: { q: string; a: string }[] = [];
      questions.forEach(btn => {
        const i = Number(btn.getAttribute('data-faq-select'));
        const q = btn.textContent?.trim() ?? '';
        data[i] = { q, a: '' };
      });
      const mobileDetails = document.querySelectorAll('.faq-details');
      mobileDetails.forEach((d, i) => {
        const p = d.querySelector('.faq-content p');
        if (p && data[i]) data[i].a = p.textContent?.trim() ?? '';
      });
      questions.forEach(btn => {
        btn.addEventListener('click', () => {
          const i = Number(btn.getAttribute('data-faq-select'));
          title.textContent = data[i].q;
          text.textContent = data[i].a;
          questions.forEach(b => {
            b.className = 'w-full text-left px-4 py-3 rounded-md text-body-large transition-all duration-short4 ease-standard cursor-pointer text-ink-muted hover:text-ink-primary hover:bg-ink-primary/[0.08]';
          });
          btn.className = 'w-full text-left px-4 py-3 rounded-md text-body-large transition-all duration-short4 ease-standard cursor-pointer bg-brand-primary/[0.08] text-brand-primary font-medium';
        });
      });
    }
  }

  document.addEventListener('astro:page-load', () => {
    initFaqSection();
  });
</script>
