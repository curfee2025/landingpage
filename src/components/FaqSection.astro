---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}

const { translations: t } = Astro.props;

const groups = [
  {
    label: t['faq.group.fit'],
    items: [
      { question: t['faq.1.question'], answer: t['faq.1.answer'] },
      { question: t['faq.nontech.question'], answer: t['faq.nontech.answer'] },
    ],
  },
  {
    label: t['faq.group.process'],
    items: [
      { question: t['faq.2.question'], answer: t['faq.2.answer'] },
      { question: t['faq.4.question'], answer: t['faq.4.answer'] },
      { question: t['faq.keep.question'], answer: t['faq.keep.answer'] },
    ],
  },
  {
    label: t['faq.group.work'],
    items: [
      { question: t['faq.patterns.structural.question'], answer: t['faq.patterns.structural.answer'] },
      { question: t['faq.patterns.operational.question'], answer: t['faq.patterns.operational.answer'] },
      { question: t['faq.decisions.question'], answer: t['faq.decisions.answer'] },
      { question: t['faq.enforcement.question'], answer: t['faq.enforcement.answer'] },
      { question: t['faq.ai.question'], answer: t['faq.ai.answer'] },
      { question: t['faq.cultural.question'], answer: t['faq.cultural.answer'] },
    ],
  },
  {
    label: t['faq.group.working'],
    items: [
      { question: t['faq.5.question'], answer: t['faq.5.answer'] },
      { question: t['faq.international.question'], answer: t['faq.international.answer'] },
      { question: t['faq.6.question'], answer: t['faq.6.answer'] },
    ],
  },
];

const answerProseClass = "text-body-medium md:text-body-large text-ink-muted leading-relaxed pb-6 [&_p]:mb-3 [&_p:last-child]:mb-0 [&_ul]:list-disc [&_ul]:pl-5 [&_ul]:space-y-1.5 [&_ul]:mb-3 [&_ul:last-child]:mb-0 [&_li]:leading-relaxed [&_strong]:text-ink-primary [&_strong]:font-semibold";
---

<section id="faq" class="py-[clamp(8rem,5rem+7vw,12rem)]" aria-labelledby="faq-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto">
    <h2 id="faq-heading" class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">{t['faq.heading']}</h2>
    <p class="text-title-medium text-brand-primary font-medium mb-12">{t['faq.subtitle']}</p>

    {groups.map((group, gi) => (
      <div class={gi > 0 ? 'mt-10' : ''}>
        <h3 class="text-label-small uppercase tracking-[0.14em] text-brand-primary/70 font-medium mb-3">{group.label}</h3>
        <div class="space-y-2">
          {group.items.map((q, i) => (
            <details class="group faq-details rounded-lg bg-surface-base shadow-elevation-1 transition-shadow duration-short4 ease-standard open:shadow-elevation-2" name="faq-accordion">
              <summary class="flex items-center justify-between cursor-pointer px-5 py-4 md:px-6 md:py-5 text-title-medium text-ink-primary hover:text-brand-primary transition-colors duration-short4 ease-standard text-left list-none [&::-webkit-details-marker]:hidden">
                <span>{q.question}</span>
                <span class="flex-shrink-0 ml-4 text-ink-muted transition-transform duration-150 ease-standard group-open:rotate-180">
                  <Icon name="expand_less" class="w-5 h-5" />
                </span>
              </summary>
              <div class="faq-content">
                <div class="px-5 md:px-6">
                  <div class={answerProseClass} {...(gi === 0 && i === 0 ? { 'data-speakable': true } : {})} set:html={q.answer} />
                </div>
              </div>
            </details>
          ))}
        </div>
      </div>
    ))}
    </div>
  </div>
</section>

<style>
  .faq-content {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 150ms cubic-bezier(0.2, 0, 0, 1);
  }
  .faq-content > div {
    overflow: hidden;
  }
  .faq-details[open] > .faq-content {
    grid-template-rows: 1fr;
  }
</style>

<script>
  function initFaqCloseOnClick() {
    const detailsList = document.querySelectorAll<HTMLDetailsElement>('.faq-details');

    // Close any open FAQ when clicking outside
    document.addEventListener('click', (event) => {
      const target = event.target as Element | null;
      if (!target) return;
      if (target.closest('.faq-details')) return;
      detailsList.forEach((d) => { if (d.open) d.open = false; });
    });

    // Click anywhere inside an open FAQ (except links/buttons) closes it
    detailsList.forEach((d) => {
      const content = d.querySelector<HTMLElement>('.faq-content');
      if (!content) return;
      content.addEventListener('click', (event) => {
        const target = event.target as Element | null;
        if (target && target.closest('a, button')) return;
        d.open = false;
      });
    });
  }

  document.addEventListener('astro:page-load', initFaqCloseOnClick);
  initFaqCloseOnClick();
</script>
