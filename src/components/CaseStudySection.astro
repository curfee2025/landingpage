---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const hasHeading = Boolean(t['casestudy.heading']);
const hasSubtitle = Boolean(t['casestudy.subtitle']);
const hasPlaceholder = Boolean(t['casestudy.placeholder']);
const hasAnyContent = hasHeading || hasSubtitle || hasPlaceholder;
---

{hasAnyContent && (
  <section id="casestudy" class="py-20 md:py-28" aria-labelledby="casestudy-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
      <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
        {hasHeading && (
          <h2 id="casestudy-heading" class="text-headline-large md:text-display-small text-ink-primary mb-2">
            {t['casestudy.heading']}
          </h2>
        )}
        {hasSubtitle && (
          <p class="text-title-medium text-brand-primary font-medium mb-12">{t['casestudy.subtitle']}</p>
        )}
      </div>
      {hasPlaceholder && (
        <div class="max-w-2xl mx-auto">
          <div class="rounded-lg bg-surface-base shadow-elevation-1 p-10 md:p-14 text-center">
            <p class="text-body-medium text-ink-muted">
              {t['casestudy.placeholder']}
            </p>
          </div>
        </div>
      )}
    </div>
  </section>
)}
