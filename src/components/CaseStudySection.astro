---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section id="casestudy" class="py-20 md:py-28" aria-labelledby="casestudy-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <h2 id="casestudy-heading" class="text-headline-large md:text-display-small text-ink-primary">
        {t['casestudy.heading']}
      </h2>
    </div>
    <div class="max-w-2xl mx-auto rounded-md border border-dashed border-stroke-outlineVariant p-10 md:p-14 text-center">
      <div class="w-16 h-16 rounded-full border-2 border-dashed border-brand-primary/30 flex items-center justify-center mx-auto mb-6">
        <div class="w-3 h-3 rounded-full bg-brand-primary/30"></div>
      </div>
      <p class="text-body-large text-ink-muted">
        {t['casestudy.placeholder']}
      </p>
    </div>
  </div>
</section>
