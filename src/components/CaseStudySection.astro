---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const hasHeading = Boolean(t['casestudy.heading']);
const hasSubtitle = Boolean(t['casestudy.subtitle']);
const hasPlaceholder = Boolean(t['casestudy.placeholder']);
---

{(hasHeading || hasSubtitle || hasPlaceholder) && (
  <section id="casestudy" class="py-[clamp(8rem,5rem+7vw,12rem)]" aria-labelledby="casestudy-heading">
    <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
      <div class="max-w-4xl mx-auto">
        {hasHeading && (
          <h2 id="casestudy-heading" class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">
            {t['casestudy.heading']}
          </h2>
        )}
        {hasSubtitle && (
          <p class="text-title-medium text-brand-primary font-medium mb-12">{t['casestudy.subtitle']}</p>
        )}
        {hasPlaceholder && (
          <div class="rounded-lg bg-surface-base shadow-elevation-1 p-8 md:p-10">
            <p class="text-body-large text-ink-muted leading-relaxed italic">
              {t['casestudy.placeholder']}
            </p>
          </div>
        )}
      </div>
    </div>
  </section>
)}
