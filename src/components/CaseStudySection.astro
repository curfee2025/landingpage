---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section id="casestudy" class="py-20 md:py-24" aria-labelledby="casestudy-heading">
  <div class="text-center mb-12 md:mb-16">
    <span class="text-label-large text-brand-primary tracking-wider uppercase">{t['casestudy.tagline']}</span>
    <h2 id="casestudy-heading" class="text-headline-large md:text-display-small text-ink-primary mt-3">
      {t['casestudy.heading']}
    </h2>
  </div>
  <div class="grid grid-cols-1 md:grid-cols-3 gap-4 md:gap-6">
    <!-- Case 1 -->
    <article class="flex flex-col rounded-md border border-stroke-outlineVariant bg-surface-raised p-6">
      <span class="text-label-large text-brand-secondary tracking-wider uppercase mb-3">{t['casestudy.1.type']}</span>
      <h3 class="text-title-medium text-ink-primary mb-3">{t['casestudy.1.title']}</h3>
      <p class="text-body-medium text-ink-muted mb-6 flex-1">{t['casestudy.1.description']}</p>
      <div class="pt-4 border-t border-stroke-subtle">
        <span class="text-label-medium text-brand-primary tracking-wider uppercase">{t['casestudy.1.result.label']}</span>
        <p class="text-body-medium text-ink-muted mt-1">{t['casestudy.1.result']}</p>
      </div>
    </article>
    <!-- Case 2 -->
    <article class="flex flex-col rounded-md border border-stroke-outlineVariant bg-surface-raised p-6">
      <span class="text-label-large text-brand-secondary tracking-wider uppercase mb-3">{t['casestudy.2.type']}</span>
      <h3 class="text-title-medium text-ink-primary mb-3">{t['casestudy.2.title']}</h3>
      <p class="text-body-medium text-ink-muted mb-6 flex-1">{t['casestudy.2.description']}</p>
      <div class="pt-4 border-t border-stroke-subtle">
        <span class="text-label-medium text-brand-primary tracking-wider uppercase">{t['casestudy.2.result.label']}</span>
        <p class="text-body-medium text-ink-muted mt-1">{t['casestudy.2.result']}</p>
        <div class="flex gap-6 mt-3">
          <div>
            <div class="text-title-large text-brand-primary">{t['casestudy.2.statistic1.value']}</div>
            <div class="text-label-small text-ink-muted">{t['casestudy.2.statistic1']}</div>
          </div>
          <div>
            <div class="text-title-large text-brand-primary">{t['casestudy.2.statistic2.value']}</div>
            <div class="text-label-small text-ink-muted">{t['casestudy.2.statistic2']}</div>
          </div>
        </div>
      </div>
    </article>
    <!-- Case 3 -->
    <article class="flex flex-col rounded-md border border-stroke-outlineVariant bg-surface-raised p-6">
      <span class="text-label-large text-brand-secondary tracking-wider uppercase mb-3">{t['casestudy.3.type']}</span>
      <h3 class="text-title-medium text-ink-primary mb-3">{t['casestudy.3.title']}</h3>
      <p class="text-body-medium text-ink-muted mb-6 flex-1">{t['casestudy.3.description']}</p>
      <div class="pt-4 border-t border-stroke-subtle">
        <span class="text-label-medium text-brand-primary tracking-wider uppercase">{t['casestudy.3.result.label']}</span>
        <p class="text-body-medium text-ink-muted mt-1">{t['casestudy.3.result']}</p>
        <div class="flex gap-6 mt-3">
          <div>
            <div class="text-title-large text-brand-primary">{t['casestudy.3.statistic1.value']}</div>
            <div class="text-label-small text-ink-muted">{t['casestudy.3.statistic1']}</div>
          </div>
          <div>
            <div class="text-title-large text-brand-primary">{t['casestudy.3.statistic2.value']}</div>
            <div class="text-label-small text-ink-muted">{t['casestudy.3.statistic2']}</div>
          </div>
        </div>
      </div>
    </article>
  </div>
</section>
