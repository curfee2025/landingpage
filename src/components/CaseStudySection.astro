---
interface Props {
  heading: string;
  placeholder: string;
}
const { heading, placeholder } = Astro.props;
---

<section id="casestudy" class="py-20 md:py-28" aria-labelledby="casestudy-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <h2 id="casestudy-heading" class="text-headline-large md:text-display-small text-ink-primary">
        {heading}
      </h2>
    </div>
    <div class="max-w-2xl mx-auto">
      <div class="rounded-md border border-dashed border-stroke-outlineVariant p-10 md:p-14 text-center">
        <p class="text-body-medium text-ink-muted">
          {placeholder}
        </p>
      </div>
    </div>
  </div>
</section>
