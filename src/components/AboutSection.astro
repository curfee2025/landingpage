---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section id="about" class="py-20 md:py-24" aria-labelledby="about-heading">
  <div class="max-w-3xl mx-auto">
    <div class="text-center mb-12">
      <span class="text-label-large text-brand-primary tracking-wider uppercase">{t['about.tagline']}</span>
      <h2 id="about-heading" class="text-headline-large md:text-display-small text-ink-primary mt-3">
        {t['about.heading']}
      </h2>
    </div>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.1']}</p>
      <p>{t['about.2']}</p>
      <p>{t['about.3']}</p>
      <p>{t['about.4']}</p>
      <p>{t['about.5']}</p>
      <p class="text-ink-primary">{t['about.6']}</p>
    </div>
  </div>
</section>
