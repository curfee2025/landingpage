---
interface Props {
  heading: string;
  texts: string[];
  emphasizedText: string;
  tags: string[];
}
const { heading, texts, emphasizedText, tags } = Astro.props;
---

<section id="about" class="py-20 md:py-28" aria-labelledby="about-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-3xl mx-auto">
      <div class="text-center mb-12 md:mb-16">
        <h2 id="about-heading" class="text-headline-large md:text-display-small text-ink-primary mb-8">
          {heading}
        </h2>
        <picture>
          <source srcset="/assets/profile.webp" type="image/webp" />
          <img src="/assets/profile.png" alt="Philipp Höllinger" class="w-[160px] h-[200px] object-cover object-top rounded-md mx-auto" loading="lazy" />
        </picture>
      </div>
      <div class="space-y-4 text-body-large text-ink-muted leading-relaxed">
        {texts.map(t => <p>{t}</p>)}
        <p class="text-ink-primary font-medium">{emphasizedText}</p>
      </div>
      <div class="flex flex-wrap justify-center gap-3 mt-8">
        {tags.map(tag => (
          <span class="text-label-large text-brand-primary bg-brand-primary/[0.08] px-4 py-2 rounded-full">{tag}</span>
        ))}
      </div>
    </div>
  </div>
</section>
