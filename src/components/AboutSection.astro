---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section id="about" class="py-20 md:py-28" aria-labelledby="about-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
  <div class="max-w-3xl mx-auto">
    <h2 id="about-heading" class="text-headline-large md:text-display-small text-ink-primary mb-8">
      {t['about.heading']}
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-[140px_1fr] gap-8 items-start">
      <div class="w-[140px] h-[175px] rounded-md bg-surface-soft border border-stroke-outlineVariant flex items-center justify-center text-label-medium text-ink-muted">
        Foto folgt
      </div>
      <div>
        <div class="space-y-4 text-body-large text-ink-muted leading-relaxed">
          <p>{t['about.1']}</p>
          <p>{t['about.2']}</p>
        </div>
        <div class="flex flex-wrap gap-2 mt-6">
          <span class="text-label-medium text-ink-muted bg-surface-soft border border-stroke-outlineVariant px-3 py-1.5 rounded-xs">{t['about.3']}</span>
          <span class="text-label-medium text-ink-muted bg-surface-soft border border-stroke-outlineVariant px-3 py-1.5 rounded-xs">{t['about.4']}</span>
          <span class="text-label-medium text-ink-muted bg-surface-soft border border-stroke-outlineVariant px-3 py-1.5 rounded-xs">{t['about.5']}</span>
          <span class="text-label-medium text-ink-muted bg-surface-soft border border-stroke-outlineVariant px-3 py-1.5 rounded-xs">{t['about.6']}</span>
          <span class="text-label-medium text-ink-muted bg-surface-soft border border-stroke-outlineVariant px-3 py-1.5 rounded-xs">{t['about.7']}</span>
          <span class="text-label-medium text-ink-muted bg-surface-soft border border-stroke-outlineVariant px-3 py-1.5 rounded-xs">{t['about.8']}</span>
        </div>
      </div>
    </div>
  </div>
  </div>
</section>
