---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const principles = [
  { title: t['acronym.1.title'], description: t['acronym.1.description'] },
  { title: t['acronym.2.title'], description: t['acronym.2.description'] },
  { title: t['acronym.3.title'], description: t['acronym.3.description'] },
  { title: t['acronym.4.title'], description: t['acronym.4.description'] },
  { title: t['acronym.5.title'], description: t['acronym.5.description'] },
  { title: t['acronym.6.title'], description: t['acronym.6.description'] },
];
---

<section id="about" class="py-32 md:py-48" style="background: linear-gradient(to bottom, rgb(var(--brand-primary) / 0) 0%, rgb(var(--brand-primary) / 0.10) 15%, rgb(var(--brand-primary) / 0.10) 80%, rgb(var(--brand-primary) / 0.05) 92%, rgb(var(--brand-primary) / 0) 100%);" aria-labelledby="about-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">

    <!-- Intro: Bild oben links, Text fließt darum -->
    <div class="mb-6 md:mb-8">
      <div class="flex justify-center mb-6 md:float-left md:mr-8 md:mb-2">
        <img src="/assets/profile.webp" alt={t['about.portrait.alt']} class="w-[180px] h-[225px] object-cover object-top rounded-md shadow-elevation-1" loading="lazy" decoding="async" width="180" height="225" />
      </div>
      <h2 id="about-heading" data-speakable class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">
        {t['about.heading']}
      </h2>
      <p class="text-title-medium text-brand-primary font-medium mb-4">{t['about.who.heading']}</p>
      <div class="flex flex-wrap gap-2 mb-6">
        <span class="text-label-large text-brand-primary font-medium border border-brand-primary/30 px-4 py-1.5 rounded-full">{t['principles.1']}</span>
        <span class="text-label-large text-brand-primary font-medium border border-brand-primary/30 px-4 py-1.5 rounded-full">{t['principles.2']}</span>
        <span class="text-label-large text-brand-primary font-medium border border-brand-primary/30 px-4 py-1.5 rounded-full">{t['principles.3']}</span>
      </div>
      <div class="space-y-4 text-body-large text-ink-muted leading-relaxed">
        <p data-speakable>{t['about.who.1']}</p>
        <p>{t['about.who.2']}</p>
        <p>{t['about.who.3']}</p>
        <p>{t['about.who.4']}</p>
        <p data-speakable>{t['about.who.5']}</p>
        <p data-speakable>{t['about.who.6']}</p>
      </div>
    </div>

    <!-- CURFEE Akronym -->
    <div>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-6 gap-6">
        {principles.map((p) => {
          const firstLetter = p.title.charAt(0);
          const rest = p.title.slice(1);
          return (
            <div>
              <div class="flex items-baseline gap-0.5">
                <span class="text-display-medium text-brand-primary font-display leading-none">{firstLetter}</span>
                <span class="text-title-medium text-ink-primary">{rest}</span>
              </div>
              <p class="text-body-medium text-ink-muted leading-relaxed mt-2">{p.description}</p>
            </div>
          );
        })}
      </div>
    </div>

  </div>
</section>
