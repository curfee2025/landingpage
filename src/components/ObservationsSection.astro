---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const pairs = [
  { icon: 'visibility', title: t['observations.3.title'], titlePositive: t['observations.3.title.positive'], reality: t['observations.3.reality'], potential: t['observations.3.potential'] },
  { icon: 'account_tree', title: t['observations.6.title'], titlePositive: t['observations.6.title.positive'], reality: t['observations.6.reality'], potential: t['observations.6.potential'] },
  { icon: 'call_split', title: t['observations.8.title'], titlePositive: t['observations.8.title.positive'], reality: t['observations.8.reality'], potential: t['observations.8.potential'] },
  { icon: 'person', title: t['observations.5.title'], titlePositive: t['observations.5.title.positive'], reality: t['observations.5.reality'], potential: t['observations.5.potential'] },
  { icon: 'compare_arrows', title: t['observations.2.title'], titlePositive: t['observations.2.title.positive'], reality: t['observations.2.reality'], potential: t['observations.2.potential'] },
  { icon: 'blur_on', title: t['observations.1.title'], titlePositive: t['observations.1.title.positive'], reality: t['observations.1.reality'], potential: t['observations.1.potential'] },
  { icon: 'psychology', title: t['observations.7.title'], titlePositive: t['observations.7.title.positive'], reality: t['observations.7.reality'], potential: t['observations.7.potential'] },
];
---

<section id="observations" class="py-32 md:py-48" style="background: linear-gradient(to bottom, rgb(var(--brand-secondary) / 0) 0%, rgb(var(--brand-secondary) / 0.10) 15%, rgb(var(--brand-secondary) / 0.10) 80%, rgb(var(--brand-secondary) / 0.05) 92%, rgb(var(--brand-secondary) / 0) 100%);" aria-labelledby="observations-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto">
    <h2 id="observations-heading" class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">
      <span class="grid">
        <span data-speakable class="col-start-1 row-start-1 transition-opacity duration-medium2 ease-standard" data-observations-heading="reality">{t['observations.heading.status_quo']}</span>
        <span class="col-start-1 row-start-1 transition-opacity duration-medium2 ease-standard opacity-0 pointer-events-none" data-observations-heading="potential" aria-hidden="true">{t['observations.heading.potential']}</span>
      </span>
    </h2>
    <div class="grid mb-8">
      <p class="col-start-1 row-start-1 text-title-medium text-brand-secondary font-medium transition-opacity duration-medium2 ease-standard" data-observations-subtitle="reality">{t['observations.subtitle.status_quo']}</p>
      <p class="col-start-1 row-start-1 text-title-medium text-brand-secondary font-medium transition-opacity duration-medium2 ease-standard opacity-0 pointer-events-none" data-observations-subtitle="potential" aria-hidden="true">{t['observations.subtitle.potential']}</p>
    </div>

    <div role="radiogroup" aria-label={t['observations.heading.status_quo']} class="inline-flex items-center gap-1 p-1 rounded-full bg-surface-base shadow-elevation-1 mb-6" data-observations-toggle-group>
      <button
        type="button"
        role="radio"
        aria-checked="true"
        data-view="reality"
        class="px-5 py-2 rounded-full text-label-large text-ink-primary bg-ink-primary/[0.08] transition-all duration-medium2 ease-standard"
      >
        {t['observations.column.left']}
      </button>
      <button
        type="button"
        role="radio"
        aria-checked="false"
        data-view="potential"
        class="px-5 py-2 rounded-full text-label-large text-ink-onSurfaceVariant hover:text-ink-primary transition-all duration-medium2 ease-standard"
      >
        {t['observations.column.right']}
      </button>
    </div>

    <ol class="space-y-2" data-observations-toggle-list>
      {pairs.map((pair) => (
        <li class="rounded-lg bg-surface-base shadow-elevation-1 px-4 py-3 md:px-5 md:py-4 flex items-start gap-3">
          <Icon name={pair.icon} class="w-5 h-5 text-brand-secondary flex-shrink-0 mt-[3px] md:mt-1" />
          <div class="flex-1 min-w-0">
            <h3 class="text-[1.125rem] leading-7 font-semibold text-ink-primary mb-1">
              <span class="grid">
                <span class="col-start-1 row-start-1 transition-opacity duration-medium2 ease-standard" data-observations-card-title="reality">{pair.title}</span>
                <span class="col-start-1 row-start-1 transition-opacity duration-medium2 ease-standard opacity-0 pointer-events-none" data-observations-card-title="potential" aria-hidden="true">{pair.titlePositive}</span>
              </span>
            </h3>
            <div class="grid">
              <p class="col-start-1 row-start-1 text-body-medium text-ink-muted leading-relaxed transition-opacity duration-medium2 ease-standard" data-observations-text="reality">{pair.reality}</p>
              <p class="col-start-1 row-start-1 text-body-medium text-brand-secondary leading-relaxed transition-opacity duration-medium2 ease-standard opacity-0 pointer-events-none" data-observations-text="potential" aria-hidden="true">{pair.potential}</p>
            </div>
          </div>
        </li>
      ))}
    </ol>
    </div>
  </div>
</section>

<script>
  function initObservationsToggle() {
    const toggleGroup = document.querySelector<HTMLElement>('[data-observations-toggle-group]');
    if (!toggleGroup) return;

    const buttons = toggleGroup.querySelectorAll<HTMLButtonElement>('[data-view]');
    const realityTexts = document.querySelectorAll<HTMLElement>('[data-observations-text="reality"]');
    const potentialTexts = document.querySelectorAll<HTMLElement>('[data-observations-text="potential"]');
    const realitySubtitles = document.querySelectorAll<HTMLElement>('[data-observations-subtitle="reality"]');
    const potentialSubtitles = document.querySelectorAll<HTMLElement>('[data-observations-subtitle="potential"]');
    const realityHeadings = document.querySelectorAll<HTMLElement>('[data-observations-heading="reality"]');
    const potentialHeadings = document.querySelectorAll<HTMLElement>('[data-observations-heading="potential"]');
    const realityCardTitles = document.querySelectorAll<HTMLElement>('[data-observations-card-title="reality"]');
    const potentialCardTitles = document.querySelectorAll<HTMLElement>('[data-observations-card-title="potential"]');
    const cards = document.querySelectorAll<HTMLElement>('[data-observations-toggle-list] > li');

    // Equalize all cards to the tallest one so the whole list has uniform row height
    const equalize = () => {
      cards.forEach((c) => { c.style.minHeight = ''; });
      let max = 0;
      cards.forEach((c) => { max = Math.max(max, c.offsetHeight); });
      cards.forEach((c) => { c.style.minHeight = max + 'px'; });
    };
    equalize();
    window.addEventListener('resize', equalize);

    buttons.forEach((btn) => {
      btn.addEventListener('click', () => {
        const view = btn.dataset.view;
        const showReality = view === 'reality';
        buttons.forEach((b) => {
          const active = b.dataset.view === view;
          b.setAttribute('aria-checked', String(active));
          if (active) {
            b.classList.add('bg-ink-primary/[0.08]', 'text-ink-primary');
            b.classList.remove('text-ink-onSurfaceVariant');
          } else {
            b.classList.remove('bg-ink-primary/[0.08]', 'text-ink-primary');
            b.classList.add('text-ink-onSurfaceVariant');
          }
        });
        const toggleText = (p: HTMLElement, visible: boolean) => {
          p.classList.toggle('opacity-0', !visible);
          p.classList.toggle('pointer-events-none', !visible);
          p.setAttribute('aria-hidden', String(!visible));
        };
        realityTexts.forEach((p) => toggleText(p, showReality));
        potentialTexts.forEach((p) => toggleText(p, !showReality));
        realitySubtitles.forEach((p) => toggleText(p, showReality));
        potentialSubtitles.forEach((p) => toggleText(p, !showReality));
        realityHeadings.forEach((p) => toggleText(p, showReality));
        potentialHeadings.forEach((p) => toggleText(p, !showReality));
        realityCardTitles.forEach((p) => toggleText(p, showReality));
        potentialCardTitles.forEach((p) => toggleText(p, !showReality));
      });
    });
  }
  document.addEventListener('astro:page-load', initObservationsToggle);
  initObservationsToggle();
</script>
