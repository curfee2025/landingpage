---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const observations = [
  t['observations.1'],
  t['observations.2'],
  t['observations.3'],
  t['observations.4'],
  t['observations.5'],
];
---

<section class="py-20 md:py-24" aria-labelledby="observations-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-3xl mx-auto">
      <h2 id="observations-heading" class="text-headline-large md:text-display-small text-ink-primary mb-12 md:mb-16">{t['observations.heading']}</h2>
      <div class="space-y-10">
        {observations.map((text, i) => (
          <div class="flex items-center gap-6">
            <span class="text-headline-large md:text-display-small text-brand-primary/50 font-display flex-shrink-0 w-10 md:w-14 select-none leading-none">{i + 1}</span>
            <p class="text-body-large md:text-title-medium text-ink-muted leading-relaxed">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
