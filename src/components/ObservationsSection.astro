---
import Icon from '@/components/shared/Icon.astro';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const pairs = [
  { icon: 'swap_horiz', title: t['observations.6.title'], reality: t['observations.6.reality'], potential: t['observations.6.potential'] },
  { icon: 'check_circle', title: t['observations.3.title'], reality: t['observations.3.reality'], potential: t['observations.3.potential'] },
  { icon: 'construction', title: t['observations.4.title'], reality: t['observations.4.reality'], potential: t['observations.4.potential'] },
  { icon: 'person_add', title: t['observations.1.title'], reality: t['observations.1.reality'], potential: t['observations.1.potential'] },
  { icon: 'group_work', title: t['observations.2.title'], reality: t['observations.2.reality'], potential: t['observations.2.potential'] },
  { icon: 'psychology', title: t['observations.5.title'], reality: t['observations.5.reality'], potential: t['observations.5.potential'] },
];
---

<section class="py-20 md:py-24" aria-labelledby="observations-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 id="observations-heading" class="text-headline-large md:text-display-small text-ink-primary mb-2">{t['observations.heading']}</h2>
    <p class="text-title-medium text-brand-primary/70 font-medium mb-12">{t['observations.subtitle']}</p>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      {pairs.map((pair) => (
        <div class="rounded-md border border-stroke-outlineVariant bg-surface-raised p-6 md:p-8">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-10 h-10 rounded-full bg-brand-primary/[0.08] flex items-center justify-center flex-shrink-0">
              <Icon name={pair.icon} class="w-5 h-5 text-brand-primary" />
            </div>
            <h3 class="text-title-medium text-ink-primary">{pair.title}</h3>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_1fr] gap-4 md:gap-6 items-center">
            <p class="text-body-medium text-ink-muted leading-relaxed">{pair.reality}</p>
            <Icon name="arrow_downward" class="w-5 h-5 text-brand-primary/50 md:hidden mx-auto" />
            <Icon name="arrow_right_alt" class="w-5 h-5 text-brand-primary/50 hidden md:block" />
            <p class="text-body-medium text-brand-primary leading-relaxed">{pair.potential}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
