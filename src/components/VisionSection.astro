---
import Icon from '@/components/shared/Icon.astro';

import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const cards = [
  { icon: 'handshake', title: t['about.vision.1.title'], description: t['about.vision.1.description'], color: 'primary' as const },
  { icon: 'hub', title: t['about.vision.2.title'], description: t['about.vision.2.description'], color: 'primary' as const },
  { icon: 'shield', title: t['about.vision.3.title'], description: t['about.vision.3.description'], color: 'secondary' as const },
  { icon: 'map', title: t['about.vision.4.title'], description: t['about.vision.4.description'], color: 'secondary' as const },
  { icon: 'trending_up', title: t['about.vision.5.title'], description: t['about.vision.5.description'], color: 'tertiary' as const },
  { icon: 'visibility', title: t['about.vision.6.title'], description: t['about.vision.6.description'], color: 'tertiary' as const },
];

const colorMap = {
  primary: { bg: 'bg-brand-primary/10', text: 'text-brand-primary' },
  secondary: { bg: 'bg-brand-primary/10', text: 'text-brand-primary' },
  tertiary: { bg: 'bg-brand-primary/10', text: 'text-brand-primary' },
};
---

<section class="py-20 md:py-24" aria-labelledby="vision-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <h2 id="vision-heading" class="text-headline-large md:text-display-small text-ink-primary">{t['about.vision.heading']}</h2>
    </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        {cards.slice(0, 3).map((card) => (
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class:list={["w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0", colorMap[card.color].bg]}>
                <Icon name={card.icon} class:list={["w-5 h-5", colorMap[card.color].text]} />
              </div>
              <h3 class="text-title-medium text-ink-primary">{card.title}</h3>
            </div>
            <p class="text-body-medium text-ink-muted">{card.description}</p>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {cards.slice(3, 6).map((card) => (
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class:list={["w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0", colorMap[card.color].bg]}>
                <Icon name={card.icon} class:list={["w-5 h-5", colorMap[card.color].text]} />
              </div>
              <h3 class="text-title-medium text-ink-primary">{card.title}</h3>
            </div>
            <p class="text-body-medium text-ink-muted">{card.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
