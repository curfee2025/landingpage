---
import Icon from '@/components/shared/Icon.astro';

interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;

const cards = [
  { icon: 'handshake', key: '1', color: 'primary' as const },
  { icon: 'hub', key: '2', color: 'primary' as const },
  { icon: 'swap_horiz', key: '3', color: 'secondary' as const },
  { icon: 'map', key: '4', color: 'secondary' as const },
  { icon: 'trending_up', key: '5', color: 'tertiary' as const },
  { icon: 'visibility', key: '6', color: 'tertiary' as const },
];

const colorMap = {
  primary: { bg: 'bg-brand-primary/10', text: 'text-brand-primary' },
  secondary: { bg: 'bg-brand-primary/10', text: 'text-brand-primary' },
  tertiary: { bg: 'bg-brand-primary/10', text: 'text-brand-primary' },
};
---

<section class="py-20 md:py-24" aria-labelledby="vision-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center max-w-3xl mx-auto mb-12 md:mb-16">
      <h2 id="vision-heading" class="text-headline-large md:text-display-small text-ink-primary">{t['about.vision.heading']}</h2>
    </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-4">
        {cards.slice(0, 3).map((card) => (
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class:list={["w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0", colorMap[card.color].bg]}>
                <Icon name={card.icon} class:list={["w-5 h-5", colorMap[card.color].text]} />
              </div>
              <h3 class="text-title-medium text-ink-primary">{t[`about.vision.${card.key}.title`]}</h3>
            </div>
            <p class="text-body-medium text-ink-muted">{t[`about.vision.${card.key}.description`]}</p>
          </div>
        ))}
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        {cards.slice(3, 6).map((card) => (
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
            <div class="flex items-center gap-3 mb-3">
              <div class:list={["w-10 h-10 rounded-full flex items-center justify-center flex-shrink-0", colorMap[card.color].bg]}>
                <Icon name={card.icon} class:list={["w-5 h-5", colorMap[card.color].text]} />
              </div>
              <h3 class="text-title-medium text-ink-primary">{t[`about.vision.${card.key}.title`]}</h3>
            </div>
            <p class="text-body-medium text-ink-muted">{t[`about.vision.${card.key}.description`]}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
