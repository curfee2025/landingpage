---
import Icon from '@/components/shared/Icon.astro';
---

<button
  type="button"
  class="fixed bottom-6 right-6 z-30 w-14 h-14 rounded-lg flex items-center justify-center bg-brand-primaryContainer text-brand-onPrimaryContainer shadow-elevation-3 hover:shadow-elevation-4 active:shadow-elevation-2 transition-all duration-medium2 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary/40 opacity-0 translate-y-4 pointer-events-none"
  aria-label="Scroll to top"
  data-scroll-top
>
  <Icon name="keyboard_arrow_up" class="w-6 h-6" />
</button>

<script>
  import { initFab } from '@/ui/ScrollToTopButton';
  initFab();
</script>
