---
import Icon from '@/components/shared/Icon.astro';
import Logo from '@/components/shared/Logo.astro';
import { localizedRoutes, EXTERNAL } from '@/configurations/routes';

interface Props {
  lang: 'de' | 'en';
  navServices: string;
  navAbout: string;
  navFaq: string;
  navCta: string;
  diagnosisTitle: string;
  guidanceTitle: string;
  sparringTitle: string;
}

const { lang, navServices, navAbout, navFaq, navCta, diagnosisTitle, guidanceTitle, sparringTitle } = Astro.props;
const routes = localizedRoutes(lang);
const menuId = 'mobile-menu';
const currentPath = Astro.url.pathname;
const isActive = (path: string) => currentPath === path || currentPath === path + '/';
const isServicePage = currentPath.startsWith(lang === 'en' ? '/en/services' : '/services');
const navClass = "px-5 py-2.5 rounded-full text-body-large font-medium whitespace-nowrap hover:text-ink-primary hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard";
const activeClass = "bg-ink-primary/[0.12] text-brand-primary font-medium";
const inactiveClass = "text-ink-muted";
const menuItemClass = "flex items-center gap-3 w-full px-4 py-3 rounded-sm hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard";
---

<header class="z-20 border-b border-stroke-subtle backdrop-blur-[12px] backdrop-saturate-[120%]" role="banner" data-header>
  <div class="mx-auto max-w-7xl flex items-center gap-3 w-full relative h-20 px-6 md:px-12 lg:px-20" data-header-shell>
    <Logo size="md" lang={lang} />
    <nav class="hidden md:flex items-center gap-1 absolute left-1/2 -translate-x-1/2" aria-label="Primary navigation">
      <div class="relative pb-2 -mb-2" data-dropdown>
        <button type="button" class:list={[navClass, isServicePage ? activeClass : inactiveClass]} aria-expanded="false" aria-haspopup="true">
          {navServices}
        </button>
        <div data-dropdown-menu class="absolute top-full left-0 w-56 bg-surface-raised border border-stroke-outlineVariant rounded-md shadow-elevation-2 p-2 opacity-0 pointer-events-none transition-all duration-short4 ease-standard" role="menu">
          <a href={routes.diagnosis} role="menuitem" tabindex="-1" class:list={[menuItemClass, isActive(routes.diagnosis) ? 'text-brand-primary font-medium' : 'text-ink-primary']}>
            <Icon name="search" class="w-5 h-5 text-ink-muted" />
            <span class="text-label-large">{diagnosisTitle}</span>
          </a>
          <a href={routes.guidance} role="menuitem" tabindex="-1" class:list={[menuItemClass, isActive(routes.guidance) ? 'text-brand-primary font-medium' : 'text-ink-primary']}>
            <Icon name="group_work" class="w-5 h-5 text-ink-muted" />
            <span class="text-label-large">{guidanceTitle}</span>
          </a>
          <a href={routes.sparring} role="menuitem" tabindex="-1" class:list={[menuItemClass, isActive(routes.sparring) ? 'text-brand-primary font-medium' : 'text-ink-primary']}>
            <Icon name="handshake" class="w-5 h-5 text-ink-muted" />
            <span class="text-label-large">{sparringTitle}</span>
          </a>
        </div>
      </div>
      <a href={routes.about} aria-current={isActive(routes.about) ? 'page' : undefined} class:list={[navClass, isActive(routes.about) ? activeClass : inactiveClass]}>{navAbout}</a>
      <a href={routes.faq} aria-current={isActive(routes.faq) ? 'page' : undefined} class:list={[navClass, isActive(routes.faq) ? activeClass : inactiveClass]}>{navFaq}</a>
    </nav>
    <div class="flex items-center gap-1 ml-auto flex-shrink-0 z-10">
      <a href={EXTERNAL.email} class="hidden sm:inline-flex items-center justify-center gap-2 border border-brand-primary text-brand-primary px-8 py-3.5 rounded-full text-label-large font-medium whitespace-nowrap hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard">
        <span>{navCta}</span>
      </a>
      <button type="button" class="md:hidden inline-flex h-12 w-12 items-center justify-center rounded-full text-ink-primary hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard" aria-label="Toggle navigation" aria-expanded="false" aria-controls={menuId} data-menu-toggle>
        <span data-menu-icon="closed"><Icon name="menu" class="w-6 h-6" /></span>
        <span data-menu-icon="open" style="display:none"><Icon name="close" class="w-6 h-6" /></span>
      </button>
    </div>
  </div>
  <div id={menuId} inert data-mobile-menu class="md:hidden border-b border-stroke-subtle backdrop-blur-[12px] backdrop-saturate-[120%] transition-[max-height,opacity] duration-medium2 ease-standard max-h-0 opacity-0 pointer-events-none overflow-hidden w-full">
    <div class="max-w-7xl mx-auto px-6 md:px-12 pb-4 space-y-2">
      <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
        <details class="group [&>summary]:list-none [&>summary::-webkit-details-marker]:hidden" data-mobile-services>
          <summary class:list={["flex items-center justify-between px-4 py-3 text-label-large cursor-pointer hover:bg-ink-primary/[0.08] rounded-full transition-all duration-short4 ease-standard", isServicePage ? 'text-brand-primary font-medium' : 'text-ink-muted']}>
            <span>{navServices}</span>
            <span class="inline-flex group-open:rotate-180 transition-transform duration-short4 ease-standard"><Icon name="expand_more" class="w-5 h-5 text-ink-muted" /></span>
          </summary>
          <div class="flex flex-col gap-1 pl-4 overflow-hidden animate-[slideDown_200ms_ease-standard]">
            <a href={routes.diagnosis} class:list={["flex items-center gap-3 px-4 py-3 rounded-full text-body-medium hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard", isActive(routes.diagnosis) ? 'text-brand-primary font-medium' : 'text-ink-primary']} data-menu-close><Icon name="search" class="w-5 h-5 text-ink-muted" />{diagnosisTitle}</a>
            <a href={routes.guidance} class:list={["flex items-center gap-3 px-4 py-3 rounded-full text-body-medium hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard", isActive(routes.guidance) ? 'text-brand-primary font-medium' : 'text-ink-primary']} data-menu-close><Icon name="group_work" class="w-5 h-5 text-ink-muted" />{guidanceTitle}</a>
            <a href={routes.sparring} class:list={["flex items-center gap-3 px-4 py-3 rounded-full text-body-medium hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard", isActive(routes.sparring) ? 'text-brand-primary font-medium' : 'text-ink-primary']} data-menu-close><Icon name="handshake" class="w-5 h-5 text-ink-muted" />{sparringTitle}</a>
          </div>
        </details>
        <a href={routes.about} class:list={["flex items-center px-4 py-3 rounded-full text-label-large hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard", isActive(routes.about) ? 'text-brand-primary font-medium' : 'text-ink-primary']} data-menu-close>{navAbout}</a>
        <a href={routes.faq} class:list={["flex items-center px-4 py-3 rounded-full text-label-large hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard", isActive(routes.faq) ? 'text-brand-primary font-medium' : 'text-ink-primary']} data-menu-close>{navFaq}</a>
      </nav>
      <div class="flex flex-col gap-2 px-4 pt-2">
        <a href={EXTERNAL.email} class="inline-flex items-center justify-center gap-2 border border-brand-primary text-brand-primary py-3 rounded-full text-label-large font-medium hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard" data-menu-close>{navCta}</a>
      </div>
    </div>
  </div>
</header>

<script>
  import { initDropdowns } from '@/ui/Dropdown';

  function initHeader() {
    const header = document.querySelector('[data-header]') as HTMLElement | null;
    const toggle = header?.querySelector('[data-menu-toggle]') as HTMLButtonElement | null;
    const menu = header?.querySelector('[data-mobile-menu]') as HTMLDivElement | null;
    const closeTargets = header?.querySelectorAll('[data-menu-close]') ?? [];
    const iconOpen = header?.querySelector('[data-menu-icon="open"]') as HTMLElement | null;
    const iconClosed = header?.querySelector('[data-menu-icon="closed"]') as HTMLElement | null;

    const setMenuState = (open: boolean) => {
      if (!menu || !toggle) return;
      menu.style.maxHeight = open ? '30rem' : '0px';
      menu.style.opacity = open ? '1' : '0';
      menu.style.pointerEvents = open ? 'auto' : 'none';
      menu.inert = !open;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (iconOpen && iconClosed) {
        (iconOpen as HTMLElement).style.display = open ? 'inline-block' : 'none';
        (iconClosed as HTMLElement).style.display = open ? 'none' : 'inline-block';
      }
    };

    if (toggle) {
      let open = false;
      toggle.addEventListener('click', () => { open = !open; setMenuState(open); });
      closeTargets.forEach((el) => el.addEventListener('click', () => { open = false; setMenuState(open); }));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && open) { open = false; setMenuState(open); toggle.focus(); }
      });
      document.addEventListener('click', (event) => {
        if (open && header && !header.contains(event.target as Node)) {
          open = false; setMenuState(open);
        }
      });
    }

    initDropdowns();
  }

  document.addEventListener('astro:page-load', () => {
    initHeader();
  });
</script>
