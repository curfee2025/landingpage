---
import Icon from '@/components/shared/Icon.astro';
import { EXTERNAL } from '@/configurations/routes';
import { getTranslations } from '@/i18n/translations';
import logoTextRaw from '@/assets/logos/logo_text.svg?raw';
import type { Lang } from '@/configurations/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const menuId = 'mobile-menu';
const navClass = "px-5 py-3 rounded-full text-label-large font-medium whitespace-nowrap text-ink-muted hover:text-ink-primary hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard";
const menuItemClass = "flex items-center px-4 py-3 rounded-full text-label-large hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard text-ink-primary";
---

<header class="z-20 sticky top-0" role="banner" data-header>
  <div class="mx-auto max-w-7xl flex items-center gap-3 w-full relative h-20 px-6 md:px-12 lg:px-20" data-header-shell>
    <a href={lang === 'en' ? '/en/' : '/'} class="flex-shrink-0 block h-7 text-brand-primary [&>svg]:h-full [&>svg]:max-h-full [&>svg]:w-auto" aria-label="Curfee" set:html={logoTextRaw} />

    <nav class="hidden md:flex items-center gap-1 absolute left-1/2 -translate-x-1/2" aria-label="Primary navigation">
      <a href="#services" class={navClass}>{t['nav.services']}</a>
      <a href="#about" class={navClass}>{t['nav.about']}</a>
      <a href="#blog" class={navClass}>{t['nav.blog']}</a>
      <a href="#faq" class={navClass}>{t['nav.faq']}</a>
    </nav>

    <div class="flex items-center gap-1 ml-auto flex-shrink-0 z-10">
      <a href={EXTERNAL.mailto} class="hidden sm:inline-flex items-center justify-center gap-2 border border-brand-primary text-brand-primary px-5 py-2.5 rounded-full text-label-large font-medium whitespace-nowrap hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard">
        <span>{t['nav.cta']}</span>
      </a>
      <button type="button" class="md:hidden inline-flex h-12 w-12 items-center justify-center rounded-full text-ink-primary hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard" aria-label="Toggle navigation" aria-expanded="false" aria-controls={menuId} data-menu-toggle>
        <span data-menu-icon="closed"><Icon name="menu" class="w-6 h-6" /></span>
        <span data-menu-icon="open" style="display:none"><Icon name="close" class="w-6 h-6" /></span>
      </button>
    </div>
  </div>

  <div id={menuId} inert data-mobile-menu class="md:hidden absolute -left-px -right-px transition-[max-height,opacity] duration-medium2 ease-standard max-h-0 opacity-0 pointer-events-none overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 md:px-12 pb-4 space-y-2">
      <nav class="flex flex-col gap-1" aria-label="Mobile navigation">
        <a href="#services" class={menuItemClass} data-menu-close>{t['nav.services']}</a>
        <a href="#about" class={menuItemClass} data-menu-close>{t['nav.about']}</a>
        <a href="#blog" class={menuItemClass} data-menu-close>{t['nav.blog']}</a>
        <a href="#faq" class={menuItemClass} data-menu-close>{t['nav.faq']}</a>
      </nav>
      <div class="flex flex-col gap-2 px-4 pt-2">
        <a href={EXTERNAL.mailto} class="inline-flex items-center justify-center gap-2 border border-brand-primary text-brand-primary py-3 rounded-full text-label-large font-medium hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard" data-menu-close>{t['nav.cta']}</a>
      </div>
    </div>
  </div>
</header>

<style>
  [data-header] {
    --menu-height: 0px;
    --header-duration: 500ms;
    --header-ease: cubic-bezier(0.25, 0.1, 0.25, 1);
    transition: top var(--header-duration) var(--header-ease);
  }
  [data-header]::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    backdrop-filter: blur(12px) saturate(120%);
    -webkit-backdrop-filter: blur(12px) saturate(120%);
    border-radius: 0;
    z-index: -1;
    transition: left var(--header-duration) var(--header-ease),
                right var(--header-duration) var(--header-ease),
                border-radius var(--header-duration) var(--header-ease);
  }
  [data-header][data-scrolled] {
    top: 0.75rem;
  }
  [data-header][data-scrolled]::before {
    left: max(0.5rem, calc(50% - 32rem));
    right: max(0.5rem, calc(50% - 32rem));
    border-radius: 1.25rem;
  }
  [data-header-shell] {
    transition: height var(--header-duration) var(--header-ease),
                max-width var(--header-duration) var(--header-ease),
                padding-left var(--header-duration) var(--header-ease),
                padding-right var(--header-duration) var(--header-ease);
  }
  [data-header][data-scrolled] [data-header-shell] {
    height: 4rem;
    max-width: 64rem;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }
  [data-header][data-scrolled] [data-header-shell] a[href^="mailto"] {
    padding: 0.625rem 1.25rem;
  }
  @media (max-width: 767px) {
    [data-header][data-scrolled] [data-header-shell] {
      padding-left: 1.5rem;
      padding-right: 1.5rem;
    }
    [data-header]::before {
      height: calc(100% + var(--menu-height));
    }
    [data-header][data-scrolled]::before {
      left: 0.5rem;
      right: 0.5rem;
    }
    [data-header][data-scrolled][data-menu-open]::before {
      border-bottom-left-radius: 0;
      border-bottom-right-radius: 0;
    }
    [data-header][data-scrolled] [data-mobile-menu] {
      border-bottom-left-radius: 1.25rem;
      border-bottom-right-radius: 1.25rem;
    }
  }
</style>

<script>
  function initHeader() {
    const header = document.querySelector('[data-header]') as HTMLElement | null;
    const toggle = header?.querySelector('[data-menu-toggle]') as HTMLButtonElement | null;
    const menu = header?.querySelector('[data-mobile-menu]') as HTMLDivElement | null;
    const closeTargets = header?.querySelectorAll('[data-menu-close]') ?? [];
    const iconOpen = header?.querySelector('[data-menu-icon="open"]') as HTMLElement | null;
    const iconClosed = header?.querySelector('[data-menu-icon="closed"]') as HTMLElement | null;

    let menuOpen = false;
    const updateMenuHeight = () => {
      if (!menu || !header) return;
      header.style.setProperty('--menu-height', menuOpen ? `${menu.scrollHeight}px` : '0px');
    };

    let menuObserver: ResizeObserver | null = null;
    if (menu) {
      menuObserver = new ResizeObserver(updateMenuHeight);
      menuObserver.observe(menu);
    }

    const setMenuState = (open: boolean) => {
      if (!menu || !toggle || !header) return;
      menuOpen = open;
      updateMenuHeight();
      menu.style.maxHeight = open ? '30rem' : '0px';
      menu.style.opacity = open ? '1' : '0';
      menu.style.pointerEvents = open ? 'auto' : 'none';
      menu.inert = !open;
      toggle.setAttribute('aria-expanded', open ? 'true' : 'false');
      if (open) {
        header.setAttribute('data-menu-open', '');
      } else {
        header.removeAttribute('data-menu-open');
      }
      if (iconOpen && iconClosed) {
        iconOpen.style.display = open ? 'inline-block' : 'none';
        iconClosed.style.display = open ? 'none' : 'inline-block';
      }
    };

    if (toggle) {
      let open = false;
      toggle.addEventListener('click', () => { open = !open; setMenuState(open); });
      closeTargets.forEach((el) => el.addEventListener('click', () => { open = false; setMenuState(open); }));
      document.addEventListener('keydown', (event) => {
        if (event.key === 'Escape' && open) { open = false; setMenuState(open); toggle.focus(); }
      });
      document.addEventListener('click', (event) => {
        if (open && header && !header.contains(event.target as Node)) {
          open = false; setMenuState(open);
        }
      });
    }

    if (header) {
      let scrolled = false;
      const onScroll = () => {
        const threshold = scrolled ? 40 : 80;
        const shouldBeScrolled = window.scrollY > threshold;
        if (shouldBeScrolled !== scrolled) {
          scrolled = shouldBeScrolled;
          if (scrolled) {
            header.setAttribute('data-scrolled', '');
          } else {
            header.removeAttribute('data-scrolled');
          }
        }
      };
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
    }
  }

  document.addEventListener('astro:page-load', () => {
    initHeader();
  });
</script>
