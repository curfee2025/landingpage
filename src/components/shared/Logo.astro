---
import logoIconRaw from '@/assets/logos/logo-icon_filled.svg?raw';
import logoTextOnlyRaw from '@/assets/logos/logo_text_only.svg?raw';
import type { Lang } from '@/configurations/i18n';

interface Props {
  size?: 'sm' | 'md';
  lang?: Lang;
}

const { size = 'md', lang = 'en' } = Astro.props;
const iconHeight = size === 'sm' ? 'h-9' : 'h-10';
const textHeight = size === 'sm' ? 'h-[20px]' : 'h-[24px]';
const homeHref = lang === 'de' ? '/de/' : '/';
---

<a href={homeHref} class="flex items-center gap-3 flex-shrink-0 z-10 rounded-sm hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard p-1 -m-1" aria-label="Curfee Home">
  <!-- Icon (larger) -->
  <span class={`${iconHeight} text-brand-primary [&>svg]:h-full [&>svg]:w-auto`} set:html={logoIconRaw} />
  <!-- Text "CURFEE" (smaller, hidden on mobile) -->
  <span class={`${textHeight} text-brand-primary [&>svg]:h-full [&>svg]:w-auto`} set:html={logoTextOnlyRaw} />
</a>
