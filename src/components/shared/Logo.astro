---
import logoIconRaw from '@/assets/logos/logo_icon.svg?raw';
interface Props {
  size?: 'sm' | 'md';
  lang?: 'de' | 'en';
}

const { size = 'md', lang = 'de' } = Astro.props;
const iconHeight = size === 'sm' ? 'h-8' : 'h-10';
const homeHref = lang === 'en' ? '/en/' : '/';
---

<a href={homeHref} class="flex items-center flex-shrink-0 z-10" aria-label="Curfee Home">
  <span class={`${iconHeight} text-brand-primary [&>svg]:h-full [&>svg]:w-auto`} set:html={logoIconRaw} />
</a>
