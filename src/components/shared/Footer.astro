---
import Icon from '@/components/shared/Icon.astro';
import { localizedRoutes } from '@/configurations/routes';
import { BRAND } from '@/configurations/brand';
import { getTranslations } from '@/i18n/translations';
import type { Lang } from '@/configurations/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const routes = localizedRoutes(lang);
const year = new Date().getFullYear();
const linkClass = "text-body-medium text-ink-onSurfaceVariant px-3 py-3 rounded-full hover:bg-ink-primary/[0.08] active:bg-ink-primary/[0.12] transition-all duration-short4 ease-standard";

const currentPath = Astro.url.pathname;
let otherLangPath: string;
let otherLangLabel: string;

if (lang === 'en') {
  const basePath = currentPath.replace(/^\/en\/?/, '/') || '/';
  otherLangPath = basePath;
  otherLangLabel = 'Deutsch';
} else {
  otherLangPath = currentPath === '/' ? '/en/' : `/en${currentPath}`;
  otherLangLabel = 'English';
}
---

<footer class="border-t border-stroke-subtle pt-10 pb-10" style="padding-bottom: max(2.5rem, env(safe-area-inset-bottom, 2.5rem));" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <nav class="flex flex-wrap items-center justify-center gap-2 mb-6" aria-label="Legal navigation">
      <a href={routes.imprint} class={linkClass}>{t['footer.legal.notice']}</a>
      <span class="text-ink-muted" aria-hidden="true">&middot;</span>
      <a href={routes.privacy} class={linkClass}>{t['footer.legal.privacy']}</a>
      <span class="text-ink-muted" aria-hidden="true">&middot;</span>
      <a href={routes.cookies} class={linkClass}>{t['footer.legal.cookies']}</a>
    </nav>
    <div class="flex flex-wrap items-center justify-center gap-4 text-body-small text-ink-muted">
      <span>&copy; {year} {BRAND.name} · {t['footer.copyright']}</span>
      <a href={BRAND.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-ink-onSurfaceVariant hover:text-ink-primary px-3 py-3 rounded-full hover:bg-ink-primary/[0.08] active:bg-ink-primary/[0.12] transition-all duration-short4 ease-standard" aria-label="LinkedIn">
        <Icon name="linkedin" class="w-4 h-4" />
        LinkedIn
      </a>
      <a href={otherLangPath} data-lang-switch class="flex items-center gap-2 text-ink-onSurfaceVariant hover:text-ink-primary px-3 py-3 rounded-full hover:bg-ink-primary/[0.08] active:bg-ink-primary/[0.12] transition-all duration-short4 ease-standard" aria-label="Switch language">
        <Icon name="language" class="w-4 h-4" />
        {otherLangLabel}
      </a>
    </div>
  </div>
</footer>
