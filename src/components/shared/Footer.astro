---
import Icon from '@/components/shared/Icon.astro';
import { localizedRoutes } from '@/configurations/routes';
import { BRAND } from '@/configurations/brand';
import { getTranslations } from '@/i18n/translations';
import logoTextRaw from '@/assets/logos/logo_text.svg?raw';
import type { Lang } from '@/configurations/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = getTranslations(lang);
const routes = localizedRoutes(lang);
const year = new Date().getFullYear();
const linkClass = "text-body-medium text-ink-muted hover:text-ink-primary transition-colors duration-short4 ease-standard";

const currentPath = Astro.url.pathname;
let otherLangPath: string;
let otherLangLabel: string;

if (lang === 'en') {
  const basePath = currentPath.replace(/^\/en\/?/, '/') || '/';
  otherLangPath = basePath;
  otherLangLabel = 'Deutsch';
} else {
  otherLangPath = currentPath === '/' ? '/en/' : `/en${currentPath}`;
  otherLangLabel = 'English';
}
---

<footer class="pt-12 pb-10" style="padding-bottom: max(2.5rem, env(safe-area-inset-bottom, 2.5rem));" role="contentinfo">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto] gap-10 md:gap-16 mb-10">

      <!-- Left: Logo + Tagline -->
      <div>
        <div class="mb-4">
          <span class="block h-7 text-brand-primary [&>svg]:h-full [&>svg]:max-h-full [&>svg]:w-auto" aria-hidden="true" set:html={logoTextRaw} />
        </div>
        <p class="text-body-medium text-ink-muted/60 max-w-xs leading-relaxed italic">{t['footer.tagline']}</p>
      </div>

      <!-- Right columns: Legal + Contact (side by side on mobile too) -->
      <div class="col-span-1 md:contents grid grid-cols-2 gap-10">
        <div>
          <p class="text-label-large text-ink-primary mb-4">{t['footer.column.legal']}</p>
          <nav class="flex flex-col gap-2" aria-label="Legal navigation">
            <a href={routes.imprint} class={linkClass}>{t['footer.legal.notice']}</a>
            <a href={routes.privacy} class={linkClass}>{t['footer.legal.privacy']}</a>
            <a href={routes.cookies} class={linkClass}>{t['footer.legal.cookies']}</a>
          </nav>
        </div>

        <div>
          <p class="text-label-large text-ink-primary mb-4">{t['footer.column.contact']}</p>
          <div class="flex flex-col gap-2">
            <a href={`mailto:${t['contact.email']}`} class={linkClass}>{t['contact.email']}</a>
            <a href={`tel:${t['contact.phone'].replace(/\s/g, '')}`} class={linkClass}>{t['contact.phone']}</a>
            <a href={BRAND.linkedin} target="_blank" rel="noopener noreferrer" class={`flex items-center gap-2 ${linkClass}`}>
              <Icon name="linkedin" class="w-4 h-4" />
              LinkedIn
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-stroke-subtle pt-6 flex flex-wrap items-center justify-between gap-4 text-body-small text-ink-muted">
      <span>&copy; {year} {BRAND.name} · {t['footer.copyright']}</span>
      <a href={otherLangPath} data-lang-switch class="flex items-center gap-2 text-ink-onSurfaceVariant hover:text-ink-primary px-3 py-2 rounded-full hover:bg-ink-primary/[0.08] active:bg-ink-primary/[0.12] transition-all duration-short4 ease-standard">
        <Icon name="language" class="w-4 h-4" />
        {otherLangLabel}
      </a>
    </div>

  </div>
</footer>
