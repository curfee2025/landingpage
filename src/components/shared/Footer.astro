---
import Icon from '@/components/shared/Icon.astro';
import Logo from '@/components/shared/Logo.astro';
import { localizedRoutes } from '@/configurations/routes';
import { BRAND } from '@/configurations/brand';
import type { Lang } from '@/configurations/i18n';

interface Props {
  lang: Lang;
  translations: Record<string, string>;
}

const { lang, translations: t } = Astro.props;
const routes = localizedRoutes(lang);
const year = new Date().getFullYear();
const linkClass = "text-body-medium text-ink-onSurfaceVariant px-3 py-2 rounded-sm hover:bg-ink-primary/[0.08] active:bg-ink-primary/[0.12] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary/40 -ml-3";

// Language toggle: link to the other language version
const currentPath = Astro.url.pathname;
let otherLangPath: string;
let otherLangLabel: string;

if (lang === 'de') {
  // Strip /de prefix to get EN path
  const basePath = currentPath.replace(/^\/de\/?/, '/') || '/';
  otherLangPath = basePath;
  otherLangLabel = 'English';
} else {
  // Add /de prefix for DE path
  otherLangPath = currentPath === '/' ? '/de/' : `/de${currentPath}`;
  otherLangLabel = 'Deutsch';
}
---

<footer class="border-t border-stroke-subtle bg-surface-soft pt-12 pb-8" role="contentinfo">
  <div class="max-w-6xl mx-auto px-4 md:px-6">
    <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-10 pb-10">
      <div class="max-w-sm">
        <Logo size="md" lang={lang} />
      </div>
      <nav class="grid grid-cols-2 md:grid-cols-3 gap-x-12 gap-y-8" aria-label="Footer navigation">
        <!-- Services column -->
        <div class="space-y-2">
          <div class="text-title-small font-medium text-ink-primary px-3 -ml-3">{t['navigation.services']}</div>
          <ul class="flex flex-col">
            <li><a href={routes.diagnosis} class={linkClass}>{t['services.diagnosis.title']}</a></li>
            <li><a href={routes.design} class={linkClass}>{t['services.design.title']}</a></li>
            <li><a href={routes.advisory} class={linkClass}>{t['services.advisory.title']}</a></li>
            <li><a href={routes.handson} class={linkClass}>{t['services.handson.title']}</a></li>
          </ul>
        </div>
        <!-- Company column -->
        <div class="space-y-2">
          <div class="text-title-small font-medium text-ink-primary px-3 -ml-3">{t['footer.company']}</div>
          <ul class="flex flex-col">
            <li><a href={routes.about} class={linkClass}>{t['navigation.about']}</a></li>
            <li><a href={routes.faq} class={linkClass}>{t['navigation.faq']}</a></li>
          </ul>
        </div>
        <!-- Legal column -->
        <div class="space-y-2">
          <div class="text-title-small font-medium text-ink-primary px-3 -ml-3">{t['footer.legal.heading']}</div>
          <ul class="flex flex-col">
            <li><a href={routes.imprint} class={linkClass}>{t['footer.legal.notice']}</a></li>
            <li><a href={routes.cookies} class={linkClass}>{t['footer.legal.cookies']}</a></li>
            <li><a href={routes.privacy} class={linkClass}>{t['footer.legal.privacy']}</a></li>
          </ul>
        </div>
      </nav>
    </div>

    <!-- Bottom bar -->
    <div class="pt-6 border-t border-stroke-subtle flex items-center justify-between">
      <span class="text-body-small text-ink-muted">&copy; {year} {BRAND.name} · {t['footer.copyright']}</span>
      <div class="flex items-center gap-4">
        <a href={BRAND.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-body-small text-ink-onSurfaceVariant hover:text-ink-primary px-3 py-2 rounded-sm hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary/40" aria-label="LinkedIn">
          <Icon name="linkedin" class="w-5 h-5" />
          LinkedIn
        </a>
        <a href={otherLangPath} class="flex items-center gap-2 text-body-small text-ink-onSurfaceVariant hover:text-ink-primary px-3 py-2 rounded-sm hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-secondary/40" aria-label="Switch language">
          <Icon name="language" class="w-5 h-5" />
          {otherLangLabel}
        </a>
      </div>
    </div>
  </div>
</footer>
