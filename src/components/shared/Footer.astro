---
import Icon from '@/components/shared/Icon.astro';
import { ROUTES } from '@/configurations/routes';
import { BRAND } from '@/configurations/brand';
import { getTranslations } from '@/i18n/translations';
import logoTextRaw from '@/assets/logos/logo_text.svg?raw';

const t = getTranslations();
const routes = ROUTES;
const year = new Date().getFullYear();
const linkClass = "text-body-medium text-ink-muted hover:text-ink-primary transition-colors duration-short4 ease-standard";
---

<footer class="pt-20 md:pt-28 pb-12" style="padding-bottom: max(3rem, env(safe-area-inset-bottom, 3rem));" role="contentinfo">
  <div class="max-w-[64rem] mx-auto px-6">

    <div class="grid grid-cols-1 md:grid-cols-[1fr_auto_auto_auto] gap-10 md:gap-16 mb-16">

      <!-- Left: Logo + Tagline (link to home) -->
      <a href={routes.home} class="block no-underline hover:no-underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/40 rounded-sm" aria-label={t['back.home']}>
        <div class="mb-4">
          <span class="block h-9 text-brand-primary [&>svg]:h-full [&>svg]:max-h-full [&>svg]:w-auto" aria-hidden="true" set:html={logoTextRaw} />
        </div>
        <p class="text-body-medium text-ink-muted/60 max-w-xs leading-relaxed italic">{t['footer.tagline']}</p>
      </a>

      <!-- Right columns: Company + Legal + Contact -->
      <div class="col-span-1 md:contents grid grid-cols-2 md:grid-cols-none gap-10">
        <div>
          <p class="text-label-large text-ink-primary mb-4">{t['footer.column.company']}</p>
          <nav class="flex flex-col gap-3" aria-label="Company navigation">
            <a href={routes.blog} class={linkClass}>{t['blog.indexHeading']}</a>
          </nav>
        </div>

        <div>
          <p class="text-label-large text-ink-primary mb-4">{t['footer.column.legal']}</p>
          <nav class="flex flex-col gap-3" aria-label="Legal navigation">
            <a href={routes.imprint} class={linkClass}>{t['footer.legal.notice']}</a>
            <a href={routes.privacy} class={linkClass}>{t['footer.legal.privacy']}</a>
          </nav>
        </div>

        <div>
          <p class="text-label-large text-ink-primary mb-4">{t['footer.column.contact']}</p>
          <div class="flex flex-col gap-3">
            <a href={`mailto:${t['contact.email']}`} class={linkClass}>{t['contact.email']}</a>
            <a href={`tel:${t['contact.phone'].replace(/\s/g, '')}`} class={linkClass}>{t['contact.phone']}</a>
            <a href={BRAND.linkedin} target="_blank" rel="noopener noreferrer" class={`flex items-center gap-2 ${linkClass}`}>
              <Icon name="linkedin" class="w-4 h-4" />
              LinkedIn
            </a>
          </div>
        </div>
      </div>

    </div>

    <!-- Bottom bar -->
    <div class="border-t border-stroke-subtle pt-6 text-body-small text-ink-muted">
      <span>&copy; {year} {BRAND.name} · {t['footer.copyright']}</span>
    </div>

  </div>
</footer>
