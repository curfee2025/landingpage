---
import Icon from '@/components/shared/Icon.astro';

interface ServiceConfig {
  title: string;
  subtitle: string;
  description: string;
  outcome: string;
  deliverables: string[];
  icon: string;
  href: string;
  iconBg: string;
  iconText: string;
  accentBg: string;
  deliverableBg: string;
}

interface Props {
  heading: string;
  services: ServiceConfig[];
}
const { heading, services } = Astro.props;
---

<section id="services" class="py-20 md:py-24" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="services-heading" class="text-headline-large md:text-display-small text-ink-primary">{heading}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-[auto_auto_auto_auto_1fr_auto_auto_auto] gap-x-8 gap-y-0 max-w-6xl mx-auto">
      {services.map((service) => (
          <a href={service.href} class="grid md:grid-rows-subgrid md:row-span-8 rounded-md border border-stroke-outlineVariant bg-surface-raised overflow-hidden transition-all duration-medium2 ease-standard hover:shadow-elevation-2 hover:-translate-y-0.5 cursor-pointer no-underline mb-8 md:mb-0">
            <div class:list={["h-1.5 w-full", service.accentBg]} />
            <div class="px-8 pt-8 md:px-10 md:pt-10">
              <div class:list={["w-12 h-12 rounded-full flex items-center justify-center", service.iconBg]}>
                <Icon name={service.icon} class:list={["w-7 h-7", service.iconText]} />
              </div>
            </div>
            <h3 class="text-title-large text-ink-primary px-8 pt-6 md:px-10">{service.title}</h3>
            <p class:list={["text-body-medium px-8 pt-2 md:px-10", service.iconText]}>{service.subtitle}</p>
            <p class="px-8 pt-6 md:px-10 text-body-medium text-ink-muted">{service.description}</p>
            <p class="px-8 pt-3 md:px-10 text-body-medium text-ink-muted">{service.outcome}</p>
            <div />
            {service.deliverables.length > 0 && (
              <div class="px-8 pb-8 pt-6 md:px-10 md:pb-10 flex">
                <div class:list={["rounded-md p-5 w-full", service.deliverableBg]}>
                  <ul class="space-y-2">
                    {service.deliverables.map(item => (
                      <li class="flex items-start gap-2">
                        <Icon name="arrow_right_alt" class:list={["w-4 h-4 flex-shrink-0 mt-0.5", service.iconText]} />
                        <span class="text-body-medium text-ink-primary">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}
          </a>
      ))}
    </div>
  </div>
</section>
