---
import Icon from '@/components/shared/Icon.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { localizedRoutes } from '@/configurations/routes';

import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const routes = localizedRoutes(lang);

const services = [
  {
    title: t['services.diagnosis.title'],
    subtitle: t['services.diagnosis.subtitle'],
    description: t['services.diagnosis.description'],
    outcome: t['services.diagnosis.deliverable'],
    deliverables: [t['services.diagnosis.deliverable.1'], t['services.diagnosis.deliverable.2'], t['services.diagnosis.deliverable.3'], t['services.diagnosis.deliverable.4']],
    icon: 'search', href: routes.diagnosis,
    iconBg: 'bg-brand-primary/10', iconText: 'text-brand-primary', accentBg: 'bg-brand-primary', deliverableBg: 'bg-brand-primary/[0.08]',
  },
  {
    title: t['services.guidance.title'],
    subtitle: t['services.guidance.subtitle'],
    description: t['services.guidance.description'],
    outcome: t['services.guidance.deliverable'],
    deliverables: [t['services.guidance.deliverable.1'], t['services.guidance.deliverable.2'], t['services.guidance.deliverable.3']],
    icon: 'group_work', href: routes.guidance,
    iconBg: 'bg-brand-secondary/10', iconText: 'text-brand-secondary', accentBg: 'bg-brand-secondary', deliverableBg: 'bg-brand-secondary/[0.08]',
  },
  {
    title: t['services.sparring.title'],
    subtitle: t['services.sparring.subtitle'],
    description: t['services.sparring.description'],
    outcome: t['services.sparring.deliverable'],
    deliverables: [t['services.sparring.deliverable.1'], t['services.sparring.deliverable.2'], t['services.sparring.deliverable.3']],
    icon: 'handshake', href: routes.sparring,
    iconBg: 'bg-brand-tertiary/10', iconText: 'text-brand-tertiary', accentBg: 'bg-brand-tertiary', deliverableBg: 'bg-brand-tertiary/[0.08]',
  },
];
---

<section id="services" class="py-20 md:py-24" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="services-heading" class="text-headline-large md:text-display-small text-ink-primary">{t['services.heading']}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 md:grid-rows-[auto_auto_auto_auto_1fr_auto_auto_auto] gap-x-8 gap-y-0 max-w-6xl mx-auto">
      {services.map((service) => (
          <a href={service.href} class="grid md:grid-rows-subgrid md:row-span-8 rounded-md border border-stroke-outlineVariant bg-surface-raised overflow-hidden transition-all duration-medium2 ease-standard hover:shadow-elevation-2 hover:-translate-y-0.5 cursor-pointer no-underline mb-8 md:mb-0">
            <div class:list={["h-1.5 w-full", service.accentBg]} />
            <div class="px-8 pt-8 md:px-10 md:pt-10">
              <div class:list={["w-12 h-12 rounded-full flex items-center justify-center", service.iconBg]}>
                <Icon name={service.icon} class:list={["w-7 h-7", service.iconText]} />
              </div>
            </div>
            <h3 class="text-title-large text-ink-primary px-8 pt-6 md:px-10">{service.title}</h3>
            <p class:list={["text-body-medium px-8 pt-2 md:px-10", service.iconText]}>{service.subtitle}</p>
            <p class="px-8 pt-6 md:px-10 text-body-medium text-ink-muted">{service.description}</p>
            <p class="px-8 pt-3 md:px-10 text-body-medium text-ink-muted">{service.outcome}</p>
            <div />
            {service.deliverables.length > 0 && (
              <div class="px-8 pb-8 pt-6 md:px-10 md:pb-10 flex">
                <div class:list={["rounded-md p-5 w-full", service.deliverableBg]}>
                  <ul class="space-y-2">
                    {service.deliverables.map(item => (
                      <li class="flex items-start gap-2">
                        <Icon name="arrow_right_alt" class:list={["w-4 h-4 flex-shrink-0 mt-0.5", service.iconText]} />
                        <span class="text-body-medium text-ink-primary">{item}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            )}
          </a>
      ))}
    </div>
  </div>
</section>
