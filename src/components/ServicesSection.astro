---
import Icon from '@/components/shared/Icon.astro';
import { EXTERNAL } from '@/configurations/routes';
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

interface TimelineStep {
  phase: string;
  title: string;
  outcome: string;
  items: string[];
}

interface ServiceCard {
  key: 'diagnosis' | 'guidance' | 'sparring';
  icon: string;
  title: string;
  subtitle: string;
  progression: string;
  duration: string;
  problem: string;
  forwhom: string[];
  timeline: TimelineStep[];
  delivers: string[];
  excludes: string[];
  objectionQ: string;
  objectionA: string;
  colorText: string;
  colorBg: string;
  colorBorder: string;
  colorDot: string;
}

const services: ServiceCard[] = [
  {
    key: 'diagnosis',
    icon: 'search',
    title: t['services.diagnosis.title'],
    subtitle: t['services.diagnosis.subtitle'],
    progression: t['services.diagnosis.progression'],
    duration: t['services.diagnosis.duration'],
    problem: t['services.diagnosis.problem'],
    forwhom: [t['services.diagnosis.forwhom.1'], t['services.diagnosis.forwhom.2'], t['services.diagnosis.forwhom.3']],
    timeline: [
      {
        phase: t['services.diagnosis.timeline.1.phase'],
        title: t['services.diagnosis.timeline.1.title'],
        outcome: t['services.diagnosis.timeline.1.outcome'],
        items: [t['services.diagnosis.timeline.1.item.1'], t['services.diagnosis.timeline.1.item.2']],
      },
      {
        phase: t['services.diagnosis.timeline.2.phase'],
        title: t['services.diagnosis.timeline.2.title'],
        outcome: t['services.diagnosis.timeline.2.outcome'],
        items: [t['services.diagnosis.timeline.2.item.1'], t['services.diagnosis.timeline.2.item.2'], t['services.diagnosis.timeline.2.item.3']],
      },
      {
        phase: t['services.diagnosis.timeline.3.phase'],
        title: t['services.diagnosis.timeline.3.title'],
        outcome: t['services.diagnosis.timeline.3.outcome'],
        items: [t['services.diagnosis.timeline.3.item.1'], t['services.diagnosis.timeline.3.item.2'], t['services.diagnosis.timeline.3.item.3']],
      },
    ],
    delivers: [t['services.diagnosis.delivers.1'], t['services.diagnosis.delivers.2'], t['services.diagnosis.delivers.3'], t['services.diagnosis.delivers.4']],
    excludes: [t['services.diagnosis.excludes.1'], t['services.diagnosis.excludes.2'], t['services.diagnosis.excludes.3']],
    objectionQ: t['services.diagnosis.objection.q'],
    objectionA: t['services.diagnosis.objection.a'],
    colorText: 'text-brand-primary',
    colorBg: 'bg-brand-primary/[0.08]',
    colorBorder: 'border-brand-primary',
    colorDot: 'bg-brand-primary',
  },
  {
    key: 'guidance',
    icon: 'route',
    title: t['services.guidance.title'],
    subtitle: t['services.guidance.subtitle'],
    progression: t['services.guidance.progression'],
    duration: t['services.guidance.duration'],
    problem: t['services.guidance.problem'],
    forwhom: [t['services.guidance.forwhom.1'], t['services.guidance.forwhom.2'], t['services.guidance.forwhom.3']],
    timeline: [
      {
        phase: t['services.guidance.timeline.1.phase'],
        title: t['services.guidance.timeline.1.title'],
        outcome: t['services.guidance.timeline.1.outcome'],
        items: [t['services.guidance.timeline.1.item.1'], t['services.guidance.timeline.1.item.2'], t['services.guidance.timeline.1.item.3']],
      },
      {
        phase: t['services.guidance.timeline.2.phase'],
        title: t['services.guidance.timeline.2.title'],
        outcome: t['services.guidance.timeline.2.outcome'],
        items: [t['services.guidance.timeline.2.item.1'], t['services.guidance.timeline.2.item.2'], t['services.guidance.timeline.2.item.3']],
      },
      {
        phase: t['services.guidance.timeline.3.phase'],
        title: t['services.guidance.timeline.3.title'],
        outcome: t['services.guidance.timeline.3.outcome'],
        items: [t['services.guidance.timeline.3.item.1'], t['services.guidance.timeline.3.item.2'], t['services.guidance.timeline.3.item.3']],
      },
      {
        phase: t['services.guidance.timeline.4.phase'],
        title: t['services.guidance.timeline.4.title'],
        outcome: t['services.guidance.timeline.4.outcome'],
        items: [t['services.guidance.timeline.4.item.1'], t['services.guidance.timeline.4.item.2'], t['services.guidance.timeline.4.item.3']],
      },
    ],
    delivers: [t['services.guidance.delivers.1'], t['services.guidance.delivers.2'], t['services.guidance.delivers.3'], t['services.guidance.delivers.4']],
    excludes: [t['services.guidance.excludes.1'], t['services.guidance.excludes.2'], t['services.guidance.excludes.3']],
    objectionQ: t['services.guidance.objection.q'],
    objectionA: t['services.guidance.objection.a'],
    colorText: 'text-brand-secondary',
    colorBg: 'bg-brand-secondary/10',
    colorBorder: 'border-brand-secondary',
    colorDot: 'bg-brand-secondary',
  },
  {
    key: 'sparring',
    icon: 'handshake',
    title: t['services.sparring.title'],
    subtitle: t['services.sparring.subtitle'],
    progression: t['services.sparring.progression'],
    duration: t['services.sparring.duration'],
    problem: t['services.sparring.problem'],
    forwhom: [t['services.sparring.forwhom.1'], t['services.sparring.forwhom.2'], t['services.sparring.forwhom.3']],
    timeline: [
      {
        phase: t['services.sparring.timeline.1.phase'],
        title: t['services.sparring.timeline.1.title'],
        outcome: t['services.sparring.timeline.1.outcome'],
        items: [t['services.sparring.timeline.1.item.1'], t['services.sparring.timeline.1.item.2'], t['services.sparring.timeline.1.item.3']],
      },
      {
        phase: t['services.sparring.timeline.2.phase'],
        title: t['services.sparring.timeline.2.title'],
        outcome: t['services.sparring.timeline.2.outcome'],
        items: [t['services.sparring.timeline.2.item.1'], t['services.sparring.timeline.2.item.2'], t['services.sparring.timeline.2.item.3']],
      },
      {
        phase: t['services.sparring.timeline.3.phase'],
        title: t['services.sparring.timeline.3.title'],
        outcome: t['services.sparring.timeline.3.outcome'],
        items: [t['services.sparring.timeline.3.item.1'], t['services.sparring.timeline.3.item.2'], t['services.sparring.timeline.3.item.3']],
      },
    ],
    delivers: [t['services.sparring.delivers.1'], t['services.sparring.delivers.2'], t['services.sparring.delivers.3'], t['services.sparring.delivers.4']],
    excludes: [t['services.sparring.excludes.1'], t['services.sparring.excludes.2'], t['services.sparring.excludes.3']],
    objectionQ: t['services.sparring.objection.q'],
    objectionA: t['services.sparring.objection.a'],
    colorText: 'text-brand-tertiary',
    colorBg: 'bg-brand-tertiary/10',
    colorBorder: 'border-brand-tertiary',
    colorDot: 'bg-brand-tertiary',
  },
];
---

<section id="services" class="py-20 md:py-24" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="services-heading" data-speakable class="text-headline-large md:text-display-small text-ink-primary mb-2">
        {t['services.heading']}
      </h2>
      <p class="text-title-medium text-ink-muted font-medium mb-12">
        {t['services.subtitle']}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 items-start">
      {services.map((service) => (
        <div
          class:list={["card flex flex-col rounded-lg border border-stroke-outlineVariant bg-surface-raised overflow-hidden cursor-pointer transition-[border-color] duration-medium2 ease-standard hover:border-ink-muted/30", service.key === 'sparring' && 'md:col-span-2']}
          data-service-card={service.key}
          role="button"
          tabindex="0"
          aria-expanded="false"
        >
          <!-- Header (always visible) -->
          <div class="flex justify-between items-start gap-4 px-6 pt-6 md:px-8 md:pt-8" data-service-header>
            <div class="flex-1 min-w-0">
              <div class:list={["w-10 h-10 rounded-full flex items-center justify-center mb-4", service.colorBg]}>
                <Icon name={service.icon} class:list={["w-5 h-5", service.colorText]} />
              </div>
              <span class:list={["inline-block rounded-full text-label-medium px-3 py-0.5 mb-2", service.colorText, service.colorBg]}>
                {service.progression}
              </span>
              <div class="flex items-center gap-3 flex-wrap mb-1">
                <h3 class="text-title-large text-ink-primary">{service.title}</h3>
                <span class:list={["rounded-full text-label-medium px-3 py-0.5 border whitespace-nowrap", service.colorText, service.colorBorder]}>
                  {service.duration}
                </span>
              </div>
              <p class:list={["text-body-medium", service.colorText]}>{service.subtitle}</p>
            </div>
            <span class="w-6 h-6 flex items-center justify-center flex-shrink-0 mt-2 toggle-icon">
              <Icon name="navigate_next" class="w-5 h-5 text-ink-muted" />
            </span>
          </div>

          <p class="px-6 pt-2 pb-5 md:px-8 text-body-medium text-ink-muted italic flex-1">
            {service.problem}
          </p>

          <!-- Body (expandable) -->
          <div class="card-body" data-service-body>
            <div class="px-6 pb-6 md:px-8 md:pb-8">
              <div class="h-px bg-stroke-outlineVariant mb-6"></div>

              <!-- For whom -->
              <p class="text-label-medium text-ink-muted mb-3">
                {t['services.label.forwhom']}
              </p>
              <div class="bg-surface-soft rounded-sm overflow-hidden mb-6 flex">
                <div class:list={["w-1 flex-shrink-0", service.colorDot]}></div>
                <div class="p-4 space-y-2">
                  {service.forwhom.map((item) => (
                    <div class="flex gap-2 items-start">
                      <Icon name="arrow_right_alt" class:list={["w-4 h-4 flex-shrink-0 mt-0.5", service.colorText]} />
                      <p class="text-body-medium text-ink-muted leading-relaxed">{item}</p>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Process / Timeline -->
              <p class="text-label-medium text-ink-muted mb-3">
                {t['services.label.process']}
              </p>
              <div class="mb-6">
                {service.timeline.map((step, stepIdx) => (
                  <div class="flex gap-4">
                    <div class="flex flex-col items-center flex-shrink-0">
                      <div class:list={["w-1.5 h-1.5 rounded-full mt-1.5 flex-shrink-0", service.colorDot]}></div>
                      {stepIdx < service.timeline.length - 1 && (
                        <div class="w-px bg-stroke-outlineVariant flex-1 my-1"></div>
                      )}
                    </div>
                    <div class="pb-4">
                      <div class="flex gap-3 items-baseline mb-0.5">
                        <span class="text-body-medium text-ink-muted/60 tracking-wider">{step.phase}</span>
                        <span class="text-body-medium text-ink-muted font-medium">{step.title}</span>
                      </div>
                      <p class="text-body-small text-ink-muted/70 italic mb-2">{step.outcome}</p>
                      {step.items.map((item) => (
                        <div class="flex gap-1.5 items-start mb-0.5">
                          <Icon name="navigate_next" class="w-3.5 h-3.5 flex-shrink-0 mt-0.5 text-ink-muted/40" />
                          <span class="text-body-small text-ink-muted/80">{item}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>

              <!-- Bento grid: delivers + excludes -->
              <div class="grid grid-cols-1 gap-3 mb-6">
                <div class="border border-stroke-outlineVariant rounded-sm p-4">
                  <p class="text-label-medium text-ink-muted/50 mb-3">
                    {t['services.label.excludes']}
                  </p>
                  {service.excludes.map((item) => (
                    <div class="flex gap-2 items-start mb-2">
                      <Icon name="close" class="w-4 h-4 flex-shrink-0 mt-0.5 text-ink-muted/40" />
                      <span class="text-body-medium text-ink-muted/50">{item}</span>
                    </div>
                  ))}
                </div>
                <div class="bg-surface-soft rounded-sm p-4">
                  <p class:list={["text-label-medium mb-3", service.colorText]}>
                    {t['services.label.delivers']}
                  </p>
                  {service.delivers.map((item) => (
                    <div class="flex gap-2 items-start mb-2">
                      <Icon name="check_circle" class:list={["w-4 h-4 flex-shrink-0 mt-0.5", service.colorText]} />
                      <span class="text-body-medium text-ink-muted">{item}</span>
                    </div>
                  ))}
                </div>
              </div>

              <!-- Objection Q&A -->
              <div class="bg-surface-soft border border-stroke-outlineVariant rounded-sm p-4 mb-6">
                <p class="text-label-medium text-ink-muted/50 mb-2">{service.objectionQ}</p>
                <p class="text-body-medium text-ink-muted leading-relaxed">{service.objectionA}</p>
              </div>

              <!-- CTA row -->
              <div class="text-center">
                <a
                  href={EXTERNAL.calendly}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-1.5 text-title-medium text-brand-primary/70 rounded-full px-4 py-2 hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard"
                  aria-label={`${t['hero.cta']} – ${service.title}`}
                >
                  {t['hero.cta']}
                  <Icon name="arrow_outward" class="w-4 h-4" />
                </a>
                {(service.key === 'sparring' ? t['services.cta.note.sparring'] : t['services.cta.note']) && (
                  <p class="text-body-small text-ink-muted/50 mt-2">
                    {service.key === 'sparring' ? t['services.cta.note.sparring'] : t['services.cta.note']}
                  </p>
                )}
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .card-body {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms cubic-bezier(0.05, 0.7, 0.1, 1);
  }

  .card.open .card-body {
    max-height: 2400px;
  }

  .toggle-icon {
    transform: rotate(90deg);
    transition: transform 300ms cubic-bezier(0.2, 0, 0, 1);
  }

  .card.open .toggle-icon {
    transform: rotate(180deg);
  }
</style>

<script>
  function initServiceCards() {
    const allCards = document.querySelectorAll<HTMLElement>('[data-service-card]');
    if (!allCards.length) return;

    // Calculate and lock closed height once
    let closedHeight = 0;
    allCards.forEach((c) => { closedHeight = Math.max(closedHeight, c.offsetHeight); });
    allCards.forEach((c) => c.style.minHeight = closedHeight + 'px');

    allCards.forEach((card) => {
      if (card.hasAttribute('data-initialized')) return;
      card.setAttribute('data-initialized', '');

      const toggle = (e: Event) => {
        e.stopPropagation();
        const target = e.target as HTMLElement;
        if (target.closest('a')) return;
        const isOpen = card.classList.contains('open');
        allCards.forEach((c) => { c.classList.remove('open'); c.setAttribute('aria-expanded', 'false'); });
        if (!isOpen) { card.classList.add('open'); card.setAttribute('aria-expanded', 'true'); }
      };
      card.addEventListener('click', toggle);
      card.addEventListener('keydown', (e: KeyboardEvent) => {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); toggle(e); }
      });
    });
  }

  initServiceCards();
  document.addEventListener('astro:page-load', initServiceCards);
</script>
