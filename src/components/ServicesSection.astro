---
import Icon from '@/components/shared/Icon.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { localizedRoutes } from '@/configurations/routes';

interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const routes = localizedRoutes(lang);

const services = [
  { key: 'diagnosis', icon: 'search', href: routes.diagnosis, iconBg: 'bg-brand-primary/10', iconText: 'text-brand-primary' },
  { key: 'design', icon: 'group_work', href: routes.design, iconBg: 'bg-brand-secondary/10', iconText: 'text-brand-secondary' },
  { key: 'advisory', icon: 'handshake', href: routes.advisory, iconBg: 'bg-brand-tertiary/10', iconText: 'text-brand-tertiary' },
];
---

<section id="services" class="py-20 md:py-24" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-6 md:mb-8">
      <h2 id="services-heading" class="text-headline-large md:text-display-small text-ink-primary">{t['services.heading']}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {services.map((service) => {
        const deliverable = t[`services.${service.key}.deliverable`];
        const hasDeliverable = deliverable && deliverable !== `services.${service.key}.deliverable`;
        return (
          <a href={service.href} class="flex flex-col rounded-md border border-stroke-outlineVariant bg-surface-raised p-6 md:p-8 transition-all duration-medium2 ease-standard hover:bg-ink-primary/[0.08] cursor-pointer no-underline">
            <div class:list={["w-10 h-10 rounded-full flex items-center justify-center mb-4", service.iconBg]}>
              <Icon name={service.icon} class:list={["w-6 h-6", service.iconText]} />
            </div>
            <h3 class="text-title-large text-ink-primary mb-1">{t[`services.${service.key}.title`]}</h3>
            <p class:list={["text-body-medium mb-4", service.iconText]}>{t[`services.${service.key}.subtitle`]}</p>
            <p class="text-body-medium text-ink-muted mb-4 flex-1">{t[`services.${service.key}.description`]}</p>
            {hasDeliverable && (
              <div class="rounded-md bg-brand-primary/[0.08] p-4 mb-4 min-h-[96px]">
                <p class="text-body-medium text-ink-primary">{deliverable}</p>
              </div>
            )}
            <div class="pt-4 border-t border-stroke-subtle flex justify-between items-baseline">
              <span class="text-body-small text-ink-muted">{t[`services.${service.key}.duration`]}</span>
              <span class:list={["text-title-medium", service.iconText]}>{t[`services.${service.key}.price`]}</span>
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
