---
import Icon from '@/components/shared/Icon.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { localizedRoutes } from '@/configurations/routes';

interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
const lang = getLangFromUrl(Astro.url);
const routes = localizedRoutes(lang);

const services = [
  { key: 'diagnosis', icon: 'search', href: routes.diagnosis, iconBg: 'bg-brand-primary/10', iconText: 'text-brand-primary', accentBg: 'bg-brand-primary', deliverableBg: 'bg-brand-primary/[0.08]' },
  { key: 'guidance', icon: 'group_work', href: routes.design, iconBg: 'bg-brand-secondary/10', iconText: 'text-brand-secondary', accentBg: 'bg-brand-secondary', deliverableBg: 'bg-brand-secondary/[0.08]' },
  { key: 'sparring', icon: 'handshake', href: routes.advisory, iconBg: 'bg-brand-tertiary/10', iconText: 'text-brand-tertiary', accentBg: 'bg-brand-tertiary', deliverableBg: 'bg-brand-tertiary/[0.08]' },
];
---

<section id="services" class="py-20 md:py-24" aria-labelledby="services-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="text-center mb-12 md:mb-16">
      <h2 id="services-heading" class="text-headline-large md:text-display-small text-ink-primary">{t['services.heading']}</h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      {services.map((service) => {
        const deliverable = t[`services.${service.key}.deliverable`];
        const hasDeliverable = deliverable && deliverable !== `services.${service.key}.deliverable`;
        return (
          <a href={service.href} class="flex flex-col rounded-md border border-stroke-outlineVariant bg-surface-raised overflow-hidden transition-all duration-medium2 ease-standard hover:shadow-elevation-2 hover:-translate-y-0.5 cursor-pointer no-underline">
            <div class:list={["h-1.5 w-full", service.accentBg]} />
            <div class="flex flex-col p-8 md:p-10">
            <div class:list={["w-12 h-12 rounded-full flex items-center justify-center mb-8", service.iconBg]}>
              <Icon name={service.icon} class:list={["w-7 h-7", service.iconText]} />
            </div>
            <h3 class="text-title-large text-ink-primary mb-3">{t[`services.${service.key}.title`]}</h3>
            <p class:list={["text-body-medium mb-8", service.iconText]}>{t[`services.${service.key}.subtitle`]}</p>
            <p class="text-body-medium text-ink-muted mb-8 flex-1">{t[`services.${service.key}.description`]}</p>
            {hasDeliverable && (
              <div class:list={["rounded-md p-5 min-h-[96px]", service.deliverableBg]}>
                <p class="text-body-medium text-ink-primary">{deliverable}</p>
              </div>
            )}
            </div>
          </a>
        );
      })}
    </div>
  </div>
</section>
