---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;

const facets = [
  {
    name: t['principle.facet.1.name'],
    statement: t['principle.facet.1.statement'],
    rationale: t['principle.facet.1.rationale'],
  },
  {
    name: t['principle.facet.2.name'],
    statement: t['principle.facet.2.statement'],
    rationale: t['principle.facet.2.rationale'],
  },
  {
    name: t['principle.facet.3.name'],
    statement: t['principle.facet.3.statement'],
    rationale: t['principle.facet.3.rationale'],
  },
];
---

<section id="principle" class="py-20 md:py-24" aria-labelledby="principle-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-3xl">
      <h2 id="principle-heading" data-speakable class="text-headline-large md:text-display-small text-ink-primary mb-2">
        {t['principle.heading']}
      </h2>
      <p class="text-title-medium text-brand-primary/70 font-medium mb-8">{t['principle.subtitle']}</p>

      <div class="space-y-5 text-body-large text-ink-muted leading-relaxed">
        <p>{t['principle.para.1']}</p>
        <p data-speakable>{t['principle.para.2']}</p>
        <p data-speakable>{t['principle.para.3']}</p>
        <p>{t['principle.para.4']}</p>
      </div>
    </div>

    <div class="mt-12 md:mt-16 grid grid-cols-1 md:grid-cols-3 gap-6">
      {facets.map((facet, i) => (
        <article class="rounded-lg border border-stroke-outlineVariant bg-surface-raised p-6 md:p-8 flex flex-col">
          <span class="text-label-medium text-brand-primary/60 tracking-wider">{String(i + 1).padStart(2, '0')}</span>
          <h3 class="text-title-large text-ink-primary mt-2 mb-4">{facet.name}</h3>
          <p data-speakable class="text-body-large text-ink-primary leading-relaxed mb-4">{facet.statement}</p>
          <p class="text-body-medium text-ink-muted leading-relaxed">{facet.rationale}</p>
        </article>
      ))}
    </div>
  </div>
</section>
