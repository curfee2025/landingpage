---
import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section id="principle" class="py-20 md:py-24" aria-labelledby="principle-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-3xl">
      <h2 id="principle-heading" data-speakable class="text-headline-large md:text-display-small text-ink-primary mb-2">
        {t['principle.heading']}
      </h2>
      <p class="text-title-medium text-brand-primary/70 font-medium mb-8">{t['principle.subtitle']}</p>

      <div class="space-y-5 text-body-large text-ink-muted leading-relaxed">
        <p>{t['principle.para.1']}</p>
        <p data-speakable>{t['principle.para.2']}</p>
        <p data-speakable>{t['principle.para.3']}</p>
        <p>{t['principle.para.4']}</p>
      </div>
    </div>
  </div>
</section>
