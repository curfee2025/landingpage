---
import Icon from '@/components/shared/Icon.astro';
import Layout from '@/layouts/Layout.astro';

interface Props {
  icon: string;
  title: string;
  subtitle: string;
  introduction: string;
  processHeading: string;
  processSteps: { title: string; description: string }[];
  deliverablesHeading: string;
  deliverables: string[];
  idealHeading: string;
  idealClients: string[];
  differentiatorHeading: string;
  differentiator: string;
  scopeExcludedHeading: string;
  scopeExcluded: string[];
  callToAction: string;
  breadcrumbHome: string;
  lang: 'de' | 'en';
  canonicalPath: string;
  pageTitle: string;
  pageDesc: string;
  ui: {
    nav: { services: string; about: string; faq: string; cta: string };
    serviceNames: { diagnosis: string; guidance: string; sparring: string };
    footer: { notice: string; privacy: string; cookies: string; copyright: string };
    consent: { message: string; learnMore: string; accept: string; decline: string };
    meta: { defaultDescription: string; orgDescription: string; jobTitle: string };
  };
}

const {
  icon, title, subtitle, introduction,
  processHeading, processSteps,
  deliverablesHeading, deliverables,
  idealHeading, idealClients,
  differentiatorHeading, differentiator,
  scopeExcludedHeading, scopeExcluded,
  callToAction, breadcrumbHome,
  lang, canonicalPath, pageTitle, pageDesc, ui,
} = Astro.props;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": `${title} — Curfee`,
    "description": pageDesc,
    "provider": { "@type": "Organization", "name": "Curfee", "url": "https://curfee.com" },
    "areaServed": "AT",
    "url": `https://curfee.com${canonicalPath}`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": breadcrumbHome, "item": `https://curfee.com${lang === 'en' ? '/en/' : '/'}` },
      { "@type": "ListItem", "position": 2, "name": title, "item": `https://curfee.com${canonicalPath}` }
    ]
  }
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  lang={lang}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  ui={ui}
  dateModified="2026-03-30"
>
  <div class="max-w-3xl mx-auto px-6">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name={icon} class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{title}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-8">{subtitle}</p>
    <p class="text-body-large text-ink-muted leading-relaxed mb-16">{introduction}</p>

    {idealClients.length > 0 && (
      <h2 class="text-headline-small text-ink-primary mb-8">{idealHeading}</h2>
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 mb-16">
        <ul class="space-y-4">
          {idealClients.map(item => (
            <li class="flex items-center gap-3">
              <Icon name="check_circle" class="w-5 h-5 text-brand-primary flex-shrink-0" />
              <span class="text-body-large text-ink-primary">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <h2 class="text-headline-small text-ink-primary mb-8">{processHeading}</h2>
    <div class="relative pl-12 mb-16">
      {processSteps.map((step, i) => (
        <div class={i < processSteps.length - 1 ? 'relative pb-10' : 'relative'}>
          {i < processSteps.length - 1 && (
            <div class="absolute -left-8 top-8 bottom-0 w-0.5 bg-brand-primary/[0.12]" aria-hidden="true"></div>
          )}
          <div class="absolute -left-12 top-0 w-8 h-8 rounded-full border-2 border-brand-primary bg-brand-primary/[0.08] flex items-center justify-center text-label-large text-brand-primary z-10">
            {i + 1}
          </div>
          <h3 class="text-title-medium text-ink-primary mb-1">{step.title}</h3>
          <p class="text-body-medium text-ink-muted">{step.description}</p>
        </div>
      ))}
    </div>

    {differentiator && (
      <h2 class="text-headline-small text-ink-primary mb-8">{differentiatorHeading}</h2>
      <p class="text-body-large text-ink-muted leading-relaxed mb-16">{differentiator}</p>
    )}

    {scopeExcluded.length > 0 && (
      <h2 class="text-headline-small text-ink-primary mb-8">{scopeExcludedHeading}</h2>
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 mb-16">
        <ul class="space-y-3">
          {scopeExcluded.map(item => (
            <li class="flex items-center gap-3">
              <Icon name="close" class="w-5 h-5 text-ink-muted flex-shrink-0" />
              <span class="text-body-medium text-ink-muted">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <h2 class="text-headline-small text-ink-primary mb-8">{deliverablesHeading}</h2>
    <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 mb-16">
      <ul class="space-y-3">
        {deliverables.map(item => (
          <li class="flex items-center gap-3">
            <Icon name="arrow_right_alt" class="w-5 h-5 text-brand-primary flex-shrink-0" />
            <span class="text-body-medium text-ink-primary">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="text-center pb-16">
      <a
        href="mailto:office@curfee.com"
        class="inline-flex items-center gap-2 text-title-large text-brand-primary rounded-full px-6 py-3 hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard"
      >
        {callToAction}
        <Icon name="arrow_outward" class="w-6 h-6" />
      </a>
    </div>
  </div>
</Layout>
