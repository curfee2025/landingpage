---
import Icon from '@/components/shared/Icon.astro';
import Layout from '@/layouts/Layout.astro';
import type { Lang } from '@/configurations/i18n';

import type { Translations } from '@/i18n/translations';

interface Props {
  serviceKey: string;
  icon: string;
  translations: Translations;
  lang: Lang;
  canonicalPath: string;
  pageTitle: string;
  pageDesc: string;
}

const { serviceKey, icon, translations: t, lang, canonicalPath, pageTitle, pageDesc } = Astro.props;
const key = serviceKey;

// Dynamic key lookup for computed keys based on serviceKey
const d = (k: string) => (t as Record<string, string>)[k] ?? k;

const processSteps: { title: string; description: string }[] = [];
for (let i = 1; i <= 10; i++) {
  const title = d(`services.${key}.process.${i}.title`);
  if (!title || title === `services.${key}.process.${i}.title`) break;
  processSteps.push({
    title,
    description: d(`services.${key}.process.${i}.description`),
  });
}

const deliverables: string[] = [];
for (let i = 1; i <= 10; i++) {
  const val = d(`services.${key}.deliverable.${i}`);
  if (val && val !== `services.${key}.deliverable.${i}`) deliverables.push(val);
  else break;
}

const idealClients: string[] = [];
for (let i = 1; i <= 10; i++) {
  const val = d(`services.${key}.ideal.${i}`);
  if (val && val !== `services.${key}.ideal.${i}`) idealClients.push(val);
  else break;
}

const scopeExcluded: string[] = [];
for (let i = 1; i <= 10; i++) {
  const val = d(`services.${key}.scope.excluded.${i}`);
  if (val && val !== `services.${key}.scope.excluded.${i}`) scopeExcluded.push(val);
  else break;
}

const differentiator = d(`services.${key}.differentiator`);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": `${d(`services.${key}.title`)} — Curfee`,
    "description": pageDesc,
    "provider": {
      "@type": "Organization",
      "name": "Curfee",
      "url": "https://curfee.com"
    },
    "areaServed": "AT",
    "url": `https://curfee.com${canonicalPath}`,
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": `https://curfee.com${lang === 'en' ? '/en/' : '/'}` },
      { "@type": "ListItem", "position": 2, "name": d(`services.${key}.title`), "item": `https://curfee.com${canonicalPath}` }
    ]
  }
];
---

<Layout
  title={pageTitle}
  description={pageDesc}
  lang={lang}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  dateModified="2026-03-30"
>
  <div class="max-w-3xl mx-auto px-6">
    <!-- Hero -->
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name={icon} class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{d(`services.${key}.title`)}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-8">{d(`services.${key}.subtitle`)}</p>
    <p class="text-body-large text-ink-muted leading-relaxed mb-16">{d(`services.${key}.introduction`)}</p>

    <!-- Who this is for -->
    {idealClients.length > 0 && (
      <h2 class="text-headline-small text-ink-primary mb-8">{t['services.ideal.heading']}</h2>
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 mb-16">
        <ul class="space-y-4">
          {idealClients.map(item => (
            <li class="flex items-center gap-3">
              <Icon name="check_circle" class="w-5 h-5 text-brand-primary flex-shrink-0" />
              <span class="text-body-large text-ink-primary">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- Process -->
    <h2 class="text-headline-small text-ink-primary mb-8">{t['services.process.heading']}</h2>
    <div class="relative pl-12 mb-16">
      {processSteps.map((step, i) => (
        <div class={`relative ${i < processSteps.length - 1 ? 'pb-10' : ''}`}>
          {i < processSteps.length - 1 && (
            <div class="absolute -left-8 top-8 bottom-0 w-0.5 bg-brand-primary/[0.12]" aria-hidden="true"></div>
          )}
          <div class="absolute -left-12 top-0 w-8 h-8 rounded-full border-2 border-brand-primary bg-brand-primary/[0.08] flex items-center justify-center text-label-large text-brand-primary z-10">
            {i + 1}
          </div>
          <h3 class="text-title-medium text-ink-primary mb-1">{step.title}</h3>
          <p class="text-body-medium text-ink-muted">{step.description}</p>
        </div>
      ))}
    </div>

    <!-- The standard -->
    {differentiator && differentiator !== `services.${key}.differentiator` && (
      <h2 class="text-headline-small text-ink-primary mb-8">{t['services.differentiator.heading']}</h2>
      <p class="text-body-large text-ink-muted leading-relaxed mb-16">{differentiator}</p>
    )}

    <!-- Not included -->
    {scopeExcluded.length > 0 && (
      <h2 class="text-headline-small text-ink-primary mb-8">{t['services.scope.excluded']}</h2>
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 mb-16">
        <ul class="space-y-3">
          {scopeExcluded.map(item => (
            <li class="flex items-center gap-3">
              <Icon name="close" class="w-5 h-5 text-ink-muted flex-shrink-0" />
              <span class="text-body-medium text-ink-muted">{item}</span>
            </li>
          ))}
        </ul>
      </div>
    )}

    <!-- What you get -->
    <h2 class="text-headline-small text-ink-primary mb-8">{t['services.deliverables.heading']}</h2>
    <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 mb-16">
      <ul class="space-y-3">
        {deliverables.map(item => (
          <li class="flex items-center gap-3">
            <Icon name="arrow_right_alt" class="w-5 h-5 text-brand-primary flex-shrink-0" />
            <span class="text-body-medium text-ink-primary">{item}</span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Call to Action -->
    <div class="text-center pb-16">
      <a
        href={`mailto:office@curfee.com`}
        class="inline-flex items-center gap-2 text-title-large text-brand-primary rounded-full px-6 py-3 hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard"
      >
        {t['services.calltoaction']}
        <Icon name="arrow_outward" class="w-6 h-6" />
      </a>
    </div>
  </div>
</Layout>
