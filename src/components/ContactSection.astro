---
import ContactButton from '@/components/shared/ContactButton.astro';

import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section id="contact" class="py-20 md:py-28" style="background: linear-gradient(to bottom, rgb(var(--brand-primary) / 0) 0%, rgb(var(--brand-primary) / 0.10) 15%, rgb(var(--brand-primary) / 0.10) 100%);" aria-labelledby="contact-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
  <div class="text-center max-w-3xl mx-auto">
    <h2 id="contact-heading" class="text-headline-large md:text-display-small text-ink-primary mb-2">
      {t['calltoaction.heading']}
    </h2>
    <p class="text-title-medium text-brand-primary font-medium mb-12">{t['calltoaction.subtitle']}</p>
    <ContactButton label={t['hero.cta']} variant="filled" class="mt-12 md:mt-16" />
  </div>
  </div>
</section>
