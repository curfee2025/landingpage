---
import ContactButton from '@/components/shared/ContactButton.astro';

import type { Translations } from '@/i18n/translations';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section id="contact" class="py-20 md:py-28" aria-labelledby="contact-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
  <div class="text-center max-w-3xl mx-auto">
    <h2 id="contact-heading" class="text-headline-large md:text-display-small text-ink-primary mb-2">
      {t['calltoaction.heading']}
    </h2>
    <p class="text-title-medium text-brand-primary/70 font-medium mb-12">{t['calltoaction.subtitle']}</p>
    <ContactButton label={t['calltoaction.button']} variant="outlined" class="mt-12 md:mt-16" />
  </div>
  </div>
</section>
