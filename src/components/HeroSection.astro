---
import type { Translations } from '@/i18n/translations';
import { EXTERNAL } from '@/configurations/routes';
import logoIconRaw from '@/assets/logos/logo_icon.svg?raw';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section class="relative py-24 md:py-32 lg:py-40" aria-labelledby="hero-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto text-center">
      <div class="flex justify-center mb-12">
        <span class="h-28 md:h-36 lg:h-44 text-brand-primary [&>svg]:h-full [&>svg]:w-auto" set:html={logoIconRaw} />
      </div>

      <h1 id="hero-heading" class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-tight tracking-tight">
        {t['hero.heading']}
      </h1>

      <p class="text-body-large md:text-title-medium text-ink-muted mt-6 max-w-2xl mx-auto leading-relaxed">
        {t['hero.subtitle']}
      </p>

      <div class="flex flex-wrap justify-center gap-2 mt-10">
        <span class="text-label-large text-brand-primary/70 bg-brand-primary/[0.06] px-4 py-1.5 rounded-full">{t['hero.badge.1']}</span>
        <span class="text-label-large text-brand-primary/70 bg-brand-primary/[0.06] px-4 py-1.5 rounded-full">{t['hero.badge.2']}</span>
        <span class="text-label-large text-brand-primary/70 bg-brand-primary/[0.06] px-4 py-1.5 rounded-full">{t['hero.badge.3']}</span>
      </div>

      <div class="mt-10">
        <a
          href={EXTERNAL.email}
          class="inline-flex items-center justify-center gap-2 bg-brand-primary text-brand-onPrimary px-8 py-4 rounded-full text-label-large font-medium shadow-elevation-0 hover:shadow-elevation-1 active:shadow-elevation-0 hover:-translate-y-0.5 transition-all duration-medium2 ease-standard"
        >
          {t['hero.cta']}
        </a>
      </div>
    </div>
  </div>
</section>
