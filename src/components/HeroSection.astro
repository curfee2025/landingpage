---
import type { Translations } from '@/i18n/translations';
import ContactButton from '@/components/shared/ContactButton.astro';

interface Props {
  translations: Translations;
}
const { translations: t } = Astro.props;
---

<section class="relative min-h-[100dvh] flex items-center py-20" aria-labelledby="hero-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto text-center">

      <h1
        id="hero-heading"
        data-speakable
        class="text-display-small md:text-display-medium lg:text-display-large text-ink-primary leading-[1.05] tracking-tight font-semibold"
      >
        {t['hero.heading']}
      </h1>

      <p
        data-speakable
        class="text-body-large text-ink-muted/70 mt-10 max-w-xl mx-auto leading-relaxed"
      >
        {t['hero.subtitle']}
      </p>

      <div class="mt-16">
        <ContactButton label={t['hero.cta']} variant="filled" />
      </div>

    </div>
  </div>
</section>
