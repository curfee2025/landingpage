---
interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section class="min-h-[72vh] flex flex-col items-center justify-center text-center py-12" aria-labelledby="hero-heading">
  <h1 id="hero-heading" class="text-display-small md:text-display-large text-ink-primary max-w-4xl leading-tight">
    {t['hero.heading.start']}{' '}{t['hero.heading.end']}
  </h1>
</section>
