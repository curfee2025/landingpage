---
interface Props {
  heading: string;
  subtitle: string;
  badges: string[];
}
const { heading, subtitle, badges } = Astro.props;
---

<section class="py-16 md:py-24" aria-labelledby="hero-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto text-center">
      <h1 id="hero-heading" class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-tight tracking-tight">
        {heading}
      </h1>
      <p class="text-body-large text-ink-muted mt-6">{subtitle}</p>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        {badges.map(b => (
          <span class="text-label-large text-brand-primary bg-brand-primary/[0.08] px-4 py-2 rounded-full">{b}</span>
        ))}
      </div>
    </div>
  </div>
</section>
