---
import { EXTERNAL } from '@/configurations/routes';
import Icon from '@/components/shared/Icon.astro';

interface Props {
  translations: Record<string, string>;
}
const { translations: t } = Astro.props;
---

<section class="py-16 md:py-24" aria-labelledby="hero-heading">
  <div class="max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto text-center">
      <h1 id="hero-heading" class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-tight tracking-tight">
        {t['hero.heading']}
      </h1>
      <p class="text-body-large text-ink-muted mt-6">{t['hero.subtitle']}</p>
      <div class="flex flex-wrap justify-center gap-3 mt-10">
        <span class="text-label-large text-brand-primary bg-brand-primary/[0.08] px-4 py-2 rounded-full">Software-Architektur</span>
        <span class="text-label-large text-brand-primary bg-brand-primary/[0.08] px-4 py-2 rounded-full">Tool-Landschaft</span>
        <span class="text-label-large text-brand-primary bg-brand-primary/[0.08] px-4 py-2 rounded-full">Organisationsstruktur</span>
      </div>
      <a
        href={EXTERNAL.email}
        class="inline-flex items-center gap-2 bg-brand-primary text-brand-onPrimary px-10 py-4 rounded-full text-body-large font-medium shadow-elevation-1 hover:shadow-elevation-2 active:shadow-elevation-0 transition-all duration-medium2 ease-standard mt-10"
      >
        {t['calltoaction.button']}
        <Icon name="arrow_forward" class="w-5 h-5" />
      </a>
    </div>
  </div>
</section>
