---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import BackToHomeSection from '@/components/shared/BackToHomeSection.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();
const linkClass = "text-brand-primary hover:underline transition-colors duration-short4 ease-standard";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.privacy'], "item": "https://curfee.com/privacy/" }
  ]
};
---

<Layout
  title={t['meta.privacy.title']}
  description={t['meta.privacy.description']}
  canonicalPath="/privacy/"
  jsonLd={jsonLd}
  dateModified="2026-03-30"
  showHeader={false}
>
  <article class="pt-[clamp(4rem,3rem+3vw,7rem)] pb-[clamp(4rem,3rem+3vw,7rem)] max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto">
      <div class="mb-16">
        <div class="w-12 h-12 rounded-full bg-brand-primary/[0.08] flex items-center justify-center mb-6">
          <Icon name="shield" class="w-6 h-6 text-brand-primary" />
        </div>
        <h1 class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">{t['privacy.heading']}</h1>
        <p class="text-title-medium text-brand-primary font-medium">{t['privacy.scope']}</p>
      </div>

      <div class="space-y-12">

        <section class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="rounded-md bg-surface-base shadow-elevation-1 p-6">
            <h2 class="text-label-large text-ink-primary mb-4">{t['privacy.controller.heading']}</h2>
            <div class="text-body-large text-ink-muted">
              <p class="text-title-medium text-ink-primary">{t['imprint.company']}</p>
              <p class="mt-1">{t['imprint.name']}</p>
              <div class="mt-3 leading-snug">
                <p>{t['imprint.address.street']}</p>
                <p>{t['imprint.address.city']}</p>
                <p>{t['imprint.address.country']}</p>
              </div>
            </div>
          </div>
          <div class="rounded-md bg-surface-base shadow-elevation-1 p-6">
            <h2 class="text-label-large text-ink-primary mb-4">{t['imprint.contact']}</h2>
            <div class="space-y-4">
              <div>
                <span class="text-label-large font-medium text-ink-muted">{t['imprint.email.label']}</span>
                <p><a href={`mailto:${t['imprint.email']}`} class={linkClass}>{t['imprint.email']}</a></p>
              </div>
              <div>
                <span class="text-label-large font-medium text-ink-muted">{t['privacy.phone.label']}</span>
                <p><a href={`tel:${t['imprint.phone'].replace(/\s/g, '')}`} class={linkClass}>{t['imprint.phone']}</a></p>
              </div>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.personal.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.personal']}</p>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.rights.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.rights']}</p>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.withdrawal.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.withdrawal']} <a href={`mailto:${t['imprint.email']}`} class={linkClass}>{t['imprint.email']}</a></p>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.complaint.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed mb-4">{t['privacy.complaint']}</p>
          <div class="rounded-md bg-surface-base shadow-elevation-1 p-6 text-body-large text-ink-muted">
            <p class="text-title-medium text-ink-primary">{t['privacy.complaint.authority']}</p>
            <p class="mt-1">{t['privacy.complaint.address.street']}</p>
            <p>{t['privacy.complaint.address.city']}</p>
            <p>{t['privacy.complaint.address.country']}</p>
            <div class="mt-3 space-y-1">
              <p>{t['privacy.phone.label']}: <a href={`tel:${t['privacy.complaint.phone'].replace(/\s/g, '')}`} class={linkClass}>{t['privacy.complaint.phone']}</a></p>
              <p>{t['imprint.email.label']}: <a href={`mailto:${t['privacy.complaint.email']}`} class={linkClass}>{t['privacy.complaint.email']}</a></p>
              <p>Website: <a href={`https://${t['privacy.complaint.website']}`} target="_blank" rel="noopener noreferrer" class={linkClass}>{t['privacy.complaint.website']}</a></p>
            </div>
          </div>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.ssl.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.ssl']}</p>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.links.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.links']}</p>
        </section>

        <section>
          <h2 class="text-headline-small text-ink-primary mb-4">{t['privacy.hosting.heading']}</h2>
          <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.hosting']}</p>
        </section>

      </div>

    </div>
  </article>
  <BackToHomeSection />
</Layout>
