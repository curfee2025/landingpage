---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.notice'], "item": "https://curfee.com/imprint" }
  ]
};
---

<Layout
  title={t['meta.imprint.title']}
  description={t['meta.imprint.description']}
  lang={lang}
  canonicalPath="/imprint"
  jsonLd={jsonLd}
  dateModified="2026-03-30"
>
  <div class="max-w-3xl mx-auto px-6">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name="gavel" class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{t['imprint.heading']}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-8">{t['imprint.legal.basis']}</p>

    <!-- Identity + Contact grouped -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
        <h2 class="text-label-large text-ink-primary mb-4">{t['imprint.owner']}</h2>
        <div class="text-body-large text-ink-muted">
          <p class="text-title-medium text-ink-primary">{t['imprint.company']}</p>
          <p class="mt-1">{t['imprint.name']}</p>
          <div class="mt-3 leading-snug">
            <p>{t['imprint.address.street']}</p>
            <p>{t['imprint.address.city']}</p>
            <p>{t['imprint.address.country']}</p>
          </div>
        </div>
      </div>
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
        <h2 class="text-label-large text-ink-primary mb-4">{t['imprint.contact']}</h2>
        <div class="space-y-4">
          <div>
            <span class="text-label-large font-medium text-ink-muted">{t['imprint.email.label']}</span>
            <p><a href={`mailto:${t['imprint.email']}`} class="text-body-large text-brand-primary hover:underline transition-colors duration-short4 ease-standard">{t['imprint.email']}</a></p>
          </div>
          <div>
            <span class="text-label-large font-medium text-ink-muted">{t['imprint.phone.label']}</span>
            <p><a href={`tel:${t['imprint.phone'].replace(/\s/g, '')}`} class="text-body-large text-brand-primary hover:underline transition-colors duration-short4 ease-standard">{t['imprint.phone']}</a></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Legal basis as structured list -->
    <section class="mb-10">
      <h2 class="text-headline-small text-ink-primary mb-8">{t['imprint.legal.heading']}</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
        <div>
          <span class="text-label-medium font-medium text-ink-muted">{t['imprint.trade.label']}</span>
          <p class="text-body-large text-ink-primary mt-1">{t['imprint.trade']}</p>
        </div>
        <div>
          <span class="text-label-medium font-medium text-ink-muted">{t['imprint.form.label']}</span>
          <p class="text-body-large text-ink-primary mt-1">{t['imprint.form']}</p>
        </div>
        <div>
          <span class="text-label-medium font-medium text-ink-muted">{t['imprint.authority.label']}</span>
          <p class="text-body-large text-ink-primary mt-1">{t['imprint.authority']}</p>
        </div>
        <div>
          <span class="text-label-medium font-medium text-ink-muted">{t['imprint.gisa.label']}</span>
          <p class="text-body-large text-ink-primary mt-1">{t['imprint.gisa']}</p>
        </div>
        <div>
          <span class="text-label-medium font-medium text-ink-muted">{t['imprint.law.label']}</span>
          <p class="text-body-large text-ink-primary mt-1">{t['imprint.law']}</p>
          <a href="https://www.ris.bka.gv.at" target="_blank" rel="noopener noreferrer" class="text-body-small text-brand-primary hover:underline transition-colors duration-short4 ease-standard">{t['imprint.lawlink']}</a>
        </div>
        <div>
          <span class="text-label-medium font-medium text-ink-muted">{t['imprint.wko.label']}</span>
          <p class="text-body-large text-ink-primary mt-1">{t['imprint.wko']}</p>
        </div>
      </div>
    </section>

    <!-- Editorial -->
    <section class="mb-10">
      <h2 class="text-headline-small text-ink-primary mb-8">{t['imprint.editorial.heading']}</h2>
      <p class="text-body-large text-ink-muted leading-relaxed mb-2">{t['imprint.editorial']}</p>
      <p class="text-body-large text-ink-primary">{t['imprint.editorial.responsible']}</p>
    </section>

    <!-- Liability + Copyright as minimal text blocks -->
    <div class="space-y-10 mb-10">
      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['imprint.liability.content.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['imprint.liability.content']}</p>
      </section>
      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['imprint.liability.links.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['imprint.liability.links']}</p>
      </section>
      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['imprint.copyright.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['imprint.copyright']}</p>
      </section>
    </div>
  </div>
</Layout>
