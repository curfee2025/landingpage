---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ObservationsSection from '@/components/ObservationsSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import AboutSection from '@/components/AboutSection.astro';
import CaseStudySection from '@/components/CaseStudySection.astro';
import FaqSection from '@/components/FaqSection.astro';
import BlogSection from '@/components/BlogSection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const t = getTranslations();

const webSiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://curfee.com/#website",
  "name": "Curfee",
  "alternateName": "Curfee – Systems, Software & Infrastructure Architecture Consulting",
  "url": "https://curfee.com",
  "description": t['meta.home.jsonld.description'],
  "inLanguage": "en",
  "publisher": { "@id": "https://curfee.com/#organization" },
  "about": { "@id": "https://curfee.com/#organization" },
  "mainEntity": { "@id": "https://curfee.com/#organization" },
  "potentialAction": {
    "@type": "CommunicateAction",
    "target": "mailto:office@curfee.com",
    "name": "Contact by email"
  }
};

const faqEntries = [
  { id: "https://curfee.com/#faq-1", name: t['faq.1.question'], text: t['faq.1.answer'] },
  { id: "https://curfee.com/#faq-nontech", name: t['faq.nontech.question'], text: t['faq.nontech.answer'] },
  { id: "https://curfee.com/#faq-2", name: t['faq.2.question'], text: t['faq.2.answer'] },
  { id: "https://curfee.com/#faq-4", name: t['faq.4.question'], text: t['faq.4.answer'] },
  { id: "https://curfee.com/#faq-keep", name: t['faq.keep.question'], text: t['faq.keep.answer'] },
  { id: "https://curfee.com/#faq-patterns-structural", name: t['faq.patterns.structural.question'], text: t['faq.patterns.structural.answer'] },
  { id: "https://curfee.com/#faq-patterns-operational", name: t['faq.patterns.operational.question'], text: t['faq.patterns.operational.answer'] },
  { id: "https://curfee.com/#faq-decisions", name: t['faq.decisions.question'], text: t['faq.decisions.answer'] },
  { id: "https://curfee.com/#faq-enforcement", name: t['faq.enforcement.question'], text: t['faq.enforcement.answer'] },
  { id: "https://curfee.com/#faq-ai", name: t['faq.ai.question'], text: t['faq.ai.answer'] },
  { id: "https://curfee.com/#faq-cultural", name: t['faq.cultural.question'], text: t['faq.cultural.answer'] },
  { id: "https://curfee.com/#faq-5", name: t['faq.5.question'], text: t['faq.5.answer'] },
  { id: "https://curfee.com/#faq-international", name: t['faq.international.question'], text: t['faq.international.answer'] },
  { id: "https://curfee.com/#faq-6", name: t['faq.6.question'], text: t['faq.6.answer'] },
];
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://curfee.com/#faq",
  "inLanguage": "en",
  "about": { "@id": "https://curfee.com/#organization" },
  "author": { "@id": "https://curfee.com/#founder" },
  "publisher": { "@id": "https://curfee.com/#organization" },
  "dateModified": "2026-04-17",
  "mainEntity": faqEntries.map((q) => ({
    "@type": "Question",
    "@id": q.id,
    "name": q.name,
    "author": { "@id": "https://curfee.com/#founder" },
    "acceptedAnswer": {
      "@type": "Answer",
      "author": { "@id": "https://curfee.com/#founder" },
      "text": q.text
    }
  }))
};

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://curfee.com/#services",
  "name": "Systems, Software & Infrastructure Architecture Consulting",
  "alternateName": "Systems-, Software- und Infrastrukturarchitektur-Beratung",
  "provider": { "@id": "https://curfee.com/#organization" },
  "serviceType": "Systems, Software & Infrastructure Architecture Consulting",
  "category": ["IT Consulting", "Management Consulting", "Systems Architecture", "Software Architecture", "Infrastructure Architecture"],
  "areaServed": [
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "audience": {
    "@type": "BusinessAudience",
    "name": "CTOs, engineering managers, team leads, founders",
    "audienceType": "Decision-makers in companies with grown system landscapes"
  },
  "serviceOutput": "Root cause analysis, architectural standards enforced by the system through pipelines and tooling, governance frameworks, implementation guidance",
  "availableLanguage": ["en"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "@id": "https://curfee.com/#offer-catalog",
    "name": t['services.heading'],
    "itemListElement": [
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-diagnosis",
        "category": "Entry engagement",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "EUR",
          "description": "Price on application"
        },
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 2, "unitCode": "WEE" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#diagnosis",
          "name": t['services.diagnosis.title'],
          "alternateName": ["Diagnosis", "Diagnose"],
          "description": t['services.diagnosis.problem'],
          "slogan": t['services.diagnosis.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "System Diagnosis",
          "inLanguage": ["en"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-guidance",
        "category": "Project engagement",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "EUR",
          "description": "Price on application"
        },
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 3, "unitCode": "MON" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#guidance",
          "name": t['services.guidance.title'],
          "alternateName": ["Guidance", "Begleitung"],
          "description": t['services.guidance.problem'],
          "slogan": t['services.guidance.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architecture Guidance",
          "inLanguage": ["en"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-sparring",
        "category": "Retainer engagement",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "EUR",
          "description": "Ongoing retainer, price on application"
        },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#sparring",
          "name": t['services.sparring.title'],
          "alternateName": ["Sparring", "Architekt-Sparring"],
          "description": t['services.sparring.problem'],
          "slogan": t['services.sparring.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architecture Sparring",
          "inLanguage": ["en"]
        }
      },
    ]
  }
};

const aboutPageLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://curfee.com/#about",
  "url": "https://curfee.com/#about",
  "mainEntity": { "@id": "https://curfee.com/#founder" },
  "isPartOf": { "@id": "https://curfee.com/#website" },
  "inLanguage": "en"
};

const decisionEnforcementLd = {
  "@context": "https://schema.org",
  "@type": "DefinedTerm",
  "@id": "https://curfee.com/#decision-enforcement-principle",
  "name": "Decision Enforcement Principle",
  "alternateName": ["Decision Enforcement", "Prinzip der Entscheidungsdurchsetzung"],
  "description": "Architectural decisions are enforced by the system itself, through pipelines, automated checks, and tool configuration, rather than by the discipline, memory, or vigilance of individual people. Curfee's core principle.",
  "url": "https://curfee.com/#faq-enforcement",
  "inDefinedTermSet": {
    "@type": "DefinedTermSet",
    "@id": "https://curfee.com/#curfee-glossary",
    "name": "Curfee glossary"
  },
  "subjectOf": { "@id": "https://curfee.com/#organization" },
  "author": { "@id": "https://curfee.com/#founder" }
};

const jsonLd = [webSiteLd, faqLd, serviceLd, aboutPageLd, decisionEnforcementLd];
---

<Layout
  title={t['meta.home.title']}
  description={t['meta.home.description']}
  canonicalPath="/"
  jsonLd={jsonLd}
  dateModified="2026-04-17"
>
  <HeroSection translations={t} />
  <ObservationsSection translations={t} />
  <ServicesSection translations={t} />
  <AboutSection translations={t} />
  <CaseStudySection translations={t} />
  <BlogSection translations={t} />
  <FaqSection translations={t} />
  <ContactSection translations={t} />
</Layout>
