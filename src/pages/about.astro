---
import Layout from '@/layouts/Layout.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://curfee.com/#founder",
    "name": "Philipp Höllinger",
    "jobTitle": t['meta.about.jobTitle'],
    "url": "https://curfee.com/about",
    "worksFor": { "@id": "https://curfee.com/#organization" },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Salzburg",
      "addressCountry": "AT"
    },
    "sameAs": ["https://www.linkedin.com/in/phoellinger"]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
      { "@type": "ListItem", "position": 2, "name": t['navigation.about'], "item": "https://curfee.com/about" }
    ]
  }
];
---

<Layout
  title={t['meta.about.title']}
  description={t['meta.about.description']}
  canonicalPath="/about"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-03-30"
>

  <!-- Wer ich bin -->
  <section class="py-20 md:py-28 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <picture><source srcset="/assets/profile.webp" type="image/webp" /><img src="/assets/profile.png" alt="Philipp Höllinger" class="w-[160px] h-[200px] object-cover object-top rounded-md mb-8" loading="lazy" /></picture>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-8">{t['about.who.heading']}</h1>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.who.1']}</p>
      <p>{t['about.who.2']}</p>
      <p>{t['about.who.3']}</p>
      <p>{t['about.who.4']}</p>
    </div>
  </section>

  <!-- Was ich gemacht habe -->
  <section class="py-20 md:py-28 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-8">{t['about.done.heading']}</h2>
    <div class="space-y-10">
      {[
        { heading: t['about.done.example.1.heading'], text: t['about.done.example.1.text'] },
        { heading: t['about.done.example.2.heading'], text: t['about.done.example.2.text'] },
        { heading: t['about.done.example.3.heading'], text: t['about.done.example.3.text'] },
      ].map(ex => (
        <div>
          <h3 class="text-title-large text-ink-primary mb-3">{ex.heading}</h3>
          <p class="text-body-large text-ink-muted leading-relaxed">{ex.text}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- Wofür ich stehe -->
  <section class="py-20 md:py-28 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-8">{t['about.stand.heading']}</h2>
    <div class="space-y-8">
      {[
        { title: t['about.stand.1.title'], description: t['about.stand.1.description'] },
        { title: t['about.stand.2.title'], description: t['about.stand.2.description'] },
        { title: t['about.stand.3.title'], description: t['about.stand.3.description'] },
      ].map((item, i) => (
        <div class="flex items-center gap-6">
          <span class="text-headline-large md:text-display-small text-brand-primary/50 font-display flex-shrink-0 w-10 md:w-14 select-none leading-none">{i + 1}</span>
          <div>
            <h3 class="text-title-large text-ink-primary mb-1">{item.title}</h3>
            <p class="text-body-large text-ink-muted leading-relaxed">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Wie ich arbeite -->
  <section class="py-20 md:py-28 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-8">{t['about.work.heading']}</h2>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.work.1']}</p>
      <p>{t['about.work.2']}</p>
      <p>{t['about.work.3']}</p>
      <p>{t['about.work.4']}</p>
      <p>{t['about.work.5']}</p>
    </div>
  </section>

  <!-- Fünf Prinzipien -->
  <section class="py-20 md:py-28 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-12">{t['principles.heading']}</h2>
    <div class="space-y-8">
      {[
        { title: t['principles.1.title'], description: t['principles.1.description'] },
        { title: t['principles.2.title'], description: t['principles.2.description'] },
        { title: t['principles.3.title'], description: t['principles.3.description'] },
        { title: t['principles.4.title'], description: t['principles.4.description'] },
        { title: t['principles.5.title'], description: t['principles.5.description'] },
      ].map((p, i) => {
        const firstLetter = p.title.charAt(0);
        const rest = p.title.slice(1);
        const isLast = i === 4;
        return (
          <div class="flex items-start gap-6 min-h-[3.5rem]">
            <span class="text-display-small text-brand-primary font-display leading-none w-12 flex-shrink-0 text-center">{isLast ? 'EE' : firstLetter}</span>
            <div>
              <h3 class="text-title-large text-ink-primary mb-1">
                <span class="text-brand-primary">{firstLetter}</span>{rest}
              </h3>
              <p class="text-body-large text-ink-muted">{p.description}</p>
            </div>
          </div>
        );
      })}
    </div>
  </section>

</Layout>
