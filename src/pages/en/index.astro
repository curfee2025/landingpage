---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ObservationsSection from '@/components/ObservationsSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
import CaseStudySection from '@/components/CaseStudySection.astro';
import AboutSection from '@/components/AboutSection.astro';
import FaqSection from '@/components/FaqSection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'en' as const;
const t = getTranslations(lang);

const webSiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Curfee",
  "url": "https://curfee.com",
  "description": t['meta.home.jsonld.description'],
  "inLanguage": "en",
  "availableLanguage": ["de", "en"],
  "publisher": { "@id": "https://curfee.com/#organization" },
  "about": { "@id": "https://curfee.com/#organization" },
  "mainEntity": { "@id": "https://curfee.com/#organization" }
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "https://curfee.com/en/"
    }
  ]
};

const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": t['faq.1.question'], "acceptedAnswer": { "@type": "Answer", "text": t['faq.1.answer'] } },
    { "@type": "Question", "name": t['faq.2.question'], "acceptedAnswer": { "@type": "Answer", "text": t['faq.2.answer'] } },
    { "@type": "Question", "name": t['faq.3.question'], "acceptedAnswer": { "@type": "Answer", "text": t['faq.3.answer'] } },
    { "@type": "Question", "name": t['faq.4.question'], "acceptedAnswer": { "@type": "Answer", "text": t['faq.4.answer'] } },
    { "@type": "Question", "name": t['faq.5.question'], "acceptedAnswer": { "@type": "Answer", "text": t['faq.5.answer'] } },
    { "@type": "Question", "name": t['faq.6.question'], "acceptedAnswer": { "@type": "Answer", "text": t['faq.6.answer'] } },
  ]
};

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://curfee.com/en/#services",
  "name": "Systems Architecture Consulting",
  "provider": { "@id": "https://curfee.com/#organization" },
  "serviceType": "Systems Architecture Consulting",
  "category": "IT Consulting",
  "areaServed": [
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "serviceOutput": "Structural analysis, root cause identification, architectural standards, governance frameworks, implementation guidance",
  "termsOfService": "https://curfee.com/en/privacy",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": t['services.heading'],
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/en/#diagnosis",
          "name": t['services.diagnosis.title'],
          "description": t['services.diagnosis.problem'],
          "slogan": t['services.diagnosis.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "System Diagnosis",
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/en/#guidance",
          "name": t['services.guidance.title'],
          "description": t['services.guidance.problem'],
          "slogan": t['services.guidance.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architecture Guidance"
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/en/#sparring",
          "name": t['services.sparring.title'],
          "description": t['services.sparring.problem'],
          "slogan": t['services.sparring.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architecture Sparring"
        }
      },
    ]
  }
};

const jsonLd = [webSiteLd, breadcrumbLd, faqLd, serviceLd];
---

<Layout
  title={t['meta.home.title']}
  description={t['meta.home.description']}
  canonicalPath="/en/"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-04-10"
>
  <HeroSection translations={t} />
  <ObservationsSection translations={t} />
  <ServicesSection translations={t} />
  <AboutSection translations={t} />
  <CaseStudySection translations={t} />
  <FaqSection translations={t} />
  <ContactSection translations={t} />
</Layout>
