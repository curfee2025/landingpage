---
import Layout from '@/layouts/Layout.astro';
import HeroSection from '@/components/HeroSection.astro';
import ObservationsSection from '@/components/ObservationsSection.astro';
import ServicesSection from '@/components/ServicesSection.astro';
// import CaseStudySection from '@/components/CaseStudySection.astro'; // disabled — component kept for future
import AboutSection from '@/components/AboutSection.astro';
import FaqSection from '@/components/FaqSection.astro';
import BlogSection from '@/components/BlogSection.astro';
import ContactSection from '@/components/ContactSection.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'en' as const;
const t = getTranslations(lang);

const webSiteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://curfee.com/#website",
  "name": "Curfee",
  "alternateName": "Curfee — Systems Architecture Consulting",
  "url": "https://curfee.com",
  "description": t['meta.home.jsonld.description'],
  "inLanguage": ["de-AT", "en"],
  "publisher": { "@id": "https://curfee.com/#organization" },
  "about": { "@id": "https://curfee.com/#organization" },
  "mainEntity": { "@id": "https://curfee.com/#organization" },
  "potentialAction": {
    "@type": "CommunicateAction",
    "target": "mailto:office@curfee.com",
    "name": "Contact by email"
  }
};

const faqEntries = [
  {
    id: "https://curfee.com/en/#faq-patterns",
    name: t['faq.patterns.question'],
    text: t['faq.patterns.answer'],
  },
  {
    id: "https://curfee.com/en/#faq-decisions",
    name: t['faq.decisions.question'],
    text: t['faq.decisions.answer'],
  },
  ...([1, 2, 4, 5, 6] as const).map((n) => ({
    id: `https://curfee.com/en/#faq-${n}`,
    name: t[`faq.${n}.question` as keyof typeof t],
    text: t[`faq.${n}.answer` as keyof typeof t],
  })),
];
const faqLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "@id": "https://curfee.com/en/#faq",
  "inLanguage": "en",
  "about": { "@id": "https://curfee.com/#organization" },
  "author": { "@id": "https://curfee.com/#founder" },
  "publisher": { "@id": "https://curfee.com/#organization" },
  "dateModified": "2026-04-14",
  "mainEntity": faqEntries.map((q) => ({
    "@type": "Question",
    "@id": q.id,
    "name": q.name,
    "author": { "@id": "https://curfee.com/#founder" },
    "acceptedAnswer": {
      "@type": "Answer",
      "author": { "@id": "https://curfee.com/#founder" },
      "text": q.text
    }
  }))
};

const serviceLd = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": "https://curfee.com/#services",
  "name": "Systems Architecture Consulting",
  "alternateName": "Systemarchitektur-Beratung",
  "provider": { "@id": "https://curfee.com/#organization" },
  "serviceType": "Systems Architecture Consulting",
  "category": ["IT Consulting", "Management Consulting", "Software Architecture"],
  "areaServed": [
    { "@type": "Country", "name": "Austria" },
    { "@type": "Country", "name": "Germany" },
    { "@type": "Country", "name": "Switzerland" }
  ],
  "audience": {
    "@type": "BusinessAudience",
    "name": "CTOs, engineering managers, team leads, founders",
    "audienceType": "Decision-makers in companies with grown system landscapes"
  },
  "serviceOutput": "Root cause analysis, architectural standards enforced by the system through pipelines and tooling, governance frameworks, implementation guidance",
  "availableLanguage": ["de", "en"],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "@id": "https://curfee.com/#offer-catalog",
    "name": t['services.heading'],
    "itemListElement": [
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-diagnosis",
        "category": "Entry engagement",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "EUR",
          "description": "Price on application"
        },
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 2, "unitCode": "WEE" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#diagnosis",
          "name": t['services.diagnosis.title'],
          "description": t['services.diagnosis.problem'],
          "slogan": t['services.diagnosis.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "System Diagnosis",
          "inLanguage": ["de", "en"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-guidance",
        "category": "Project engagement",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "EUR",
          "description": "Price on application"
        },
        "eligibleDuration": { "@type": "QuantitativeValue", "minValue": 3, "unitCode": "MON" },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#guidance",
          "name": t['services.guidance.title'],
          "description": t['services.guidance.problem'],
          "slogan": t['services.guidance.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architecture Guidance",
          "inLanguage": ["de", "en"]
        }
      },
      {
        "@type": "Offer",
        "@id": "https://curfee.com/#offer-sparring",
        "category": "Retainer engagement",
        "priceSpecification": {
          "@type": "PriceSpecification",
          "priceCurrency": "EUR",
          "description": "Ongoing retainer, price on application"
        },
        "itemOffered": {
          "@type": "Service",
          "@id": "https://curfee.com/#sparring",
          "name": t['services.sparring.title'],
          "description": t['services.sparring.problem'],
          "slogan": t['services.sparring.subtitle'],
          "provider": { "@id": "https://curfee.com/#organization" },
          "serviceType": "Architecture Sparring",
          "inLanguage": ["de", "en"]
        }
      },
    ]
  }
};

const aboutPageLd = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": "https://curfee.com/en/#about",
  "url": "https://curfee.com/en/#about",
  "mainEntity": { "@id": "https://curfee.com/#founder" },
  "isPartOf": { "@id": "https://curfee.com/#website" },
  "inLanguage": "en"
};

const jsonLd = [webSiteLd, faqLd, serviceLd, aboutPageLd];
---

<Layout
  title={t['meta.home.title']}
  description={t['meta.home.description']}
  canonicalPath="/en/"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-04-14"
>
  <HeroSection translations={t} />
  <ObservationsSection translations={t} />
  <ServicesSection translations={t} />
  <AboutSection translations={t} />
  <FaqSection translations={t} />
  <BlogSection translations={t} lang={lang} />
  <ContactSection translations={t} />
</Layout>
