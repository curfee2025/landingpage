---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import BackToHomeSection from '@/components/shared/BackToHomeSection.astro';
import { getTranslations } from '@/i18n/translations';
import { getPostsForLang, postPath, formatDate, readingTime } from '@/utils/blog';

const lang = 'en' as const;
const t = getTranslations(lang);

const posts = await getPostsForLang(lang);
const topics = Array.from(new Set(posts.map((p) => p.data.topic))).sort();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "https://curfee.com/en/blog/#blog",
  "name": t['blog.indexHeading'],
  "description": t['blog.indexSubtitle'],
  "inLanguage": "en",
  "url": "https://curfee.com/en/blog/",
  "publisher": { "@id": "https://curfee.com/#organization" },
  "blogPost": posts.map((p) => ({
    "@type": "BlogPosting",
    "@id": `https://curfee.com${postPath(p)}#post`,
    "headline": p.data.title,
    "description": p.data.excerpt,
    "datePublished": p.data.createdAt.toISOString(),
    "dateModified": (p.data.updatedAt ?? p.data.createdAt).toISOString(),
    "author": { "@id": "https://curfee.com/#founder" },
    "url": `https://curfee.com${postPath(p)}`,
    "keywords": [p.data.topic, ...p.data.tags].join(', '),
  })),
};
---

<Layout
  title={`${t['blog.indexHeading']} – Curfee`}
  description={t['blog.indexSubtitle']}
  lang={lang}
  canonicalPath="/en/blog/"
  jsonLd={jsonLd}
>
  <article class="py-16 md:py-24 max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto">
      <div class="mb-12">
        <div class="w-12 h-12 rounded-full bg-brand-primary/[0.08] flex items-center justify-center mb-6">
          <Icon name="article" class="w-6 h-6 text-brand-primary" />
        </div>
        <h1 class="text-display-small md:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">
          {t['blog.indexHeading']}
        </h1>
        <p class="text-body-large text-ink-muted/70 max-w-xl">
          {t['blog.indexSubtitle']}
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="text-body-large text-ink-muted">{t['blog.empty']}</p>
      ) : (
        <>
          <div class="flex flex-wrap items-center gap-3 mb-10" data-blog-controls>
            <label class="inline-flex items-center gap-2 text-label-medium text-ink-onSurfaceVariant">
              <span>{t['blog.filterLabel']}</span>
              <span class="relative inline-block">
                <select data-blog-filter class="appearance-none rounded-full border border-stroke-outlineVariant bg-surface-base text-body-medium text-ink-primary pl-4 pr-9 py-2 cursor-pointer hover:border-ink-primary/60 hover:bg-ink-primary/[0.04] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/40">
                  <option value="">{t['blog.filterAll']}</option>
                  {topics.map((topic) => (
                    <option value={topic}>{topic}</option>
                  ))}
                </select>
                <Icon name="expand_less" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-onSurfaceVariant rotate-180" />
              </span>
            </label>
            <label class="inline-flex items-center gap-2 text-label-medium text-ink-onSurfaceVariant">
              <span>{t['blog.sortLabel']}</span>
              <span class="relative inline-block">
                <select data-blog-sort class="appearance-none rounded-full border border-stroke-outlineVariant bg-surface-base text-body-medium text-ink-primary pl-4 pr-9 py-2 cursor-pointer hover:border-ink-primary/60 hover:bg-ink-primary/[0.04] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/40">
                  <option value="newest">{t['blog.sortNewest']}</option>
                  <option value="oldest">{t['blog.sortOldest']}</option>
                  <option value="az">{t['blog.sortAZ']}</option>
                </select>
                <Icon name="expand_less" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-ink-onSurfaceVariant rotate-180" />
              </span>
            </label>
          </div>

          <ol class="space-y-4" data-blog-list>
            {posts.map((post) => {
              const minutes = post.data.readingTimeMinutes ?? readingTime(post.body ?? '');
              return (
                <li
                  data-blog-item
                  data-topic={post.data.topic}
                  data-title={post.data.title}
                  data-date={post.data.createdAt.toISOString()}
                >
                  <a
                    href={postPath(post)}
                    class="group block rounded-xl bg-surface-base shadow-elevation-1 p-6 md:p-8 hover:shadow-elevation-3 transition-shadow duration-medium2 ease-standard"
                  >
                    <div class="flex flex-wrap items-center gap-3 text-label-medium text-ink-muted mb-3">
                      <span class="rounded-full bg-brand-primary/[0.08] text-brand-primary px-3 py-0.5">
                        {post.data.topic}
                      </span>
                      <span>{minutes} {t['blog.minutes']}</span>
                      <time datetime={post.data.createdAt.toISOString()}>
                        {formatDate(post.data.createdAt, lang)}
                      </time>
                    </div>
                    <h2 class="text-headline-small md:text-headline-large text-ink-primary mb-2 tracking-tight group-hover:text-brand-primary transition-colors duration-short4">
                      {post.data.title}
                    </h2>
                    <p class="text-body-large text-ink-muted leading-relaxed">
                      {post.data.excerpt}
                    </p>
                  </a>
                </li>
              );
            })}
          </ol>
        </>
      )}
    </div>
  </article>
  <BackToHomeSection lang={lang} />
</Layout>

<script>
  function initBlogControls() {
    const list = document.querySelector<HTMLElement>('[data-blog-list]');
    const filter = document.querySelector<HTMLSelectElement>('[data-blog-filter]');
    const sort = document.querySelector<HTMLSelectElement>('[data-blog-sort]');
    if (!list || !filter || !sort) return;

    const items = Array.from(list.querySelectorAll<HTMLElement>('[data-blog-item]'));

    const apply = () => {
      const topicFilter = filter.value;
      const sortMode = sort.value;
      const visible = items.filter((it) => !topicFilter || it.dataset.topic === topicFilter);
      const hidden = items.filter((it) => topicFilter && it.dataset.topic !== topicFilter);
      visible.sort((a, b) => {
        if (sortMode === 'oldest') return (a.dataset.date ?? '').localeCompare(b.dataset.date ?? '');
        if (sortMode === 'az') return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '');
        return (b.dataset.date ?? '').localeCompare(a.dataset.date ?? '');
      });
      visible.forEach((el) => { el.style.display = ''; list.appendChild(el); });
      hidden.forEach((el) => { el.style.display = 'none'; });
    };

    filter.addEventListener('change', apply);
    sort.addEventListener('change', apply);
    apply();
  }

  document.addEventListener('astro:page-load', initBlogControls);
  initBlogControls();
</script>
