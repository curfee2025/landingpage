---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'en' as const;
const t = getTranslations(lang);
---

<ServicePageTemplate
  serviceKey="sparring" icon="handshake"
  translations={t}
  lang={lang}
  canonicalPath="/en/services/sparring"
  pageTitle={t['services.sparring.page.title']}
  pageDesc={t['services.sparring.page.description']}
/>
