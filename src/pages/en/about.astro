---
import Layout from '@/layouts/Layout.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { getTranslations } from '@/i18n/translations';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://curfee.com/#founder",
    "name": "Philipp Höllinger",
    "jobTitle": t['meta.about.jobTitle'],
    "url": "https://curfee.com/en/about",
    "worksFor": { "@id": "https://curfee.com/#organization" },
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Salzburg",
      "addressCountry": "AT"
    },
    "sameAs": ["https://www.linkedin.com/in/phoellinger"]
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": `https://curfee.com${lang === 'en' ? '/en/' : '/'}` },
      { "@type": "ListItem", "position": 2, "name": t['navigation.about'], "item": `https://curfee.com${lang === 'en' ? '/en/about' : '/about'}` }
    ]
  }
];
---

<Layout
  title={t['meta.about.title']}
  description={t['meta.about.description']}
  canonicalPath="/en/about"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-03-30"
>

  <!-- Who I am -->
  <section class="mb-20 max-w-3xl mx-auto px-6">
    <picture><source srcset="/assets/profile.webp" type="image/webp" /><img src="/assets/profile.png" alt="Philipp Höllinger" class="w-[160px] h-[200px] object-cover object-top rounded-md mb-8" loading="lazy" /></picture>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-8">{t['about.who.heading']}</h1>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.who.1']}</p>
      <p>{t['about.who.2']}</p>
      <p>{t['about.who.3']}</p>
    </div>
  </section>

  <!-- What I've done -->
  <section class="mb-20 max-w-3xl mx-auto px-6">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-8">{t['about.done.heading']}</h2>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.done.1']}</p>
      <p>{t['about.done.2']}</p>
    </div>
  </section>

  <!-- What I stand for -->
  <section class="mb-20 max-w-3xl mx-auto px-6">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-8">{t['about.stand.heading']}</h2>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.stand.1']}</p>
    </div>
  </section>

  <!-- How I work -->
  <section class="mb-20 max-w-3xl mx-auto px-6">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-8">{t['about.work.heading']}</h2>
    <div class="space-y-6 text-body-large text-ink-muted leading-relaxed">
      <p>{t['about.work.1']}</p>
    </div>
  </section>

  <!-- Five Principles -->
  <section class="mb-20 max-w-3xl mx-auto px-6">
    <h2 class="text-headline-large md:text-display-small text-ink-primary mb-12">{t['principles.heading']}</h2>
    <div class="space-y-8">
      {[1, 2, 3, 4, 5].map(i => {
        const title = t[`principles.${i}.title`];
        const firstLetter = title.charAt(0);
        const rest = title.slice(1);
        const isLast = i === 5;
        return (
          <div class="flex items-start gap-6 min-h-[3.5rem]">
            <span class="text-display-small text-brand-primary font-display leading-none w-12 flex-shrink-0 text-center">{isLast ? 'EE' : firstLetter}</span>
            <div>
              <h3 class="text-title-large text-ink-primary mb-1">
                <span class="text-brand-primary">{firstLetter}</span>{rest}
              </h3>
              <p class="text-body-large text-ink-muted">{t[`principles.${i}.description`]}</p>
            </div>
          </div>
        );
      })}
    </div>
  </section>


</Layout>
