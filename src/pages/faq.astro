---
import Icon from '@/components/shared/Icon.astro';
import Layout from '@/layouts/Layout.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);

const questions = [
  { question: t['faq.9.question'], answer: t['faq.9.answer'] },
  { question: t['faq.1.question'], answer: t['faq.1.answer'] },
  { question: t['faq.2.question'], answer: t['faq.2.answer'] },
  { question: t['faq.3.question'], answer: t['faq.3.answer'] },
  { question: t['faq.4.question'], answer: t['faq.4.answer'] },
  { question: t['faq.5.question'], answer: t['faq.5.answer'] },
  { question: t['faq.6.question'], answer: t['faq.6.answer'] },
  { question: t['faq.7.question'], answer: t['faq.7.answer'] },
  { question: t['faq.8.question'], answer: t['faq.8.answer'] },
];

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": questions.map(q => ({
      "@type": "Question",
      "name": q.question,
      "acceptedAnswer": { "@type": "Answer", "text": q.answer }
    }))
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
      { "@type": "ListItem", "position": 2, "name": "FAQ", "item": "https://curfee.com/faq" }
    ]
  }
];
---

<Layout
  title={t['meta.faq.title']}
  description={t['meta.faq.description']}
  canonicalPath="/faq"
  jsonLd={jsonLd}
  lang={lang}
  dateModified="2026-03-30"
>

  <div class="max-w-3xl mx-auto px-6 mb-10">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name="help" class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{t['faq.heading']}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-12">{t['faq.subtitle']}</p>

    <div class="divide-y divide-stroke-subtle" data-faq-accordion>
      {questions.map(q => (
        <div>
          <button
            type="button"
            data-faq-trigger
            aria-expanded="false"
            class="w-full flex items-center justify-between cursor-pointer py-6 text-title-medium text-ink-primary hover:text-brand-primary transition-colors duration-short4 ease-standard text-left"
          >
            <span>{q.question}</span>
            <span data-faq-icon class="flex-shrink-0 ml-4 text-ink-muted">
              <Icon name="expand_less" class="w-5 h-5" />
            </span>
          </button>
          <div data-faq-content class="faq-panel" aria-hidden="true">
            <div class="faq-panel-inner">
              <p class="text-body-medium text-ink-muted leading-relaxed pb-6">{q.answer}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <style>
    /*
     * CSS-only accordion panel using grid-template-rows: 0fr/1fr.
     * This avoids all JS height calculation and scrollHeight quirks.
     * The collapsed state uses visibility:hidden as a Firefox safeguard:
     * during view-transition snapshots, Firefox may briefly render content
     * at natural height before inline styles or class-based rules take effect.
     * visibility:hidden ensures nothing flashes even if the grid row
     * momentarily expands during the snapshot frame.
     */
    .faq-panel {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 200ms ease-out, visibility 0s linear 200ms;
      visibility: hidden;
    }
    .faq-panel[aria-hidden="false"] {
      grid-template-rows: 1fr;
      visibility: visible;
      transition: grid-template-rows 200ms ease-out, visibility 0s linear 0s;
    }
    .faq-panel-inner {
      overflow: hidden;
    }

    [data-faq-icon] {
      transition: transform 200ms ease-out;
    }
    button[aria-expanded="true"] [data-faq-icon] {
      transform: rotate(180deg);
    }
  </style>

  <script>
    function initFaq() {
      const container = document.querySelector('[data-faq-accordion]') as HTMLElement | null;
      if (!container || container.hasAttribute('data-faq-ready')) return;
      container.setAttribute('data-faq-ready', '');

      const triggers = container.querySelectorAll('[data-faq-trigger]') as NodeListOf<HTMLButtonElement>;

      triggers.forEach(trigger => {
        trigger.addEventListener('click', () => {
          const isOpen = trigger.getAttribute('aria-expanded') === 'true';
          const panel = trigger.nextElementSibling as HTMLElement;

          // Close all panels first
          triggers.forEach(t => {
            t.setAttribute('aria-expanded', 'false');
            const p = t.nextElementSibling as HTMLElement;
            p.setAttribute('aria-hidden', 'true');
          });

          // Open the clicked panel if it was closed
          if (!isOpen) {
            trigger.setAttribute('aria-expanded', 'true');
            panel.setAttribute('aria-hidden', 'false');
          }
        });
      });
    }
    initFaq();
    document.addEventListener('astro:after-swap', initFaq);
  </script>

</Layout>
