---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import { getTranslations } from '@/i18n/translations';
const lang = 'de' as const;
const t = getTranslations(lang);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.cookies'], "item": "https://curfee.com/cookies" }
  ]
};
---

<Layout
  title={t['meta.cookies.title']}
  description={t['meta.cookies.description']}
  lang={lang}
  canonicalPath="/cookies"
  jsonLd={jsonLd}
  dateModified="2026-03-30"
>
  <div class="max-w-3xl mx-auto px-6">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name="cookie" class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{t['cookies.heading']}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-8">{t['cookies.updated']}</p>

    <div class="space-y-10 mb-12">
      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['cookies.what.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['cookies.what']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['cookies.legal.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['cookies.legal']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['cookies.types.heading']}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
          <div>
            <span class="text-label-large text-ink-primary">{t['cookies.types.necessary.label']}</span>
            <p class="text-body-large text-ink-muted mt-2">{t['cookies.types.necessary']}</p>
          </div>
          <div>
            <span class="text-label-large text-ink-primary">{t['cookies.types.analytics.label']}</span>
            <p class="text-body-large text-ink-muted mt-2">{t['cookies.types.analytics']}</p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['cookies.list.heading']}</h2>
        <!-- Desktop: Grid-Tabelle -->
        <div class="hidden sm:block rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 space-y-6">
          <div class="grid grid-cols-5 gap-4 pb-4 border-b border-stroke-outlineVariant">
            <span class="text-label-medium text-ink-primary">{t['cookies.list.name']}</span>
            <span class="text-label-medium text-ink-primary">{t['cookies.list.provider']}</span>
            <span class="text-label-medium text-ink-primary">{t['cookies.list.purpose']}</span>
            <span class="text-label-medium text-ink-primary">{t['cookies.list.duration']}</span>
            <span class="text-label-medium text-ink-primary">{t['cookies.list.type']}</span>
          </div>
          <div class="grid grid-cols-5 gap-4 pb-4 border-b border-stroke-outlineVariant">
            <span class="text-body-large text-ink-muted font-mono">_ga</span>
            <span class="text-body-large text-ink-muted">Google Analytics</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.ga.purpose']}</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.ga.duration']}</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.ga.type']}</span>
          </div>
          <div class="grid grid-cols-5 gap-4 pb-4 border-b border-stroke-outlineVariant">
            <span class="text-body-large text-ink-muted font-mono">{t['cookies.list.gastar.name']}</span>
            <span class="text-body-large text-ink-muted">Google Analytics</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.gastar.purpose']}</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.gastar.duration']}</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.gastar.type']}</span>
          </div>
          <div class="grid grid-cols-5 gap-4">
            <span class="text-body-large text-ink-muted font-mono">curfee-consent</span>
            <span class="text-body-large text-ink-muted">Curfee e.U.</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.consent.purpose']}</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.consent.duration']}</span>
            <span class="text-body-large text-ink-muted">{t['cookies.list.consent.type']}</span>
          </div>
        </div>
        <!-- Mobile: gestapelte Cards -->
        <div class="sm:hidden space-y-4">
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-4 space-y-2">
            <span class="text-label-medium text-ink-primary font-mono block">_ga</span>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.provider']}:</span> Google Analytics</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.purpose']}:</span> {t['cookies.list.ga.purpose']}</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.duration']}:</span> {t['cookies.list.ga.duration']}</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.type']}:</span> {t['cookies.list.ga.type']}</div>
          </div>
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-4 space-y-2">
            <span class="text-label-medium text-ink-primary font-mono block">{t['cookies.list.gastar.name']}</span>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.provider']}:</span> Google Analytics</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.purpose']}:</span> {t['cookies.list.gastar.purpose']}</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.duration']}:</span> {t['cookies.list.gastar.duration']}</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.type']}:</span> {t['cookies.list.gastar.type']}</div>
          </div>
          <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-4 space-y-2">
            <span class="text-label-medium text-ink-primary font-mono block">curfee-consent</span>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.provider']}:</span> Curfee e.U.</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.purpose']}:</span> {t['cookies.list.consent.purpose']}</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.duration']}:</span> {t['cookies.list.consent.duration']}</div>
            <div class="text-body-medium text-ink-muted"><span class="text-label-medium text-ink-primary">{t['cookies.list.type']}:</span> {t['cookies.list.consent.type']}</div>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['cookies.manage.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed mb-6">{t['cookies.manage']}</p>
        <button
          type="button"
          data-consent-reset
          class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-label-large text-ink-primary border border-stroke-outlineVariant hover:bg-ink-primary/[0.08] transition-all duration-short4 ease-standard"
        >
          <Icon name="cookie" class="w-5 h-5" />
          {t['consent.settings']}
        </button>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-8">{t['cookies.updates.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['cookies.updates']}</p>
      </section>
    </div>
  </div>
</Layout>
