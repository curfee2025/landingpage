---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import { getLangFromUrl } from '@/i18n/utils';
import { getTranslations } from '@/i18n/translations';
import { localizedRoutes } from '@/configurations/routes';

const lang = getLangFromUrl(Astro.url);
const t = getTranslations(lang);
const routes = localizedRoutes(lang);
const linkClass = "text-brand-primary hover:underline transition-colors duration-short4 ease-standard";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://curfee.com/de/" },
    { "@type": "ListItem", "position": 2, "name": t['footer.legal.privacy'], "item": "https://curfee.com/de/privacy" }
  ]
};
---

<Layout
  title="Datenschutzerklärung — Curfee"
  description="Datenschutzerklärung für Curfee e.U., Unternehmensberatung im Bereich Informationstechnologie von Philipp Höllinger, Salzburg, Österreich."
  lang={lang}
  canonicalPath="/de/privacy"
  jsonLd={jsonLd}
  dateModified="2026-03-30"
>
  <div class="max-w-3xl mx-auto">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name="shield" class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{t['privacy.heading']}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-8">{t['privacy.scope']}</p>

    <!-- Controller + Contact Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-12">
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
        <h2 class="text-label-large text-ink-primary mb-4">{t['privacy.controller.heading']}</h2>
        <div class="text-body-large text-ink-muted">
          <p class="text-title-medium text-ink-primary">{t['imprint.company']}</p>
          <p class="mt-1">{t['imprint.name']}</p>
          <div class="mt-3 leading-snug">
            <p>{t['imprint.address.street']}</p>
            <p>{t['imprint.address.city']}</p>
            <p>{t['imprint.address.country']}</p>
          </div>
        </div>
      </div>
      <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6">
        <h2 class="text-label-large text-ink-primary mb-4">{t['imprint.contact']}</h2>
        <div class="space-y-4">
          <div>
            <span class="text-label-large font-medium text-ink-muted">E-Mail</span>
            <p><a href={`mailto:${t['imprint.email']}`} class={linkClass}>{t['imprint.email']}</a></p>
          </div>
          <div>
            <span class="text-label-large font-medium text-ink-muted">{t['privacy.phone.label']}</span>
            <p><a href={`tel:${t['imprint.phone'].replace(/\s/g, '')}`} class={linkClass}>{t['imprint.phone']}</a></p>
          </div>
        </div>
      </div>
    </div>

    <!-- Legal text sections -->
    <div class="space-y-10 mb-12">
      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.personal.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.personal']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.rights.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.rights']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.withdrawal.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.withdrawal']} <a href={`mailto:${t['imprint.email']}`} class={linkClass}>{t['imprint.email']}</a></p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.complaint.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed mb-4">{t['privacy.complaint']}</p>
        <div class="rounded-md bg-surface-raised border border-stroke-outlineVariant p-6 text-body-large text-ink-muted">
          <p class="text-title-medium text-ink-primary">{t['privacy.complaint.authority']}</p>
          <p class="mt-1">{t['privacy.complaint.address.street']}</p>
          <p>{t['privacy.complaint.address.city']}</p>
          <p>{t['privacy.complaint.address.country']}</p>
          <div class="mt-3 space-y-1">
            <p>{t['privacy.phone.label']}: <a href={`tel:${t['privacy.complaint.phone'].replace(/\s/g, '')}`} class={linkClass}>{t['privacy.complaint.phone']}</a></p>
            <p>E-Mail: <a href={`mailto:${t['privacy.complaint.email']}`} class={linkClass}>{t['privacy.complaint.email']}</a></p>
            <p>Website: <a href={`https://${t['privacy.complaint.website']}`} target="_blank" rel="noopener noreferrer" class={linkClass}>{t['privacy.complaint.website']}</a></p>
          </div>
        </div>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.ssl.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.ssl']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.cookies.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.cookies.reference']} <a href={routes.cookies} class={linkClass}>{t['footer.legal.cookies']}</a></p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.links.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.links']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.hosting.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.hosting']}</p>
      </section>

      <section>
        <h2 class="text-headline-small text-ink-primary mb-3">{t['privacy.analytics.heading']}</h2>
        <p class="text-body-large text-ink-muted leading-relaxed">{t['privacy.analytics']}</p>
        <p class="text-body-large text-ink-muted leading-relaxed mt-2">{t['privacy.analytics.more']} <a href="https://policies.google.com/privacy" target="_blank" rel="noopener noreferrer" class={linkClass}>policies.google.com/privacy</a></p>
      </section>
    </div>
  </div>
</Layout>
