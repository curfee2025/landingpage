---
import Icon from '@/components/shared/Icon.astro';
import Layout from '@/layouts/Layout.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);

const questions = [
  { question: t['faq.question1'], answer: t['faq.answer1'] },
  { question: t['faq.question2'], answer: t['faq.answer2'] },
  { question: t['faq.question3'], answer: t['faq.answer3'] },
  { question: t['faq.question4'], answer: t['faq.answer4'] },
  { question: t['faq.question5'], answer: t['faq.answer5'] },
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": questions.map(q => ({
    "@type": "Question",
    "name": q.question,
    "acceptedAnswer": { "@type": "Answer", "text": q.answer }
  }))
};
---

<Layout
  title="FAQ — Curfee | Häufige Fragen zur Technologieberatung"
  description="Antworten auf häufige Fragen zu Curfees Beratungsleistungen: Umfang, Preise, Zeitrahmen und wie Diagnose, Design und Advisory funktionieren."
  canonicalPath="/de/faq"
  jsonLd={jsonLd}
  lang={lang}
>

  <div class="max-w-3xl mx-auto mb-10">
    <div class="w-12 h-12 rounded-full bg-brand-primary/10 flex items-center justify-center mb-6">
      <Icon name="help" class="w-6 h-6 text-brand-primary" />
    </div>
    <h1 class="text-display-small md:text-display-medium text-ink-primary mb-2">{t['faq.heading']}</h1>
    <p class="text-title-medium text-brand-primary font-medium mb-12">{t['faq.subtitle']}</p>

    <div class="grid grid-cols-1 gap-4" data-faq-accordion>
      {questions.map(q => (
        <details class="group rounded-md bg-surface-raised border border-stroke-outlineVariant [&>summary]:list-none [&>summary::-webkit-details-marker]:hidden">
          <summary class="flex items-center justify-between cursor-pointer p-6 text-title-medium text-ink-primary hover:text-brand-primary transition-colors duration-short4 ease-standard">
            <span>{q.question}</span>
            <span class="inline-flex group-open:rotate-180 transition-transform duration-short4 ease-standard flex-shrink-0 ml-4"><Icon name="expand_more" class="w-6 h-6 text-ink-muted" /></span>
          </summary>
          <p class="text-body-medium text-ink-muted leading-relaxed px-6 pb-6">{q.answer}</p>
        </details>
      ))}
    </div>
  </div>

  <script>
    function initFaqAccordion(): void {
      const container = document.querySelector('[data-faq-accordion]') as HTMLElement | null;
      if (!container) return;
      const items = container.querySelectorAll('details') as NodeListOf<HTMLDetailsElement>;
      items.forEach((item: HTMLDetailsElement) => {
        item.addEventListener('toggle', () => {
          if (item.open) {
            items.forEach((other: HTMLDetailsElement) => { if (other !== item) other.open = false; });
          }
        });
      });
    }
    document.addEventListener('astro:page-load', initFaqAccordion);
  </script>

</Layout>
