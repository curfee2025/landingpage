---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);
---

<ServicePageTemplate
  serviceKey="diagnosis" icon="search"
  translations={t}
  lang={lang}
  canonicalPath="/services/diagnosis"
  pageTitle={t['services.diagnosis.page.title']}
  pageDesc={t['services.diagnosis.page.description']}
/>
