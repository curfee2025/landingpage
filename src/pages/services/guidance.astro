---
import ServicePageTemplate from '@/components/ServicePageTemplate.astro';
import { getTranslations } from '@/i18n/translations';

const lang = 'de' as const;
const t = getTranslations(lang);
---

<ServicePageTemplate
  serviceKey="guidance" icon="group_work"
  translations={t}
  lang={lang}
  canonicalPath="/services/guidance"
  pageTitle={t['services.guidance.page.title']}
  pageDesc={t['services.guidance.page.description']}
/>
