---
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import BackToHomeSection from '@/components/shared/BackToHomeSection.astro';
import { getTranslations } from '@/i18n/translations';
import { getPosts, postPath } from '@/utils/blog';
import BlogCard from '@/components/BlogCard.astro';

const t = getTranslations();

const posts = await getPosts();
const topics = Array.from(new Set(posts.map((p) => p.data.topic))).sort();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "@id": "https://curfee.com/blog/#blog",
  "name": t['blog.indexHeading'],
  "description": t['blog.indexSubtitle'],
  "inLanguage": "en",
  "url": "https://curfee.com/blog/",
  "publisher": { "@id": "https://curfee.com/#organization" },
  "blogPost": posts.map((p) => ({
    "@type": "BlogPosting",
    "@id": `https://curfee.com${postPath(p)}#post`,
    "headline": p.data.title,
    "description": p.data.excerpt,
    "datePublished": p.data.createdAt.toISOString(),
    "dateModified": (p.data.updatedAt ?? p.data.createdAt).toISOString(),
    "author": { "@id": "https://curfee.com/#founder" },
    "url": `https://curfee.com${postPath(p)}`,
    "keywords": [p.data.topic, ...p.data.tags].join(', '),
  })),
};
---

<Layout
  title={t['meta.blog.title']}
  description={t['meta.blog.description']}
  canonicalPath="/blog/"
  jsonLd={jsonLd}
  showHeader={false}
>
  <article class="pt-[clamp(4rem,3rem+3vw,7rem)] pb-[clamp(8rem,5rem+7vw,12rem)] max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
      <div class="mb-12 md:mb-16">
        <h1 class="text-headline-large md:text-display-small lg:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-3">
          {t['blog.indexH1']}
        </h1>
        <p class="text-body-large text-brand-primary max-w-xl">
          {t['blog.indexSubtitle']}
        </p>
      </div>

      {posts.length === 0 ? (
        <p class="text-body-large text-ink-muted">{t['blog.empty']}</p>
      ) : (
        <>
          <div class="flex flex-wrap items-center gap-3 mb-10" data-blog-controls>
            <label class="inline-flex items-center gap-2 text-label-medium text-ink-onSurfaceVariant">
              <span>{t['blog.filterLabel']}</span>
              <span class="relative inline-block">
                <select data-blog-filter class="appearance-none rounded-full border border-brand-primary/30 bg-surface-base text-body-medium text-brand-primary font-medium pl-4 pr-9 py-2 cursor-pointer hover:border-brand-primary/60 hover:bg-brand-primary/[0.04] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/40">
                  <option value="">{t['blog.filterAll']}</option>
                  {topics.map((topic) => (
                    <option value={topic}>{topic}</option>
                  ))}
                </select>
                <Icon name="expand_less" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-primary rotate-180" />
              </span>
            </label>
            <label class="inline-flex items-center gap-2 text-label-medium text-ink-onSurfaceVariant">
              <span>{t['blog.sortLabel']}</span>
              <span class="relative inline-block">
                <select data-blog-sort class="appearance-none rounded-full border border-brand-primary/30 bg-surface-base text-body-medium text-brand-primary font-medium pl-4 pr-9 py-2 cursor-pointer hover:border-brand-primary/60 hover:bg-brand-primary/[0.04] transition-all duration-short4 ease-standard focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-primary/40">
                  <option value="newest">{t['blog.sortNewest']}</option>
                  <option value="oldest">{t['blog.sortOldest']}</option>
                  <option value="az">{t['blog.sortAZ']}</option>
                </select>
                <Icon name="expand_less" class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-brand-primary rotate-180" />
              </span>
            </label>
          </div>

          <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" data-blog-list>
            {posts.map((post, index) => (
              <li
                data-blog-item
                data-topic={post.data.topic}
                data-title={post.data.title}
                data-date={post.data.createdAt.toISOString()}
              >
                <BlogCard post={post} index={index + 1} headingLevel="h2" />
              </li>
            ))}
          </ol>
        </>
      )}
  </article>
  <BackToHomeSection />
</Layout>

<script>
  function initBlogControls() {
    const list = document.querySelector<HTMLElement>('[data-blog-list]');
    const filter = document.querySelector<HTMLSelectElement>('[data-blog-filter]');
    const sort = document.querySelector<HTMLSelectElement>('[data-blog-sort]');
    if (!list || !filter || !sort) return;

    const items = Array.from(list.querySelectorAll<HTMLElement>('[data-blog-item]'));

    const apply = () => {
      const topicFilter = filter.value;
      const sortMode = sort.value;
      const visible = items.filter((it) => !topicFilter || it.dataset.topic === topicFilter);
      const hidden = items.filter((it) => topicFilter && it.dataset.topic !== topicFilter);
      visible.sort((a, b) => {
        if (sortMode === 'oldest') return (a.dataset.date ?? '').localeCompare(b.dataset.date ?? '');
        if (sortMode === 'az') return (a.dataset.title ?? '').localeCompare(b.dataset.title ?? '');
        return (b.dataset.date ?? '').localeCompare(a.dataset.date ?? '');
      });
      visible.forEach((el) => { el.style.display = ''; list.appendChild(el); });
      hidden.forEach((el) => { el.style.display = 'none'; });
    };

    filter.addEventListener('change', apply);
    sort.addEventListener('change', apply);
    apply();
  }

  document.addEventListener('astro:page-load', initBlogControls);
  initBlogControls();
</script>
