---
import { getCollection, render } from 'astro:content';
import Layout from '@/layouts/Layout.astro';
import Icon from '@/components/shared/Icon.astro';
import BackToHomeSection from '@/components/shared/BackToHomeSection.astro';
import { getTranslations } from '@/i18n/translations';
import { postSlug, postPath, formatDate, getRelatedPosts, extractToc, getAdjacentPosts, extractReferences } from '@/utils/blog';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: postSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const t = getTranslations();
const { Content } = await render(post);
const slug = postSlug(post);
const canonicalPath = `/blog/${slug}/`;
const related = await getRelatedPosts(post, 3);
const toc = extractToc(post.body ?? '');
const adjacent = await getAdjacentPosts(post);
const references = extractReferences(post.body ?? '');
const contactPath = '/#contact';

const postImage = post.data.coverImage
  ? (post.data.coverImage.startsWith('http') ? post.data.coverImage : `https://curfee.com${post.data.coverImage}`)
  : 'https://curfee.com/assets/og-image.png';

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": t['breadcrumb.home'], "item": "https://curfee.com/" },
    { "@type": "ListItem", "position": 2, "name": t['blog.indexHeading'], "item": "https://curfee.com/blog/" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": `https://curfee.com${canonicalPath}` }
  ]
};

const blogPostingLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `https://curfee.com${canonicalPath}#post`,
  "headline": post.data.title,
  "description": post.data.excerpt,
  "image": {
    "@type": "ImageObject",
    "url": postImage,
    "width": 1200,
    "height": 630
  },
  "datePublished": post.data.createdAt.toISOString(),
  "dateModified": (post.data.updatedAt ?? post.data.createdAt).toISOString(),
  "author": { "@id": "https://curfee.com/#founder" },
  "publisher": { "@id": "https://curfee.com/#organization" },
  "mainEntityOfPage": { "@type": "WebPage", "@id": `https://curfee.com${canonicalPath}` },
  "inLanguage": "en",
  "url": `https://curfee.com${canonicalPath}`,
  "keywords": [post.data.topic, ...post.data.tags].join(', '),
  "wordCount": (post.body ?? '').split(/\s+/).filter(Boolean).length,
  "isPartOf": { "@id": "https://curfee.com/blog/#blog" },
};

const jsonLd = [blogPostingLd, breadcrumbLd];
---

<Layout
  title={`${post.data.title} – Curfee Blog`}
  description={post.data.excerpt}
  canonicalPath={canonicalPath}
  jsonLd={jsonLd}
  ogType="article"
  datePublished={post.data.createdAt.toISOString().slice(0, 10)}
  dateModified={(post.data.updatedAt ?? post.data.createdAt).toISOString().slice(0, 10)}
  showHeader={false}
>
  <article class="pt-[clamp(4rem,3rem+3vw,7rem)] pb-[clamp(8rem,5rem+7vw,12rem)] max-w-7xl mx-auto px-6 md:px-12 lg:px-20">
    <div class="max-w-4xl mx-auto">
      <a href="/blog/" class="inline-flex items-center gap-1.5 text-label-medium text-ink-muted hover:text-brand-primary mb-8 transition-colors duration-short4">
        <Icon name="arrow_back_outline" class="w-4 h-4" />
        {t['blog.backToIndex']}
      </a>

      <header class="mb-12">
        <div class="flex flex-wrap items-center justify-between gap-4 mb-6">
          <span class="inline-flex items-center rounded-full bg-brand-primaryContainer text-brand-onPrimaryContainer px-3 py-1 text-label-medium">
            {post.data.topic}
          </span>
          <span class="inline-flex items-center gap-1.5 rounded-full border border-stroke-outlineVariant bg-surface-base px-3 py-1 text-label-medium text-ink-muted" title={t['blog.publishedOn']}>
            <Icon name="event" class="w-4 h-4" />
            <time datetime={post.data.createdAt.toISOString()}>
              {formatDate(post.data.createdAt)}
            </time>
            {post.data.updatedAt && post.data.updatedAt.toISOString() !== post.data.createdAt.toISOString() && (
              <>
                <span class="text-ink-muted/50">·</span>
                <span class="text-ink-muted/70">Updated</span>
                <time datetime={post.data.updatedAt.toISOString()}>
                  {formatDate(post.data.updatedAt)}
                </time>
              </>
            )}
          </span>
        </div>
        <h1 class="text-display-small md:text-display-medium text-ink-primary leading-[1.1] tracking-tight mb-4 [text-wrap:balance]">
          {post.data.title}
        </h1>
        <p class="text-title-medium text-ink-muted/80 mb-6">
          {post.data.excerpt}
        </p>
      </header>

      {toc.length > 0 && (
        <nav class="mb-14 p-6 md:p-7 rounded-xl bg-brand-primary/[0.025]" aria-labelledby="toc-heading">
          <h2 id="toc-heading" class="text-label-small uppercase tracking-[0.14em] text-ink-muted mb-5">
            {t['blog.tocHeading']}
          </h2>
          <ol class="sm:columns-2 sm:gap-x-10 space-y-3">
            {toc.map((item, i) => (
              <li class="flex items-baseline gap-3 break-inside-avoid">
                <span class="text-label-small text-brand-primary/50 font-semibold tabular-nums shrink-0 w-6">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <a href={`#${item.slug}`} class="flex-1 text-body-medium text-ink-primary leading-snug hover:text-brand-primary underline decoration-1 decoration-transparent underline-offset-4 hover:decoration-brand-primary/60 transition-all duration-short4">
                  {item.text}
                </a>
              </li>
            ))}
          </ol>
        </nav>
      )}

      {post.data.coverImage && (
        <figure class="mb-12 -mx-6 md:mx-0">
          <img
            src={post.data.coverImage}
            alt={post.data.coverImageAlt ?? ''}
            loading="eager"
            class="w-full h-auto rounded-none md:rounded-lg"
          />
          {post.data.coverImageAlt && (
            <figcaption class="mt-3 text-label-small text-ink-onSurfaceVariant px-6 md:px-0">
              {post.data.coverImageAlt}
            </figcaption>
          )}
        </figure>
      )}

      <div class={`prose-blog text-body-large text-ink-primary leading-[1.7] [&_h2]:text-headline-small [&_h2]:text-ink-primary [&_h2]:mt-14 [&_h2]:mb-4 [&_h2]:tracking-tight [&_h2]:scroll-mt-20 [&_h2]:md:scroll-mt-24 [&_h3]:text-title-large [&_h3]:text-ink-primary [&_h3]:mt-10 [&_h3]:mb-3 [&_h3]:scroll-mt-20 [&_h3]:md:scroll-mt-24 [&_p]:mb-6 [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-6 [&_ul]:space-y-2 [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-6 [&_ol]:space-y-2 [&_li]:leading-[1.7] [&_a]:text-brand-primary [&_a]:underline [&_a]:underline-offset-2 [&_a:hover]:text-brand-primary/80 [&_strong]:font-semibold [&_strong]:text-ink-primary [&_blockquote]:border-l-2 [&_blockquote]:border-brand-primary [&_blockquote]:pl-6 [&_blockquote]:my-10 [&_blockquote]:italic [&_blockquote]:text-title-medium [&_blockquote]:text-ink-primary [&_blockquote]:leading-[1.6] [&_blockquote_p]:mb-0 [&_code]:bg-surface-container [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-body-medium [&_pre]:bg-surface-container [&_pre]:border [&_pre]:border-stroke-outlineVariant [&_pre]:rounded-lg [&_pre]:p-4 [&_pre]:my-6 [&_pre]:overflow-x-auto [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_hr]:border-stroke-outlineVariant [&_hr]:my-12`}>
        <Content />
      </div>

      {references.length > 0 && (
        <section class="mt-16 p-6 md:p-7 rounded-xl bg-brand-primary/[0.025]" aria-labelledby="references-heading">
          <h2 id="references-heading" class="text-label-small uppercase tracking-[0.14em] text-ink-muted mb-4">
            {t['blog.referencesHeading']}
          </h2>
          <ol class="sm:columns-2 sm:gap-x-8 space-y-4">
            {references.map((ref, i) => (
              <li class="flex items-baseline gap-3 break-inside-avoid">
                <span class="text-label-small text-ink-muted/50 font-semibold tabular-nums shrink-0 w-6">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <span class="flex-1 min-w-0 text-body-medium leading-snug">
                  <a href={ref.url} rel="noopener" target="_blank" class="block text-ink-primary hover:text-brand-primary transition-colors duration-short4">
                    {ref.title}
                  </a>
                  <span class="block text-label-small text-ink-muted/50 mt-1 break-all">
                    {ref.url}
                  </span>
                </span>
              </li>
            ))}
          </ol>
        </section>
      )}

      <aside class="mt-16 p-8 md:p-10 rounded-xl bg-brand-primary/[0.04] shadow-elevation-1" aria-labelledby="cta-heading">
        <h2 id="cta-heading" class="text-title-large text-ink-primary tracking-tight mb-2 [text-wrap:balance]">
          {t['blog.ctaTitle']}
        </h2>
        <p class="text-body-medium text-ink-muted mb-5 [text-wrap:pretty]">
          {t['blog.ctaText']}
        </p>
        <a href={contactPath} class="inline-flex items-center gap-1.5 text-label-large text-brand-primary rounded-full px-4 py-2 -ml-4 hover:bg-brand-primary/[0.08] active:bg-brand-primary/[0.12] transition-all duration-short4 ease-standard">
          {t['blog.ctaLink']}
          <Icon name="arrow_outward" class="w-4 h-4" />
        </a>
      </aside>
    </div>

    {related.length > 0 && (
      <aside class="max-w-4xl mx-auto mt-24 pt-12 border-t border-stroke-outlineVariant" aria-labelledby="related-heading">
        <h2 id="related-heading" class="text-headline-small text-ink-primary tracking-tight mb-2">
          {t['blog.relatedHeading']}
        </h2>
        <p class="text-body-medium text-ink-muted/80 mb-8">
          {t['blog.relatedSubtitle']}
        </p>
        <ul class="space-y-6">
          {related.map((r) => (
            <li>
              <a href={postPath(r)} class="group block">
                <div class="flex items-center gap-3 mb-1.5">
                  <span class="text-label-small text-brand-primary">{r.data.topic}</span>
                  <span class="text-label-small text-ink-muted/60">·</span>
                  <time class="text-label-small text-ink-muted/70" datetime={r.data.createdAt.toISOString()}>
                    {formatDate(r.data.createdAt)}
                  </time>
                </div>
                <h3 class="text-title-large text-ink-primary group-hover:text-brand-primary transition-colors duration-short4 mb-1">
                  {r.data.title}
                </h3>
                <p class="text-body-medium text-ink-muted/80 line-clamp-2">
                  {r.data.excerpt}
                </p>
              </a>
            </li>
          ))}
        </ul>
      </aside>
    )}

    {(adjacent.previous || adjacent.next) && (
      <nav class="max-w-4xl mx-auto mt-16 pt-8 border-t border-stroke-outlineVariant grid grid-cols-1 md:grid-cols-2 gap-4" aria-label="Post navigation">
        {adjacent.previous ? (
          <a href={postPath(adjacent.previous)} class="group block p-5 rounded-lg bg-surface-base shadow-elevation-1 hover:shadow-elevation-3 transition-shadow duration-medium2 ease-standard">
            <span class="block text-label-small uppercase tracking-[0.14em] text-ink-muted mb-2">
              ← {t['blog.previous']}
            </span>
            <span class="block text-body-large text-ink-primary group-hover:text-brand-primary transition-colors duration-short4 [text-wrap:balance]">
              {adjacent.previous.data.title}
            </span>
          </a>
        ) : <span aria-hidden="true"></span>}
        {adjacent.next ? (
          <a href={postPath(adjacent.next)} class="group block p-5 rounded-lg bg-surface-base shadow-elevation-1 hover:shadow-elevation-3 transition-shadow duration-medium2 ease-standard text-right">
            <span class="block text-label-small uppercase tracking-[0.14em] text-ink-muted mb-2">
              {t['blog.next']} →
            </span>
            <span class="block text-body-large text-ink-primary group-hover:text-brand-primary transition-colors duration-short4 [text-wrap:balance]">
              {adjacent.next.data.title}
            </span>
          </a>
        ) : <span aria-hidden="true"></span>}
      </nav>
    )}
  </article>
  <BackToHomeSection />
</Layout>
